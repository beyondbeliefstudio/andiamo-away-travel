---
// COMPONENTS
import Heading from "@/components/Heading.astro";
import InternalHeroAlt from "@/components/InternalHeroAlt.astro";
import Layout from "@/layouts/Layout.astro";
import { baseData } from "@/data/siteData";
---

<Layout
  pageTitle="Terms & Conditions | Andiamo Away"
  description="Read the terms and conditions for using the Andiamo Away website and requesting travel planning services."
>
  <InternalHeroAlt
    pageTitle="Terms and Conditions"
    title="Terms and Conditions"
    subtitle="By accessing and using this website, you agree to the following terms and conditions. If you do not agree with these terms, please do not use the website."
    ariaLabel="Terms and Conditions Hero Section"
  />

  <section class="bg-light terms">
    <div class="container container-md">
      <div class="content-md terms__content-wrapper">
        <div class="terms__content">
          <Heading tag="h2" size="l" fontFamily="primary" marginBottom="m" weight="fw500"
            >Website Use</Heading
          >
          <p>
            This website is provided for informational purposes only. Content on this site is
            intended to describe our travel services and allow users to request information or
            contact us.
          </p>
          <p>
            We reserve the right to update or modify website content at any time without notice.
          </p>
        </div>

        <div class="terms__content">
          <Heading tag="h2" size="l" fontFamily="primary" marginBottom="m" weight="fw500"
            >Travel Planning Services</Heading
          >
          <p>
            Andiamo Away provides travel planning and advisory services. Some trips may be booked
            through trusted travel partners, and some planning services may include a separate fee
            that is disclosed before work begins.
          </p>
          <p>
            Any booking, deposit, payment, cancellation, or refund terms tied to flights, cruises,
            resorts, tours, or other travel products are determined by the applicable supplier or
            travel partner.
          </p>
        </div>

        <div class="terms__content">
          <Heading tag="h2" size="l" fontFamily="primary" marginBottom="m" weight="fw500"
            >Intellectual Property</Heading
          >
          <p>
            All content on this website, including text, images, logos, graphics, and design
            elements, is the property of Andiamo Away unless otherwise stated.
          </p>
          <p>
            You may not copy, reproduce, distribute, or use website content without written
            permission. Linking to our website is permitted.
          </p>
        </div>

        <div class="terms__content">
          <Heading tag="h2" size="l" fontFamily="primary" marginBottom="m" weight="fw500"
            >Limitation of Liability</Heading
          >
          <p>
            While we strive to keep information on this website accurate and up to date, we make no
            guarantees regarding completeness or accuracy.
          </p>
          <p>
            Andiamo Away is not liable for any damages resulting from the use or inability to use
            this website, or for changes made by third-party suppliers, carriers, hotels, cruise
            lines, or other travel providers.
          </p>
        </div>

        <div class="terms__content">
          <Heading tag="h2" size="l" fontFamily="primary" marginBottom="m" weight="fw500"
            >External Links</Heading
          >
          <p>
            This website may contain links to third-party websites or booking platforms. We are not
            responsible for the content, policies, availability, or practices of those websites.
          </p>
        </div>

        <div class="terms__content">
          <Heading tag="h2" size="l" fontFamily="primary" marginBottom="m" weight="fw500"
            >Traveler Responsibilities</Heading
          >
          <p>
            Travelers are responsible for reviewing all supplier terms, verifying passport, visa,
            vaccination, and entry requirements, and maintaining appropriate travel documents and
            insurance where needed.
          </p>
          <p>
            Unless otherwise stated in writing, travel arrangements are subject to the policies of
            the applicable supplier or partner.
          </p>
        </div>

        <div class="terms__content">
          <Heading tag="h2" size="l" fontFamily="primary" marginBottom="m" weight="fw500"
            >Changes to These Terms</Heading
          >
          <p>
            We may update these Terms and Conditions at any time. Continued use of the website
            indicates acceptance of any changes.
          </p>
        </div>

        <div class="terms__content">
          <Heading tag="h2" size="l" fontFamily="primary" marginBottom="m" weight="fw500"
            >Contact Information</Heading
          >
          <p>If you have questions about these Terms and Conditions, please contact:</p>
          <p>
            <strong>{baseData.title}</strong><br />
            <strong>Email:</strong>
            <a href={`mailto:${baseData.email}`}>{baseData.email}</a><br />
            <strong>Phone:</strong>
            <a href={`tel:${baseData.phone.replace(/\D/g, "")}`}>{baseData.phone}</a>
          </p>
        </div>
        <p><i>Last Updated: May 20, 2026</i></p>
      </div>
    </div>
  </section>
</Layout>
