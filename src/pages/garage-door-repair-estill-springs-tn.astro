---
// COMPONENTS
import InternalHero from "@/components/InternalHero.astro";
import Layout from "@/layouts/Layout.astro";
import Heading from "@/components/Heading.astro";
import SplitOverlay from "@/components/SplitOverlay.astro";
import Links from "@/components/Links.astro";
import CardGrid from "@/components/CardGrid.astro";
import ServicesCard from "@/components/ServicesCard.astro";
import FAQ from "@/components/FAQ.astro";

// IMAGES
import homeGarage from "@/assets/homeGarage10.jpeg";
import seanGarage from "@/assets/seanGarage.png";
import closingDoor from "@/assets/closingDoor.png";
import repairingDoor from "@/assets/repairingDoor.png";
import tuneUp from "@/assets/tuneup.png";

// ICONS
import quality from "@/assets/quality.svg";
import pricing from "@/assets/pricing.svg";
import available from "@/assets/available.svg";

import { getCollection } from "astro:content";
const faq = await getCollection("garageDoorRepairEstillSpringsFAQ");

const faqData = faq.map(item => ({
  tag: item.data.tag,
  question: item.data.question,
  answer: item.data.answer,
}));

const repairCardData = [
  {
    title: "Complete System Inspection",
    description:
      "We inspect springs, cables, rollers, tracks, hinges, opener components, and safety sensors to identify the root cause of the issue.",
    icon: quality,
    iconAlt: "Inspection checklist icon",
  },
  {
    title: "Clear Diagnosis & Transparent Estimate",
    description:
      "Once the problem is identified, we explain the repair clearly and provide an upfront estimate before starting any work.",
    icon: pricing,
    iconAlt: "Transparent pricing icon",
  },
  {
    title: "Professional Repair & Testing",
    description:
      "After completing the repair, we test the door for balance, smooth operation, and safety function to ensure everything works properly.",
    icon: available,
    iconAlt: "Quality assurance icon",
  },
];

const locationServiceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  serviceType: "Garage Door Repair",
  areaServed: {
    "@type": "City",
    name: "Estill Springs",
    addressRegion: "TN",
  },
  provider: {
    "@type": "LocalBusiness",
    name: "Lambo's Garage Door Service",
  },
};
---

<Layout
  pageTitle="Garage Door Repair in Estill Springs, TN | Lambo's Garage Door Service"
  description="Local garage door repair in Estill Springs, TN. Fast service for broken springs, opener problems, and emergency repairs across Franklin County."
>
  <script type="application/ld+json" set:html={JSON.stringify(locationServiceSchema)} />

  <InternalHero
    pageTitle="Garage Door Repair in Estill Springs, TN"
    title="Fast, Reliable Garage Door Service for Estill Springs Homes"
    ariaLabel="Garage Door Repair Hero Section"
    imageSrc={homeGarage}
    imageAlt="Home garage with a well-maintained garage door"
    primaryCtaText="Schedule Garage Door Repair"
    primaryCtaHref="/contact"
    secondaryCtaText="Call Now for Service"
    secondaryCtaHref="tel:+19312229963"
  >
    <p>
      When your garage door stops working properly, you need reliable service from someone nearby
      who understands the area. Lambo’s Garage Door Service proudly provides professional garage
      door repair in Estill Springs, Tennessee, helping homeowners restore safe and dependable
      operation quickly.
    </p>
    <p>
      Because our business is located right here in Estill Springs, we are able to respond quickly
      to garage door repair calls throughout the community and surrounding Franklin County areas.
      Whether you're dealing with a broken spring, off-track door, damaged cable, or opener
      malfunction, we diagnose the issue and fix it correctly.
    </p>
    <div class="btn-wrapper btn-wrapper--left">
      <Links variant="primary" href="/contact">Schedule Garage Door Repair</Links>
      <Links variant="outline" href="tel:+19312229963">Call Now for Service</Links>
    </div>
  </InternalHero>

  <SplitOverlay
    title="Local Garage Door Repair in Estill Springs"
    imgSrc={tuneUp}
    imgAlt="Garage door tune-up service"
    background="bg-primary"
    orientation="right"
  >
    <p>
      Garage doors are one of the most frequently used systems in any home. Many homeowners in
      Estill Springs rely on their garage doors multiple times each day, especially when the garage
      serves as the primary entrance to the house.
    </p>

    <p>
      Over time, the constant movement of springs, rollers, hinges, and cables naturally causes wear
      throughout the system. Weather conditions across Franklin County, including seasonal humidity
      and temperature swings, can also contribute to metal fatigue and mechanical stress.
    </p>

    <p>
      Because our shop is located in Estill Springs, we are able to provide fast and dependable
      service to homeowners throughout the area. Our goal is to identify the root cause of the
      problem and restore smooth, reliable garage door operation.
    </p>
  </SplitOverlay>

  <SplitOverlay
    title="Common Garage Door Problems We Repair in Estill Springs"
    imgSrc={seanGarage}
    imgAlt="Sean performing garage door maintenance service"
    background="bg-light"
    orientation="left"
  >
    <p>
      Most garage door issues start as small mechanical problems before eventually causing a
      complete system failure.
    </p>

    <p>Homeowners in Estill Springs frequently contact us for repairs involving:</p>

    <ul>
      <li><p>Broken torsion or extension springs</p></li>
      <li><p>Snapped or frayed lift cables</p></li>
      <li><p>Garage doors that have come off track</p></li>
      <li><p>Worn rollers causing loud grinding or vibration</p></li>
      <li><p>Bent or misaligned tracks</p></li>
      <li><p>Garage door opener motor problems</p></li>
      <li><p>Remote or keypad connection issues</p></li>
      <li><p>Safety sensor alignment problems</p></li>
    </ul>

    <p>
      If your garage door suddenly feels extremely heavy or refuses to lift, a broken spring is
      often the cause. In that case, our <strong
        ><a href="/garage-door-spring-replacement">Garage Door Spring Replacement</a></strong
      > service can safely restore proper door balance.
    </p>

    <p>
      If the opener motor runs but the door does not move properly, our <strong
        ><a href="/garage-door-opener-repair">Garage Door Opener Repair</a></strong
      > & <strong><a href="/garage-door-installation">Installation</a></strong> service can restore dependable
      operation.
    </p>
  </SplitOverlay>

  <SplitOverlay
    title="Why Prompt Garage Door Repair Matters"
    imgSrc={repairingDoor}
    imgAlt="Repairing a garage door"
    background="bg-dark"
    orientation="right"
  >
    <p>
      Many homeowners continue using their garage door even after noticing unusual noises or
      inconsistent operation. Unfortunately, small issues can quickly lead to larger and more
      expensive repairs.
    </p>

    <Heading tag="h3" size="m" fontFamily="primary" marginBottom="s" weight="fw500"
      >Prevent Additional Mechanical Damage</Heading
    >

    <p>
      When springs or cables begin to wear down, the opener motor must work harder to lift the door.
      Over time this strain can lead to motor failure or additional mechanical problems.
    </p>

    <Heading tag="h3" size="m" fontFamily="primary" marginBottom="s" weight="fw500"
      >Maintain Home Safety</Heading
    >

    <p>
      Garage doors operate under high tension and can weigh hundreds of pounds. Damaged springs or
      cables can fail unexpectedly and create safety risks.
    </p>

    <p>
      Addressing problems early helps keep your garage door system operating safely and reliably.
    </p>
  </SplitOverlay>

  <section class="bg-light">
    <div class="container container-md column-small">
      <div class="content-md">
        <Heading tag="h2" size="xl" fontFamily="primary" marginBottom="l" weight="fw500">
          Our Garage Door Repair Process
        </Heading>
        <p class="margin-bottom-xl">
          When you schedule service in Estill Springs, we follow a straightforward process designed
          to deliver dependable results. When you schedule service in Estill Springs, we follow a
          straightforward process designed to deliver dependable results.
        </p>
      </div>
      <div class="content-full">
        <CardGrid cardData={repairCardData} />
      </div>
    </div>
  </section>

  <FAQ faq={faqData} />

  <SplitOverlay
    title="Serving Estill Springs and Nearby Communities"
    imgSrc={closingDoor}
    imgAlt="Closing a garage door"
    background="bg-primary"
    orientation="left"
  >
    <p>
      While we are based in Estill Springs, our garage door repair services extend throughout
      surrounding communities across Franklin and Coffee County.
    </p>

    <p>We frequently serve homeowners in:</p>

    <ul>
      <li>
        <p><a href="/garage-door-repair-estill-springs-tn">Estill Springs</a></p>
      </li>
      <li>
        <p><a href="/garage-door-repair-winchester-tn">Winchester</a></p>
      </li>
      <li>
        <p><a href="/garage-door-repair-decherd-tn">Decherd</a></p>
      </li>
      <li>
        <p><a href="/garage-door-repair-tullahoma-tn">Tullahoma</a></p>
      </li>
      <li>
        <p><a href="/garage-door-repair-lynchburg-tn">Lynchburg</a></p>
      </li>
    </ul>

    <p>
      If you're searching for garage door repair near Estill Springs, our team is ready to help.
    </p>
  </SplitOverlay>

  <section>
    <div class="container container-md column-main">
      <div class="content-md">
        <Heading tag="h2" size="xl" fontFamily="primary" marginBottom="l" weight="fw500">
          Garage Door Services Available in Estill Springs
        </Heading>
        <p class="margin-bottom-xl">
          In addition to garage door repair, we provide a full range of garage door services
          throughout Estill Springs and surrounding communities.
        </p>
      </div>
      <div class="content-full">
        <div class="services-grid flex">
          <ServicesCard descriptionType="short" excludeIds={[1]} />
        </div>
      </div>
    </div>
  </section>
</Layout>
