---
// COMPONENTS
import Heading from "@/components/Heading.astro";
import InternalHeroAlt from "@/components/InternalHeroAlt.astro";
import Layout from "@/layouts/Layout.astro";
import { baseData } from "@/data/siteData";
---

<Layout
  pageTitle="Accessibility Statement | Andiamo Away"
  description="Andiamo Away is committed to making our website accessible to all travelers and continuously improving the experience for every visitor."
>
  <InternalHeroAlt
    pageTitle="Accessibility Statement"
    title="Our Commitment to Accessibility"
    subtitle="Andiamo Away is committed to making our website accessible and usable for as many people as possible, including individuals with disabilities."
    ariaLabel="Accessibility Hero Section"
  />

  <section class="bg-light terms">
    <div class="container container-md">
      <div class="content-md terms__content-wrapper">
        <div class="terms__content">
          <Heading tag="h2" size="l" fontFamily="primary" marginBottom="m" weight="fw500"
            >Accessibility Statement</Heading
          >
          <p>
            We aim to follow best practices for accessibility and usability by designing and
            maintaining our website with accessibility in mind. Our site is custom coded and built
            using semantic HTML, proper heading structure, descriptive image alt text, and
            keyboard-friendly navigation to support assistive technologies.
          </p>
        </div>
        <div class="terms__content">
          <Heading tag="h2" size="l" fontFamily="primary" marginBottom="m" weight="fw500"
            >Ongoing Efforts</Heading
          >
          <p>
            Accessibility is an ongoing effort. We continue to review and improve our website to
            enhance accessibility, from the main pages to the contact form and supporting content.
          </p>

          <p>
            If you experience difficulty accessing any part of our website or need assistance,
            please contact us and we will do our best to help.
          </p>
        </div>

        <div class="terms__content">
          <Heading tag="h2" size="l" fontFamily="primary" marginBottom="m" weight="fw500"
            >Contact Information</Heading
          >
          <p>
            <strong>Email:</strong>
            <a href={`mailto:${baseData.email}`}>{baseData.email}</a><br />
            <strong>Phone:</strong>
            <a href={`tel:${baseData.phone.replace(/\D/g, "")}`}>{baseData.phone}</a>
          </p>
        </div>
        <p><i>Last Updated: May 20, 2026</i></p>
      </div>
    </div>
  </section>
</Layout>
