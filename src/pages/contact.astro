---
// COMPONENTS
import Layout from "@/layouts/Layout.astro";
import InternalHero from "@/components/InternalHero.astro";
import ContactForm from "@/components/ContactForm.astro";
import Heading from "@/components/Heading.astro";

// IMAGES
import garageHome from "@/assets/garageHome.jpg";
---

<Layout
  pageTitle="Contact Us"
  description="Get in touch with Lambo's Garage Door Service for all your garage door needs. We're here to help with repairs, installations, and inquiries."
>
  <InternalHero
    pageTitle="Contact Us"
    title="Get in Touch with Lambo's Garage Door Service"
    subtitle="Whether you have questions about our services, need a quote, or want to schedule an appointment, we're here to help. Contact us today and experience the difference of working with a local garage door expert who cares about your satisfaction."
    ariaLabel="Contact Us Hero Section"
    imageSrc={garageHome}
    imageAlt="Contact Lambo's Garage Door Service"
  />

  <section class="contact bg-light">
    <div class="container container-lg">
      <div class="content-lg contact__form">
        <Heading tag="h2" size="xl" fontFamily="primary" marginBottom="m" weight="fw400"
          >Send Us a Message</Heading
        >
        <p>Please fill out the form below and we will get back to you as soon as possible.</p>
        <ContactForm />
      </div>
    </div>
  </section>
</Layout>
