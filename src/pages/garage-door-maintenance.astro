---
// COMPONENTS
import InternalHero from "@/components/InternalHero.astro";
import Layout from "@/layouts/Layout.astro";
import Heading from "@/components/Heading.astro";
import SplitOverlay from "@/components/SplitOverlay.astro";
import Links from "@/components/Links.astro";
import CardGrid from "@/components/CardGrid.astro";
import ServicesCard from "@/components/ServicesCard.astro";
import FAQ from "@/components/FAQ.astro";

// IMAGES
import garageHome from "@/assets/garageHome.jpg";
import sean from "@/assets/sean.jpg";
import closingDoor from "@/assets/closingDoor.png";
import garageNewDoor from "@/assets/garageNewDoor.jpg";
import tuneUp from "@/assets/tuneup.png";
import garageTuneUp from "@/assets/garageTuneUp.jpg";
import seanGarage from "@/assets/seanGarage.png";

// ICONS
import quality from "@/assets/quality.svg";
import pricing from "@/assets/pricing.svg";
import available from "@/assets/available.svg";

// DATA
import { getCollection } from "astro:content";
const faq = await getCollection("garageDoorMaintenanceFAQ");

const faqData = faq.map(item => ({
  tag: item.data.tag,
  question: item.data.question,
  answer: item.data.answer,
}));

const garageDoorMaintenanceProcess = [
  {
    title: "Full System Inspection",
    description:
      "We evaluate springs, cables, rollers, hinges, tracks, and opener components to check for wear, damage, or misalignment.",
    icon: quality,
    iconAlt: "Full system inspection icon",
  },
  {
    title: "Tune-Up & Lubrication",
    description:
      "Moving components are lubricated and adjusted to reduce friction and ensure smooth operation.",
    icon: pricing,
    iconAlt: "Tune-up and lubrication icon",
  },
  {
    title: "Safety Testing & Performance Check",
    description:
      "We test door balance, opener response, and safety sensors to confirm the system operates correctly.",
    icon: available,
    iconAlt: "Safety testing and performance check icon",
  },
];

const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  serviceType: "Garage Door Maintenance",
  provider: {
    "@type": "LocalBusiness",
    name: "Lambo's Garage Door Service",
  },
  areaServed: ["Franklin County TN", "Coffee County TN"],
};
---

<Layout
  pageTitle="Garage Door Opener Repair in Franklin & Coffee County, TN"
  description="Is your garage door opener not working? We provide professional garage door opener repair in Franklin & Coffee County. Call today."
>
  <script type="application/ld+json" set:html={JSON.stringify(serviceSchema)} />

  <InternalHero
    pageTitle="Garage Door Maintenance in Central Tennessee"
    title="Keep Your Garage Door Running Smoothly Year After Year"
    ariaLabel="Garage Door Maintenance Hero Section"
    imageSrc={garageNewDoor}
    imageAlt="Newly installed garage door"
    primaryCtaText="Schedule Garage Door Maintenance"
    primaryCtaHref="/contact"
    secondaryCtaText="Call Now for Service"
    secondaryCtaHref="tel:+19312229963"
  >
    <p>
      Regular garage door maintenance helps prevent unexpected breakdowns and keeps your system
      operating safely and quietly. Our annual maintenance service includes a full tune-up,
      lubrication, safety inspection, and adjustment to ensure every component of your garage door
      system is working properly.
    </p>
    <p>
      We proudly serve homeowners in Winchester, Tullahoma, Lynchburg, Estill Springs, Decherd, and
      surrounding communities across the area.
    </p>
    <div class="btn-wrapper btn-wrapper--left">
      <Links variant="primary" href="/contact">Schedule Garage Door Maintenance</Links>
      <Links variant="outline" href="tel:+19312229963">Call Now for Service</Links>
    </div>
  </InternalHero>

  <!-- Content for the About Us page goes here -->
  <section class="bg-primary">
    <div class="container container-md">
      <div class="content-md">
        <Heading tag="h2" size="xl" fontFamily="primary" marginBottom="l" weight="fw500"
          >Prevent Problems Before They Start</Heading
        >
        <p>
          Most homeowners use their garage door multiple times every day without thinking about the
          mechanical system behind it. Over time, the constant movement of springs, rollers, hinges,
          and cables naturally causes wear.
        </p>

        <p>
          Without regular maintenance, small issues like loose hardware or worn rollers can
          gradually turn into larger repairs. In many cases, the problems we repair across Franklin
          and Coffee County could have been avoided with routine service.
        </p>

        <p>
          Annual garage door maintenance helps extend the lifespan of your door system and keeps it
          operating safely and quietly.
        </p>
      </div>
    </div>
  </section>

  <SplitOverlay
    title="What's Included in a Garage Door Tune-Up"
    imgSrc={tuneUp}
    imgAlt="Garage door tune-up service"
    background="bg-light"
    orientation="left"
  >
    <p>
      Our maintenance service is designed to evaluate the entire garage door system and ensure every
      moving part is functioning correctly.
    </p>

    <p><strong>A typical maintenance appointment includes:</strong></p>

    <ul>
      <li><p>Complete lubrication of rollers, hinges, bearings, and springs</p></li>
      <li><p>Inspection of torsion or extension springs</p></li>
      <li><p>Hardware tightening and adjustment</p></li>
      <li><p>Track inspection and alignment check</p></li>
      <li><p>Roller wear inspection</p></li>
      <li><p>Cable condition inspection</p></li>
      <li><p>Opener system evaluation</p></li>
      <li><p>Safety sensor testing</p></li>
      <li><p>Balance and door movement testing</p></li>
    </ul>

    <p>
      By inspecting each component carefully, we can identify potential issues early before they
      develop into costly repairs.
    </p>
  </SplitOverlay>

  <SplitOverlay
    title="Why Annual Garage Door Maintenance Matters"
    imgSrc={seanGarage}
    imgAlt="Sean performing garage door maintenance service"
    background="bg-white"
    orientation="right"
  >
    <p>Many garage door problems start with small mechanical changes that go unnoticed.</p>

    <Heading tag="h3" size="m" fontFamily="primary" marginBottom="s" weight="fw500"
      >Prevent Unexpected Breakdowns</Heading
    >

    <p>
      A loose bolt, worn roller, or misaligned track may not seem serious at first, but these issues
      can eventually lead to larger mechanical failures.
    </p>

    <p>
      Regular maintenance allows us to catch these issues early and correct them before they affect
      the entire system.
    </p>

    <Heading tag="h3" size="m" fontFamily="primary" marginBottom="s" weight="fw500"
      >Improve Safety</Heading
    >

    <p>
      Garage doors are heavy moving systems that rely on springs and cables under significant
      tension. Routine inspection ensures safety features like auto-reverse sensors are functioning
      correctly and that your door operates safely.
    </p>

    <Heading tag="h3" size="m" fontFamily="primary" marginBottom="s" weight="fw500"
      >Extend the Life of Your System</Heading
    >

    <p>
      Proper lubrication and adjustment reduce strain on springs, rollers, and opener motors. This
      helps extend the overall lifespan of your garage door system.
    </p>
  </SplitOverlay>

  <SplitOverlay
    title="Signs Your Garage Door May Need Maintenance"
    imgSrc={garageTuneUp}
    imgAlt="Garage door tune-up service"
    background="bg-primary"
    orientation="left"
  >
    <p>
      Even if your door is still operating, certain warning signs may indicate it's time for a
      tune-up.
    </p>

    <p>
      <strong
        >Homeowners across Winchester and Tullahoma often schedule maintenance when they notice:</strong
      >
    </p>

    <ul>
      <li><p>Increased noise during operation</p></li>
      <li><p>Slower opening or closing speed</p></li>
      <li><p>Slight shaking or vibration when moving</p></li>
      <li><p>Uneven door movement</p></li>
      <li><p>Remote response delays</p></li>
      <li><p>Loose hardware or visible wear</p></li>
    </ul>

    <p>
      If any of these symptoms appear, maintenance can often resolve the issue before repair becomes
      necessary.
    </p>

    <p>
      If a larger issue is discovered during inspection, we may recommend <strong
        ><a href="/garage-door-repair">Garage Door Repair</a></strong
      > or <strong><a href="/garage-door-spring-replacement">Spring Replacement</a></strong> to restore
      full functionality.
    </p>
  </SplitOverlay>

  <section class="bg-light">
    <div class="container container-md column-small">
      <div class="content-md">
        <Heading tag="h2" size="xl" fontFamily="primary" marginBottom="l" weight="fw500">
          Our Garage Door Maintenance Process
        </Heading>
        <p class="margin-bottom-xl">
          We follow a thorough inspection process to ensure your garage door system operates safely
          and efficiently.
        </p>
      </div>
      <div class="content-full">
        <CardGrid cardData={garageDoorMaintenanceProcess} />
      </div>
    </div>
  </section>

  <FAQ faq={faqData} />

  <SplitOverlay
    title="Garage Door Service Across Franklin & Coffee County"
    imgSrc={closingDoor}
    imgAlt="Closing a garage door"
    background="bg-light"
    orientation="right"
  >
    <p>
      Lambo’s Garage Door Service proudly provides professional garage door repair, installation,
      and maintenance throughout Franklin County, Coffee County, and surrounding Central Tennessee
      communities.
    </p>

    <p>Because we are based nearby in Estill Springs, we regularly serve homeowners in:</p>

    <ul>
      <li>
        <p><a href="/garage-door-repair-tullahoma-tn">Tullahoma</a></p>
      </li>
      <li>
        <p><a href="/garage-door-repair-winchester-tn">Winchester</a></p>
      </li>
      <li>
        <p><a href="/garage-door-repair-decherd-tn">Decherd</a></p>
      </li>
      <li>
        <p><a href="/garage-door-repair-estill-springs-tn">Estill Springs</a></p>
      </li>
      <li>
        <p><a href="/garage-door-repair-lynchburg-tn">Lynchburg</a></p>
      </li>
    </ul>
  </SplitOverlay>

  <section>
    <div class="container container-md column-main">
      <div class="content-md">
        <Heading tag="h2" size="xl" fontFamily="primary" marginBottom="l" weight="fw500">
          Explore Our Other Garage Door Services
        </Heading>
        <p class="margin-bottom-xl">
          To keep your entire system operating safely and efficiently, we also provide the following
          services.
        </p>
      </div>
      <div class="content-full">
        <div class="services-grid flex">
          <ServicesCard descriptionType="short" excludeIds={[5]} />
        </div>
      </div>
    </div>
  </section>
</Layout>
