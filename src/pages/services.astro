---
// COMPONENTS
import InternalHero from "@/components/InternalHero.astro";
import Layout from "@/layouts/Layout.astro";
import ServicesCard from "@/components/ServicesCard.astro";
import Heading from "@/components/Heading.astro";

// IMAGES
import garageHome2 from "@/assets/garageHome2.jpg";
---

<Layout
  pageTitle="Garage Door Services | Repair, Installation & Openers"
  description="Professional garage door services including repair, spring replacement, opener repair, installation, and maintenance across Franklin and Coffee County."
>
  <InternalHero
    pageTitle="Complete Garage Door Services for Your Home"
    title="Comprehensive Garage Door Solutions"
    ariaLabel="Services Hero Section"
    imageSrc={garageHome2}
    imageAlt="Garage door service and repair"
  >
    <p>
      From spring replacements and opener repairs to complete installations and emergency service,
      we provide a full suite of garage door services tailored to your needs throughout Estill
      Springs, Tullahoma, Murfreesboro, Winchester, Manchester, and surrounding Middle Tennessee
      areas.
    </p>
  </InternalHero>

  <section class="bg-light">
    <div class="container container-md">
      <div class="content-md">
        <Heading tag="h2" size="xl" fontFamily="primary" marginBottom="l" weight="fw500">
          Our Garage Door Services
        </Heading>
        <p>
          At Lambo's Garage Door Service, I provide a full range of garage door services to
          homeowners throughout Middle Tennessee. Whether you need a quick repair, a new door
          installation or regular maintenance, I am here to help. Below are some of the most popular
          services I offer:
        </p>
      </div>
    </div>
  </section>

  <section>
    <div class="container container-md">
      <div class="content-full">
        <div class="services-grid grid-auto-2">
          <ServicesCard descriptionType="full" />
        </div>
      </div>
    </div>
  </section>
</Layout>
