---
// COMPONENTS
import Layout from "@/layouts/Layout.astro";
import SplitOverlay from "@/components/SplitOverlay.astro";
import ValuesSection from "@/components/ValuesSection.astro";
import FAQ from "@/components/FAQ.astro";
import OwnerHighlights from "@/components/OwnerHighlights.astro";
import { getCollection } from "astro:content";

// IMAGES
import stainRemover from "@/assets/stainRemover.jpg";
import InternalHeroAlt from "@/components/InternalHeroAlt.astro";
import Reviews from "@/components/Reviews.astro";
import Heading from "@/components/Heading.astro";

const faq = await getCollection("aboutFAQ");

const faqData = faq.map(item => ({
  tag: item.data.tag,
  question: item.data.question,
  answer: item.data.answer,
}));
---

<Layout
  pageTitle="Carpet, Tile & Floor Cleaning Services in Monroe, NC"
  description="Need carpet, tile, or floor cleaning services? Contact All The Rage Carpet Cleaning in Monroe, NC to schedule fast, reliable service today."
>
  <InternalHeroAlt
    title="Carpet, Tile & Floor Cleaning Services"
    ariaLabel="About Us Hero Section"
    imageSrc={stainRemover}
    imageAlt="About All The Rage Carpet Cleaning"
  >
    <p>
      Professional cleaning services for homes and businesses. Done right, without the hassle. If
      it’s dirty, stained, or overdue for a proper clean, we can take care of it.
    </p>
  </InternalHeroAlt>

  <SplitOverlay
    class="services-split"
    title="Carpet Cleaning"
    imgSrc={stainRemover}
    imgAlt="All The Rage Carpet Cleaning team at work"
  >
    <p>
      Carpet sees the most wear out of anything in your home. Dirt, spills, pets, and everyday
      traffic all add up over time.
    </p>
    <p>We provide deep carpet cleaning that helps remove:</p>
    <ul>
      <li><p>Embedded dirt and dust</p></li>
      <li><p>Pet stains and odors</p></li>
      <li><p>High-traffic wear patterns</p></li>
      <li><p>General buildup over time</p></li>
    </ul>
    <p>Whether it's one room or your entire home, we'll help bring your carpet back to life.</p>
  </SplitOverlay>

  <SplitOverlay
    class="services-split"
    title="Upholstery & Furniture Cleaning"
    imgSrc={stainRemover}
    imgAlt="All The Rage Carpet Cleaning team at work"
    background="bg-light"
  >
    <p>Furniture gets just as much use as your floors, but it's often overlooked.</p>
    <p>We clean:</p>
    <ul>
      <li><p>Couches and sectionals</p></li>
      <li><p>Chairs and recliners</p></li>
      <li><p>Fabric furniture of all types</p></li>
    </ul>
    <p>
      Our process is designed to safely clean fabric while improving appearance and removing odors.
    </p>
  </SplitOverlay>

  <SplitOverlay
    class="services-split"
    title="Tile and Grout Cleaning"
    imgSrc={stainRemover}
    imgAlt="Before and after photo of carpet cleaning in Monroe, NC"
  >
    <p>
      Mopping can only do so much. Over time, grime builds up deep in grout lines and textured tile
      surfaces.
    </p>
    <p>We use professional equipment to:</p>
    <ul>
      <li><p>Break down built-up dirt and grime</p></li>
      <li><p>Restore the original look of your tile</p></li>
      <li><p>Brighten and clean grout lines</p></li>
    </ul>
    <p>This is one of the biggest visual transformations we see in homes.</p>
  </SplitOverlay>

  <SplitOverlay
    class="services-split"
    title="Hardwood Floor Cleaning"
    imgSrc={stainRemover}
    imgAlt="Before and after photo of carpet cleaning in Monroe, NC"
    background="bg-light"
  >
    <p>Hardwood floors need the right kind of care to avoid damage.</p>
    <p>We provide safe cleaning that:</p>
    <ul>
      <li><p>Removes dirt without harming the finish</p></li>
      <li><p>Helps restore natural appearance</p></li>
      <li><p>Leaves floors looking clean without residue</p></li>
    </ul>
    <p>No harsh treatments. Just proper cleaning done the right way.</p>
  </SplitOverlay>

  <SplitOverlay
    class="services-split"
    title="Emergency Cleaning Services"
    imgSrc={stainRemover}
    imgAlt="Before and after photo of carpet cleaning in Monroe, NC"
  >
    <p><strong>Fast Response When You Need It</strong></p>
    <p>Some situations can't wait.</p>
    <p>
      Whether it's a spill, pet accident, or unexpected issue, we offer fast-response cleaning to
      help prevent further damage and get things back under control.
    </p>
    <p>Common emergency jobs include:</p>
    <ul>
      <li><p>Water spills or minor flooding</p></li>
      <li><p>Pet accidents and odor removal</p></li>
      <li><p>Heavy stains that need immediate attention</p></li>
      <li><p>Move-out or last-minute cleanups</p></li>
    </ul>
    <p>If it's urgent, give us a call. That's the fastest way to get help.</p>
    <p>(704) 254-3754</p>
  </SplitOverlay>

  <SplitOverlay
    class="services-split"
    title="Quartz, Marble & Granite Cleaning"
    imgSrc={stainRemover}
    imgAlt="Before and after photo of carpet cleaning in Monroe, NC"
    background="bg-light"
  >
    <p>Stone surfaces require a more careful approach than standard cleaning.</p>
    <p>We clean:</p>
    <ul>
      <li><p>Quartz countertops</p></li>
      <li><p>Marble surfaces</p></li>
      <li><p>Granite countertops and surfaces</p></li>
    </ul>
    <p>Our process removes buildup while protecting the integrity of the material.</p>
  </SplitOverlay>

  <ValuesSection />

  <section>
    <div class="container container-full column-small">
      <div class="content-md">
        <Heading tag="h3" size="xxl" fontFamily="primary" marginBottom="s" weight="fw800">
          What Our Clients Are Saying
        </Heading>
        <p>
          We take pride in our work and it shows in the feedback we get from our clients. Here are
          just a few of the reviews that highlight our commitment to quality, professionalism, and
          customer satisfaction.
        </p>
      </div>

      <div class="content-full">
        <Reviews />
      </div>
    </div>
  </section>
</Layout>

<style lang="scss" is:global>
  .services-split {
    .container {
      padding-top: 1rem;
      padding-bottom: 1rem;
    }

    .split__img-wrapper {
      position: absolute;
    }

    .split__col {
      min-height: 0px;
    }
  }
</style>
