---
// COMPONENTS
import Layout from "@/layouts/Layout.astro";
import SplitOverlay from "@/components/SplitOverlay.astro";
import ValuesSection from "@/components/ValuesSection.astro";
import FAQ from "@/components/FAQ.astro";
import OwnerHighlights from "@/components/OwnerHighlights.astro";

// IMAGES
import stainRemover from "@/assets/stainRemover.jpg";
import InternalHeroAlt from "@/components/InternalHeroAlt.astro";

// Data for FAQ section
import { getCollection } from "astro:content";
const faq = await getCollection("aboutFAQ");

const faqData = faq.map(item => ({
  tag: item.data.tag,
  question: item.data.question,
  answer: item.data.answer,
}));
---

<Layout
  pageTitle="Contact Lambo’s Garage Door Service | Schedule Repair"
  description="Need garage door repair or service? Contact Lambo’s Garage Door Service in Estill Springs to schedule fast, reliable service today."
>
  <InternalHeroAlt
    title="About All The Rage Carpet Cleaning"
    ariaLabel="About Us Hero Section"
    imageSrc={stainRemover}
    imageAlt="About All The Rage Carpet Cleaning"
  >
    <p>
      Whether you have questions about our services, need a quote, or want to schedule an
      appointment, we're here to help. Contact us today and experience the difference of working
      with a local garage door expert who cares about your satisfaction.
    </p>
  </InternalHeroAlt>

  <SplitOverlay
    title="A Local Business Built on Experience"
    imgSrc={stainRemover}
    imgAlt="All The Rage Carpet Cleaning team at work"
  >
    <p>
      All The Rage Carpet Cleaning is a veteran-owned business built on over 25 years of hands-on
      experience in carpet and floor cleaning.
    </p>
    <p>
      What started as a way to provide honest, dependable service has grown into a trusted local
      business serving homeowners and businesses throughout Monroe and nearby areas.
    </p>
    <p>
      From day one, the focus has been simple. Do the job right, treat people fairly, and stand
      behind the work.
    </p>
  </SplitOverlay>

  <OwnerHighlights />

  <SplitOverlay
    title="How We Approach Our Work"
    imgSrc={stainRemover}
    imgAlt="All The Rage Carpet Cleaning team at work"
    orientation="left"
  >
    <p>
      There's a big difference between a quick cleaning and one that actually makes a lasting
      difference.
    </p>
    <p>We take the time to:</p>
    <ul>
      <li><p>Properly assess each job before getting started</p></li>
      <li><p>Use the right methods for each surface</p></li>
      <li><p>Focus on problem areas, not just the easy spots</p></li>
    </ul>
    <p>We're not here to rush through jobs. We're here to make sure it's done right.</p>
  </SplitOverlay>

  <ValuesSection />

  <SplitOverlay
    title="Serving Monroe and Surrounding Areas"
    imgSrc={stainRemover}
    imgAlt="Before and after photo of carpet cleaning in Monroe, NC"
  >
    <p>We're based in Monroe and regularly work throughout the surrounding communities.</p>
    <p><strong>Areas we serve:</strong></p>
    <ul>
      <li><p>Indian Trail</p></li>
      <li><p>Waxhaw</p></li>
      <li><p>Weddington</p></li>
      <li><p>Marshville</p></li>
      <li><p>Wingate</p></li>
      <li><p>Matthews</p></li>
      <li><p>Mint Hill</p></li>
    </ul>
    <p>If you're nearby and not sure if we cover your area, just reach out.</p>
  </SplitOverlay>

  <FAQ faq={faqData} />
</Layout>
