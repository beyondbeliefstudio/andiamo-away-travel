---
// COMPONENTS
import Layout from "@/layouts/Layout.astro";
import MainHero from "@/components/MainHero.astro";
import Heading from "@/components/Heading.astro";
import Links from "@/components/Links.astro";
import ScrollingMarquee from "@/components/ScrollingMarquee.astro";
import SplitOverlay from "@/components/SplitOverlay.astro";
import Process from "@/components/Process.astro";
import ValuesSection from "@/components/ValuesSection.astro";

import cleaningWorks from "@/assets/cleaningWorks.jpg";
import carpet from "@/assets/carpet.jpg";
import flooring from "@/assets/flooring.jpg";
import mattress from "@/assets/mattress.jpg";
import kitchen from "@/assets/kitchen.jpg";

// REVIEWS DATA
import { getCollection } from "astro:content";
import FullOverlay from "@/components/FullOverlay.astro";
import Reviews from "@/components/Reviews.astro";
---

<Layout
  pageTitle="All The Rage Carpet Cleaning | Professional Cleaning Services in Monroe, NC"
  description="All The Rage Carpet Cleaning offers expert carpet cleaning, tile and grout cleaning, upholstery cleaning, and water damage restoration services in Monroe, NC. Book your cleaning today!"
>
  <MainHero />

  <section>
    <div class="container container-md">
      <div class="content-md">
        <Heading tag="h2" size="xxl" fontFamily="primary" marginBottom="m" weight="fw800">
          A Proper Clean Makes a Big Difference
        </Heading>
        <p>
          Most people don’t realize how much dirt, buildup, and wear is sitting in their floors and
          furniture until it’s actually cleaned the right way. That’s what we focus on.
        </p>
        <p>
          At All The Rage Carpet Cleaning, we go beyond surface-level cleaning. We take the time to
          do it right so your carpets, floors, and furniture don’t just look better for a day, they
          stay cleaner longer.
        </p>
        <p>
          Whether it’s one room or an entire home, we approach every job with the same attention to
          detail.
        </p>
        <div class="btn-wrapper">
          <Links
            variant="primary"
            href="/services"
            ariaLabel="View our carpet cleaning services in Monroe, NC">Explore Our Services</Links
          >
        </div>
      </div>
    </div>
  </section>
  <ScrollingMarquee />

  <ValuesSection />

  <SplitOverlay
    title="Serving Monroe and Surrounding Areas"
    imgSrc={carpet}
    imgAlt="Before and after photo of carpet cleaning in Monroe, NC"
  >
    <p>We're based in Monroe and regularly work throughout the surrounding communities.</p>
    <p><strong>Areas we serve:</strong></p>
    <ul>
      <li><p>Indian Trail</p></li>
      <li><p>Waxhaw</p></li>
      <li><p>Weddington</p></li>
      <li><p>Marshville</p></li>
      <li><p>Wingate</p></li>
      <li><p>Matthews</p></li>
      <li><p>Mint Hill</p></li>
    </ul>
    <p>If you're nearby and not sure if we cover your area, just reach out.</p>
  </SplitOverlay>

  <FullOverlay backgroundImage={kitchen}>
    <Heading
      tag="h2"
      size="xxl"
      fontFamily="primary"
      marginBottom="s"
      weight="fw800"
      textTransform="capitalize">Ready to Get Things Clean Again?</Heading
    >
    <p>
      If your carpets, floors, or furniture need attention, we're ready when you are. Call us or
      fill out the form below and we'll get back to you quickly.
    </p>
    <Links variant="primary" href="tel:7042543754" ariaLabel="Call All The Rage Carpet Cleaning"
      >(704) 254-3754</Links
    >
  </FullOverlay>

  <SplitOverlay
    title="When Something Happens, You Don't Want to Wait"
    imgSrc={mattress}
    imgAlt="Before and after photo of carpet cleaning in Monroe, NC"
    orientation="left"
  >
    <p>
      Spills, water issues, pet accidents, or last-minute situations don't give you much time to
      think. And the longer they sit, the worse they get.
    </p>
    <p>
      We offer fast-response cleaning to help you take care of the problem before it turns into
      something bigger. Whether it's a soaked carpet, a strong odor, or a stain that needs immediate
      attention, we'll do our best to get there quickly and handle it the right way.
    </p>
    <p><strong>Common emergency calls:</strong></p>
    <ul>
      <li><p>Water spills or minor flooding</p></li>
      <li><p>Pet accidents and odor issues</p></li>
      <li><p>Heavy stains that need immediate attention</p></li>
      <li><p>Move-out or last-minute cleanups</p></li>
    </ul>
    <p><em>If it feels urgent, it probably is.</em></p>
    <p><strong>Need help right now?</strong> Call us directly for the fastest response.</p>
    <Links variant="primary" href="tel:7042543754" ariaLabel="Call us for emergency carpet cleaning"
      >(704) 254-3754</Links
    >
  </SplitOverlay>

  <Process />

  <section>
    <div class="container container-full column-small">
      <div class="content-md">
        <Heading tag="h3" size="xxl" fontFamily="primary" marginBottom="s" weight="fw800">
          What Our Clients Are Saying
        </Heading>
        <p>
          We take pride in our work and it shows in the feedback we get from our clients. Here are
          just a few of the reviews that highlight our commitment to quality, professionalism, and
          customer satisfaction.
        </p>
      </div>

      <div class="content-full">
        <Reviews />
      </div>
    </div>
  </section>
</Layout>

<style lang="scss">
  .service-areas-card {
    background-color: var(--light-100);
    border-radius: var(--border-radius-small);
    padding: 1.25rem;
    display: flex;
    flex-direction: column;
    gap: var(--_spacing---space--4);
    text-align: left;

    &__link {
      margin-top: auto;
      width: fit-content;
      margin-left: 0;
    }
  }
</style>
