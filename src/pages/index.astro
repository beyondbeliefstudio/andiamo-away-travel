---
// COMPONENTS
import Layout from "@/layouts/Layout.astro";
import MainHero from "@/components/MainHero.astro";
import Heading from "@/components/Heading.astro";
import Links from "@/components/Links.astro";
import ScrollingMarquee from "@/components/ScrollingMarquee.astro";
import SplitOverlay from "@/components/SplitOverlay.astro";

import cleaningWorks from "@/assets/cleaningWorks.jpg";

// ICONS
import local from "@/assets/local.svg";
import fast from "@/assets/fast.svg";
import vacuum from "@/assets/vacuum.svg";
import pets from "@/assets/pets.svg";
import price from "@/assets/price.svg";
import available from "@/assets/available.svg";

import CardGrid from "@/components/CardGrid.astro";
import ReviewsCard from "@/components/ReviewsCard.astro";

// REVIEWS DATA
import { getCollection } from "astro:content";

const reviews = await getCollection("reviews", ({ data }) => data.isFeatured);

// Data for "values" section
const values = [
  {
    title: "Fast response times and flexible scheduling",
    description:
      "We make it easy to get service when it works for you, with quick call-backs, prompt arrivals, and appointment windows that fit your day.",
    icon: fast.src,
  },
  {
    title: "24/7 emergency service when you need it most",
    description:
      "When spills, flooding, or urgent cleanup issues happen after hours, our team is ready to respond fast and help prevent further damage.",
    icon: available.src,
  },
  {
    title: "Honest pricing with real value",
    description:
      "You get straightforward recommendations and transparent pricing, so you know exactly what to expect without surprise upsells or hidden fees.",
    icon: price.src,
  },
  {
    title: "Professional equipment that gets deeper results",
    description:
      "Our commercial-grade tools lift embedded dirt, grime, and residue that standard consumer machines often leave behind, giving you a deeper clean.",
    icon: vacuum.src,
  },
  {
    title: "Safe cleaning for kids and pets",
    description:
      "We use methods and products designed to be tough on buildup but safe for the people and pets who live, play, and relax in your home.",
    icon: pets.src,
  },
  {
    title: "Local, family-owned business that takes pride in the work",
    description:
      "As a locally owned team, we treat every job like it matters because it does. We focus on quality work, clear communication, and long-term customer trust.",
    icon: local.src,
  },
];

const process = [
  {
    number: 1,
    title: "Call or Text Us for a Quote",
    description:
      "Reach out with a quick call or text and tell us what you need cleaned. We will provide clear pricing and help you choose the right service.",
  },
  {
    number: 2,
    title: "Schedule a Time That Works for You",
    description:
      "Pick a day and time that fits your schedule. We offer flexible appointment windows so service is convenient and stress-free.",
  },
  {
    number: 3,
    title: "We Show Up and Get to Work",
    description:
      "Our team arrives on time with professional equipment and gets started right away, focusing on deep, detailed cleaning from the start.",
  },
  {
    number: 4,
    title: "You Enjoy a Cleaner, Fresher Space",
    description:
      "After service, your home or business looks better, feels fresher, and is ready for everyday life with results you can see and smell.",
  },
];
---

<Layout
  pageTitle="Mercy Carpet Cleaning & Restoration | Professional Cleaning Services in Monroe, NC"
  description="Mercy Carpet Cleaning & Restoration offers expert carpet cleaning, tile and grout cleaning, upholstery cleaning, and water damage restoration services in Monroe, NC. Book your cleaning today!"
>
  <MainHero />

  <section>
    <div class="container container-lg">
      <div class="content-full">
        <Heading tag="h2" size="xl" fontFamily="secondary" marginBottom="m" weight="fw800">
          Complete Cleaning & Restoration Services
        </Heading>
        <p>
          From everyday cleaning to emergency restoration, we offer a full range of services
          designed to keep your home or business looking its best.
        </p>
        <div class="btn-wrapper btn-wrapper--left">
          <Links
            variant="primary"
            href="/services"
            ariaLabel="View our carpet cleaning services in Monroe, NC">Explore Our Services</Links
          >
        </div>
      </div>
    </div>
  </section>
  <ScrollingMarquee />

  <SplitOverlay
    title="Our Results Speak for Themselves"
    imgSrc={cleaningWorks}
    imgAlt="Before and after photo of carpet cleaning in Monroe, NC"
  >
    <p>
      There’s a big difference between a surface clean and a deep clean. We focus on pulling out
      dirt, buildup, and stains from deep within your floors and furniture so your space looks and
      feels truly clean again.
    </p>
    <p>
      If your carpets look worn, your tile is dull, or your home just doesn’t feel as fresh as it
      should, we can fix that.
    </p>
  </SplitOverlay>

  <section id="values" class="bg-dark">
    <div class="container container-lg column-main">
      <div class="content-full">
        <Heading
          tag="h2"
          size="xs"
          fontFamily="secondary"
          marginBottom="m"
          weight="fw800"
          class="eyebrow">Our Values</Heading
        >
        <Heading tag="h3" size="xxl" fontFamily="primary" marginBottom="m" weight="fw800"
          >Why People in Monroe Call Mercy</Heading
        >
        <p>
          Our values guide everything we do, from the way we treat our clients to the quality of our
          work. Here's how our commitment to these principles benefits you.
        </p>
        <Links variant="primary" href="/contact">Book Your Cleaning Today</Links>
      </div>
      <div class="content-full">
        <div class="card-grid grid-auto-3">
          {
            values.map(item => (
              <div class="card bg-light">
                <span class="icon">
                  <img src={item.icon} alt="" />
                </span>
                <div class="card__content">
                  <Heading
                    tag="h3"
                    size="m"
                    fontFamily="primary"
                    marginBottom="s"
                    weight="fw800"
                    textTransform="capitalize"
                  >
                    {item.title}
                  </Heading>
                  <p>{item.description}</p>
                </div>
              </div>
            ))
          }
        </div>
      </div>
    </div>
  </section>

  <SplitOverlay
    title="24/7 Emergency Water Damage Cleanup"
    imgSrc={cleaningWorks}
    imgAlt="Before and after photo of carpet cleaning in Monroe, NC"
    orientation="left"
  >
    <p>
      When water hits your home, waiting is not an option. The longer it sits, the worse the damage
      gets.
    </p>

    <p>
      We offer after-hours and emergency service so you can get help right away. From burst pipes to
      flooding, we respond quickly and start the cleanup process immediately.
    </p>
  </SplitOverlay>

  <section class="bg-light">
    <div class="container container-lg column-main">
      <div class="content-full">
        <Heading tag="h2" size="xxl" fontFamily="primary" marginBottom="l" weight="fw800">
          Simple, Fast, and Done Right
        </Heading>
        <p class="margin-bottom-xl">
          We make it easy to get the cleaning and restoration you need with a simple process that
          focuses on clear communication, fast response times, and quality results.
        </p>
      </div>
      <div class="content-full">
        <CardGrid cardData={process} />
      </div>
    </div>
  </section>

  <section>
    <div class="container container-lg column-main">
      <div class="content-full">
        <Heading
          tag="h2"
          size="xs"
          fontFamily="secondary"
          marginBottom="s"
          weight="fw500"
          class="eyebrow"
        >
          Testimonials
        </Heading>
        <Heading tag="h3" size="xxl" fontFamily="primary" marginBottom="m" weight="fw800">
          What Our Clients Are Saying
        </Heading>
      </div>
      <div class="content-full">
        <div class="grid-auto-3">
          {reviews.map(review => <ReviewsCard reviews={review} />)}
        </div>
      </div>
    </div>
  </section>
</Layout>

<style lang="scss">
  .service-areas-card {
    background-color: var(--light-100);
    border-radius: var(--border-radius-small);
    padding: 1.25rem;
    display: flex;
    flex-direction: column;
    gap: var(--_spacing---space--4);
    text-align: left;

    &__link {
      margin-top: auto;
      width: fit-content;
      margin-left: 0;
    }
  }
</style>
