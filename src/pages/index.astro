---
// COMPONENTS
import Layout from "@/layouts/Layout.astro";
import MainHero from "@/components/MainHero.astro";
import Heading from "@/components/Heading.astro";
import Links from "@/components/Links.astro";
import ScrollingMarquee from "@/components/ScrollingMarquee.astro";
import SplitOverlay from "@/components/SplitOverlay.astro";
import Process from "@/components/Process.astro";

import cleaningWorks from "@/assets/cleaningWorks.jpg";
import carpet from "@/assets/carpet.jpg";
import flooring from "@/assets/flooring.jpg";
import mattress from "@/assets/mattress.jpg";
import kitchen from "@/assets/kitchen.jpg";

// ICONS
import local from "@/assets/local.svg";
import fast from "@/assets/fast.svg";
import vacuum from "@/assets/vacuum.svg";
import pets from "@/assets/pets.svg";
import price from "@/assets/price.svg";
import available from "@/assets/available.svg";

// REVIEWS DATA
import { getCollection } from "astro:content";
import FullOverlay from "@/components/FullOverlay.astro";
import Reviews from "@/components/Reviews.astro";

// Data for "values" section
const values = [
  {
    title: "Fast response times and flexible scheduling",
    description:
      "We make it easy to get service when it works for you, with quick call-backs, prompt arrivals, and appointment windows that fit your day.",
    icon: fast.src,
  },
  {
    title: "24/7 emergency service when you need it most",
    description:
      "When spills, flooding, or urgent cleanup issues happen after hours, our team is ready to respond fast and help prevent further damage.",
    icon: available.src,
  },
  {
    title: "Honest pricing with real value",
    description:
      "You get straightforward recommendations and transparent pricing, so you know exactly what to expect without surprise upsells or hidden fees.",
    icon: price.src,
  },
  {
    title: "Professional equipment that gets deeper results",
    description:
      "Our commercial-grade tools lift embedded dirt, grime, and residue that standard consumer machines often leave behind, giving you a deeper clean.",
    icon: vacuum.src,
  },
  {
    title: "Safe cleaning for kids and pets",
    description:
      "We use methods and products designed to be tough on buildup but safe for the people and pets who live, play, and relax in your home.",
    icon: pets.src,
  },
  {
    title: "Local, family-owned business that takes pride in the work",
    description:
      "As a locally owned team, we treat every job like it matters because it does. We focus on quality work, clear communication, and long-term customer trust.",
    icon: local.src,
  },
];
---

<Layout
  pageTitle="All The Rage Carpet Cleaning | Professional Cleaning Services in Monroe, NC"
  description="All The Rage Carpet Cleaning offers expert carpet cleaning, tile and grout cleaning, upholstery cleaning, and water damage restoration services in Monroe, NC. Book your cleaning today!"
>
  <MainHero />

  <section>
    <div class="container container-md">
      <div class="content-md">
        <Heading tag="h2" size="xxl" fontFamily="primary" marginBottom="m" weight="fw800">
          Complete Cleaning & Restoration Services
        </Heading>
        <p>
          From everyday cleaning to emergency restoration, we offer a full range of services
          designed to keep your home or business looking its best.
        </p>
        <div class="btn-wrapper">
          <Links
            variant="primary"
            href="/services"
            ariaLabel="View our carpet cleaning services in Monroe, NC">Explore Our Services</Links
          >
        </div>
      </div>
    </div>
  </section>
  <ScrollingMarquee />

  <section id="values" class="bg-primary">
    <div class="container container-md column-main">
      <div class="content-md">
        <Heading tag="h3" size="xxl" fontFamily="primary" marginBottom="m" weight="fw800"
          >Why People in Marshville Call All The Rage</Heading
        >
        <p>
          Our values guide everything we do, from the way we treat our clients to the quality of our
          work. Here's how our commitment to these principles benefits you.
        </p>
      </div>
      <div class="content-full">
        <div class="card-grid grid-auto-3">
          {
            values.map(item => (
              <div class="card bg-white">
                <span class="icon">
                  <img src={item.icon} alt="" />
                </span>
                <div class="card__content">
                  <Heading
                    tag="h3"
                    size="m"
                    fontFamily="primary"
                    marginBottom="s"
                    weight="fw800"
                    textTransform="capitalize"
                  >
                    {item.title}
                  </Heading>
                  <p>{item.description}</p>
                </div>
              </div>
            ))
          }
        </div>
      </div>
    </div>
  </section>

  <SplitOverlay
    title="Our Results Speak for Themselves"
    imgSrc={carpet}
    imgAlt="Before and after photo of carpet cleaning in Monroe, NC"
  >
    <p>
      There’s a big difference between a surface clean and a deep clean. We focus on pulling out
      dirt, buildup, and stains from deep within your floors and furniture so your space looks and
      feels truly clean again.
    </p>
    <p>
      If your carpets look worn, your tile is dull, or your home just doesn’t feel as fresh as it
      should, we can fix that.
    </p>
  </SplitOverlay>

  <FullOverlay backgroundImage={kitchen}>
    <Heading
      tag="h2"
      size="xxl"
      fontFamily="primary"
      marginBottom="m"
      weight="fw800"
      textTransform="capitalize">Proudly Serving North & South Carolina</Heading
    >
    <p>
      We serve homeowners and businesses throughout Monroe, Indian Trail, Waxhaw, Matthews, and
      surrounding areas. If you’re nearby and need cleaning or restoration, we’re just a call or
      text away.
    </p>
  </FullOverlay>

  <SplitOverlay
    title="24/7 Emergency Water Damage Cleanup"
    imgSrc={mattress}
    imgAlt="Before and after photo of carpet cleaning in Monroe, NC"
    orientation="left"
  >
    <p>
      When water hits your home, waiting is not an option. The longer it sits, the worse the damage
      gets.
    </p>

    <p>
      We offer after-hours and emergency service so you can get help right away. From burst pipes to
      flooding, we respond quickly and start the cleanup process immediately.
    </p>
  </SplitOverlay>

  <Process />

  <section>
    <div class="container container-full column-small">
      <div class="content-md">
        <Heading tag="h3" size="xxl" fontFamily="primary" marginBottom="m" weight="fw800">
          What Our Clients Are Saying
        </Heading>
        <p>
          We take pride in our work and it shows in the feedback we get from our clients. Here are
          just a few of the reviews that highlight our commitment to quality, professionalism, and
          customer satisfaction.
        </p>
      </div>

      <div class="content-full">
        <Reviews />
      </div>
    </div>
  </section>
</Layout>

<style lang="scss">
  .service-areas-card {
    background-color: var(--light-100);
    border-radius: var(--border-radius-small);
    padding: 1.25rem;
    display: flex;
    flex-direction: column;
    gap: var(--_spacing---space--4);
    text-align: left;

    &__link {
      margin-top: auto;
      width: fit-content;
      margin-left: 0;
    }
  }
</style>
