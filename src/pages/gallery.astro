---
// COMPONENTS
import CTA from "@/components/CTA.astro";
import GalleryComponent from "@/components/Gallery.astro";
import Layout from "@/layouts/Layout.astro";
import InternalHero from "@/components/InternalHero.astro";

// IMAGES
import garageHome from "@/assets/garageHome.jpg";
import garageHome4 from "@/assets/garageHome4.jpg";

// Data for Image Slider
const projects = [
  { src: garageHome, alt: "Garage Home", id: "slide-1" },
  { src: garageHome, alt: "Garage Home", id: "slide-2" },
  { src: garageHome, alt: "Garage Home", id: "slide-3" },
  { src: garageHome, alt: "Garage Home", id: "slide-4" },
  { src: garageHome, alt: "Garage Home", id: "slide-5" },
  { src: garageHome, alt: "Garage Home", id: "slide-6" },
  { src: garageHome, alt: "Garage Home", id: "slide-7" },
  { src: garageHome, alt: "Garage Home", id: "slide-8" },
  { src: garageHome, alt: "Garage Home", id: "slide-9" },
  { src: garageHome, alt: "Garage Home", id: "slide-10" },
  { src: garageHome, alt: "Garage Home", id: "slide-11" },
  { src: garageHome, alt: "Garage Home", id: "slide-12" },
];
---

<Layout
  title="Projects"
  description="Discover the quality and craftsmanship of Lambo's Garage Door Service through our recent projects. From installations to repairs, see how we bring garage door solutions to life."
>
  <InternalHero
    pageTitle="Projects"
    title="Our Recent Work"
    subtitle="Explore our latest projects and see how we can help you achieve your goals."
    ariaLabel="Projects Hero Section"
    imageSrc={garageHome4}
    imageAlt="Lambo's Garage Door Service Projects"
  />
  <section class="projects bg-light" aria-label="Projects Gallery">
    <div class="container container-md projects__container">
      <GalleryComponent items={projects} />
    </div>
  </section>

  <CTA />
</Layout>
