---
// COMPONENTS
import InternalHero from "@/components/InternalHero.astro";
import Layout from "@/layouts/Layout.astro";
import Heading from "@/components/Heading.astro";
import SplitOverlay from "@/components/SplitOverlay.astro";
import Links from "@/components/Links.astro";
import CardGrid from "@/components/CardGrid.astro";
import ServicesCard from "@/components/ServicesCard.astro";
import FAQ from "@/components/FAQ.astro";

// IMAGES
import closingDoor from "@/assets/closingDoor.png";
import garageFrontHouse from "@/assets/garageFrontHouse.jpg";
import brokenDoor from "@/assets/brokenDoor.png";
import doorInsulation from "@/assets/doorInsulation.jpeg";
import repairingDoor from "@/assets/repairingDoor.png";

// ICONS
import quality from "@/assets/quality.svg";
import pricing from "@/assets/pricing.svg";
import available from "@/assets/available.svg";

// DATA
import { getCollection } from "astro:content";
const faq = await getCollection("garageInstallationFAQ");

const faqData = faq.map(item => ({
  tag: item.data.tag,
  question: item.data.question,
  answer: item.data.answer,
}));

const installationProcess = [
  {
    title: "Door Selection & Planning",
    description:
      "We help determine the best door style, material, and insulation level based on your home and usage needs.",
    icon: quality,
    iconAlt: "Door selection and planning icon",
  },
  {
    title: "Professional Installation",
    description:
      "Our team installs the door system, tracks, springs, and hardware while ensuring precise alignment and safe tensioning.",
    icon: pricing,
    iconAlt: "Professional installation icon",
  },
  {
    title: "Final Testing & Calibration",
    description:
      "We test door balance, smooth movement, and opener compatibility to confirm the system operates correctly before completion.",
    icon: available,
    iconAlt: "Final testing and calibration icon",
  },
];

const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  serviceType: "Garage Door Installation",
  provider: {
    "@type": "LocalBusiness",
    name: "Lambo's Garage Door Service",
  },
  areaServed: ["Franklin County TN", "Coffee County TN"],
};
---

<Layout
  pageTitle="Garage Door Installation in Franklin & Coffee County, TN"
  description="Looking to upgrade your garage door? We provide professional garage door installation in Franklin & Coffee County. Call today."
>
  <script type="application/ld+json" set:html={JSON.stringify(serviceSchema)} />

  <InternalHero
    pageTitle="Garage Door Installation in Central Tennessee"
    title="Upgrade Your Home With a Garage Door Built to Last"
    ariaLabel="Garage Door Installation Hero Section"
    imageSrc={garageFrontHouse}
    imageAlt="A home with a newly installed garage door"
    primaryCtaText="Schedule Garage Door Installation"
    primaryCtaHref="/contact"
    secondaryCtaText="Call Now for Service"
    secondaryCtaHref="tel:+19312229963"
  >
    <p>
      Whether you're replacing an outdated door or installing a new one for a remodel or build,
      Lambo’s Garage Door Service provides professional garage door installation throughout Franklin
      County and Coffee County, Tennessee. We install durable, high-quality garage doors designed to
      improve curb appeal, security, and long-term performance.
    </p>
    <p>
      We proudly serve homeowners in Winchester, Tullahoma, Lynchburg, Estill Springs, Decherd, and
      surrounding communities across the area.
    </p>
    <div class="btn-wrapper btn-wrapper--left">
      <Links variant="primary" href="/contact">Schedule Garage Door Installation</Links>
      <Links variant="outline" href="tel:+19312229963">Call Now for Service</Links>
    </div>
  </InternalHero>

  <!-- Content for the About Us page goes here -->
  <section class="bg-primary">
    <div class="container container-md">
      <div class="content-md">
        <Heading tag="h2" size="xl" fontFamily="primary" marginBottom="l" weight="fw500"
          >Professional Garage Door Installation You Can Trust</Heading
        >
        <p>
          A garage door is one of the largest moving systems in your home and one of the most
          visible parts of your property’s exterior. Proper installation ensures the door operates
          safely, looks great, and performs reliably for years to come.
        </p>

        <p>
          Homeowners across Franklin and Coffee County often choose to replace their garage doors
          for several reasons. Older doors may struggle with frequent repairs, noisy operation, or
          outdated appearance. In other cases, homeowners simply want to improve their home’s curb
          appeal with a modern door design.
        </p>

        <p>
          Professional installation ensures the door is properly balanced, the tracks are aligned
          correctly, and the opener system works smoothly with the new door.
        </p>
      </div>
    </div>
  </section>

  <SplitOverlay
    title="When It’s Time to Replace Your Garage Door"
    imgSrc={brokenDoor}
    imgAlt="A broken garage door that needs replacement"
    background="bg-light"
    orientation="left"
  >
    <p>
      Garage doors can last many years, but eventually replacement becomes the smarter long-term
      investment.
    </p>

    <p><strong>Common reasons homeowners choose new garage door installation include:</strong></p>

    <ul>
      <li><p>Repeated repairs on an aging door</p></li>
      <li><p>Severe panel damage from impact or weather</p></li>
      <li><p>Outdated design affecting curb appeal</p></li>
      <li><p>Noisy or unreliable door operation</p></li>
      <li><p>Safety concerns with older hardware systems</p></li>
      <li><p>Home renovations or exterior upgrades</p></li>
    </ul>

    <p>
      A new garage door can significantly improve both the appearance and functionality of your
      home.
    </p>

    <p>
      If your existing system still has life left but needs mechanical repairs, our <strong
        ><a href="/garage-door-repair">Garage Door Repair</a></strong
      > service may be a better option.
    </p>
  </SplitOverlay>

  <SplitOverlay
    title="Choosing the Right Garage Door for Your Home"
    imgSrc={doorInsulation}
    imgAlt="Garage door with insulation"
    background="bg-white"
    orientation="right"
  >
    <p>
      Garage doors are available in a wide range of materials, styles, and insulation levels.
      Selecting the right option depends on both aesthetic preferences and practical considerations.
    </p>

    <Heading tag="h3" size="m" fontFamily="primary" marginBottom="s" weight="fw500"
      >Door Materials</Heading
    >

    <p>Homeowners in Winchester, Tullahoma, and surrounding areas commonly choose:</p>

    <ul>
      <li><p>Steel garage doors for durability and affordability</p></li>
      <li><p>Insulated doors for improved energy efficiency</p></li>
      <li><p>Modern panel designs for updated curb appeal</p></li>
    </ul>

    <Heading tag="h3" size="m" fontFamily="primary" marginBottom="s" weight="fw500"
      >Style Options</Heading
    >

    <p>Garage doors can complement almost any home style, including:</p>

    <ul>
      <li><p>Traditional raised-panel designs</p></li>
      <li><p>Modern minimalist styles</p></li>
      <li><p>Carriage house garage doors</p></li>
    </ul>

    <p>
      The right door should enhance the overall look of your home while providing dependable daily
      operation.
    </p>
  </SplitOverlay>

  <section class="bg-light">
    <div class="container container-md column-small">
      <div class="content-md">
        <Heading tag="h2" size="xl" fontFamily="primary" marginBottom="l" weight="fw500">
          Our Garage Door Installation Process
        </Heading>
        <p class="margin-bottom-xl">
          We follow a straightforward installation process to ensure every new door operates safely
          and smoothly.
        </p>
      </div>
      <div class="content-full">
        <CardGrid cardData={installationProcess} />
      </div>
    </div>
  </section>

  <SplitOverlay
    title="Why Professional Installation Matters"
    imgSrc={repairingDoor}
    imgAlt="Garage door being professionally installed"
    background="bg-primary"
    orientation="left"
  >
    <p>
      Garage door systems operate under significant tension and must be installed with precision.
      Improper installation can lead to poor door balance, premature hardware wear, and potential
      safety hazards.
    </p>

    <Heading tag="h3" size="m" fontFamily="primary" marginBottom="s" weight="fw500"
      >Proper Door Balance</Heading
    >

    <p>
      Correctly installed springs ensure the door opens and closes smoothly without placing strain
      on the opener motor.
    </p>

    <Heading tag="h3" size="m" fontFamily="primary" marginBottom="s" weight="fw500"
      >Accurate Track Alignment</Heading
    >

    <p>Misaligned tracks can cause vibration, noise, and uneven door movement.</p>

    <Heading tag="h3" size="m" fontFamily="primary" marginBottom="s" weight="fw500"
      >Long-Term Reliability</Heading
    >

    <p>
      Professional installation ensures all components work together properly, reducing the
      likelihood of future mechanical problems.
    </p>

    <p>Our goal is to install a door that performs reliably from day one.</p>
  </SplitOverlay>

  <FAQ faq={faqData} />

  <SplitOverlay
    title="Garage Door Service Across Franklin & Coffee County"
    imgSrc={closingDoor}
    imgAlt="Closing a garage door"
    background="bg-light"
    orientation="right"
  >
    <p>
      Lambo’s Garage Door Service proudly provides professional garage door repair, installation,
      and maintenance throughout Franklin County, Coffee County, and surrounding Central Tennessee
      communities.
    </p>

    <p>Because we are based nearby in Estill Springs, we regularly serve homeowners in:</p>

    <ul>
      <li>
        <p><a href="/garage-door-repair-tullahoma-tn">Tullahoma</a></p>
      </li>
      <li>
        <p><a href="/garage-door-repair-winchester-tn">Winchester</a></p>
      </li>
      <li>
        <p><a href="/garage-door-repair-decherd-tn">Decherd</a></p>
      </li>
      <li>
        <p><a href="/garage-door-repair-estill-springs-tn">Estill Springs</a></p>
      </li>
      <li>
        <p><a href="/garage-door-repair-lynchburg-tn">Lynchburg</a></p>
      </li>
    </ul>
  </SplitOverlay>

  <section>
    <div class="container container-md column-main">
      <div class="content-md">
        <Heading tag="h2" size="xl" fontFamily="primary" marginBottom="l" weight="fw500">
          Explore Our Other Garage Door Services
        </Heading>
        <p class="margin-bottom-xl">
          To keep your entire system operating safely and efficiently, we also provide the following
          services.
        </p>
      </div>
      <div class="content-full">
        <div class="services-grid flex">
          <ServicesCard descriptionType="short" excludeIds={[3]} />
        </div>
      </div>
    </div>
  </section>
</Layout>
