<script>
  // Native date inputs show "mm/dd/yyyy" in the regular text color; dim them
  // to match placeholder styling until a value is entered.
  document.querySelectorAll<HTMLInputElement>('input[type="date"]').forEach((input) => {
    const update = () => input.classList.toggle("date-empty", !input.value);
    input.addEventListener("input", update);
    update();
  });
</script>

