---
// COMPONENTS
import Buttons from "@/components/Buttons.astro";
import Heading from "@/components/Heading.astro";
import InternalHeroAlt from "@/components/InternalHeroAlt.astro";
import Layout from "@/layouts/Layout.astro";

// DATA
import { baseData } from "@/data/siteData";

const cabinCategories = [
  "Interior (No window)",
  "Oceanview (Window)",
  "Balcony (Clear view)",
  "Balcony (Obstructed view)",
  "Suite",
];
---

<Layout
  pageTitle="Trip Inquiry | Andiamo Away"
  description="Group cruise registration form for your upcoming trip with Andiamo Away."
  noindex={true}
  hideCTA={true}
>
  <InternalHeroAlt
    pageTitle="Trip Inquiry"
    title="Trip Inquiry"
    ariaLabel="Trip Inquiry Hero Section"
    classes="trip-inquiry-hero"
    titleWeight="fw500"
  >
    <p>
      Please fill out the form below for your cruise. If you have any questions while filling it
      out, reach out to me directly at any time — call or text <a
        href={`tel:${baseData.phone.replace(/\D/g, "")}`}>{baseData.phone}</a
      > or email <a href={`mailto:${baseData.email}`}>{baseData.email}</a>.
    </p>
  </InternalHeroAlt>

  <section class="bg-light trip-inquiry">
    <div class="container container-md">
      <div class="content-md">
        <form
          data-netlify="true"
          data-netlify-recaptcha="true"
          netlify-honeypot="bot-field"
          name="trip-inquiry"
          class="trip-inquiry__form"
          method="POST"
          action="/thank-you"
        >
          <input type="hidden" name="form-name" value="trip-inquiry" />

          <!-- Honeypot field - hidden from users but visible to bots -->
          <p class="hidden">
            <label
              >Don't fill this out if you're human: <input
                name="bot-field"
                type="text"
                tabindex="-1"
                autocomplete="off"
              /></label
            >
          </p>

          <!-- EVENT DETAILS -->
          <div class="trip-inquiry__section">
            <Heading tag="h2" size="m" fontFamily="primary" marginBottom="s" weight="fw600"
              >Event Details</Heading
            >

            <div class="form-group">
              <label for="group-name">Group Name <span class="required">*</span></label>
              <input
                type="text"
                id="group-name"
                name="group-name"
                placeholder="e.g. Smith Family Reunion"
                required
              />
            </div>

            <div class="form-row">
              <div class="form-group">
                <label for="cruise-line-ship"
                  >Cruise Line / Ship <span class="required">*</span></label
                >
                <input
                  type="text"
                  id="cruise-line-ship"
                  name="cruise-line-ship"
                  placeholder="e.g. Royal Caribbean — Wonder of the Seas"
                  required
                />
              </div>
              <div class="form-group">
                <label for="sail-date">Sail Date <span class="required">*</span></label>
                <input type="date" id="sail-date" name="sail-date" required />
              </div>
            </div>
          </div>

          <!-- CABIN 1 -->
          <div class="trip-inquiry__section">
            <Heading tag="h2" size="m" fontFamily="primary" marginBottom="s" weight="fw600"
              >Cabin 1</Heading
            >

            <div class="trip-inquiry__traveler">
              <h3 class="trip-inquiry__traveler-title">Traveler 1 (Lead Passenger)</h3>

              <div class="form-row">
                <div class="form-group">
                  <label for="c1-t1-name"
                    >Full Name (as on passport) <span class="required">*</span></label
                  >
                  <input
                    type="text"
                    id="c1-t1-name"
                    name="cabin1-traveler1-full-name"
                    placeholder="Jane Marie Smith"
                    required
                  />
                </div>
                <div class="form-group">
                  <label for="c1-t1-dob">Date of Birth <span class="required">*</span></label>
                  <input type="date" id="c1-t1-dob" name="cabin1-traveler1-dob" required />
                </div>
              </div>

              <div class="form-row">
                <div class="form-group">
                  <label for="c1-t1-email">Email Address <span class="required">*</span></label>
                  <input
                    type="email"
                    id="c1-t1-email"
                    name="cabin1-traveler1-email"
                    placeholder="Enter your email"
                    required
                  />
                </div>
                <div class="form-group">
                  <label for="c1-t1-phone">Phone Number <span class="required">*</span></label>
                  <input
                    type="tel"
                    id="c1-t1-phone"
                    name="cabin1-traveler1-phone"
                    placeholder="+1 234 5678"
                    required
                  />
                </div>
              </div>

              <div class="form-row">
                <div class="form-group">
                  <label for="c1-t1-citizenship">Citizenship <span class="required">*</span></label>
                  <input
                    type="text"
                    id="c1-t1-citizenship"
                    name="cabin1-traveler1-citizenship"
                    placeholder="e.g. United States"
                    required
                  />
                </div>
                <div class="form-group">
                  <label for="c1-t1-passport">Passport Number</label>
                  <input
                    type="text"
                    id="c1-t1-passport"
                    name="cabin1-traveler1-passport-number"
                    placeholder="e.g. 123456789"
                  />
                </div>
              </div>

              <div class="form-row">
                <div class="form-group">
                  <label for="c1-t1-passport-exp">Passport Expiration Date</label>
                  <input
                    type="date"
                    id="c1-t1-passport-exp"
                    name="cabin1-traveler1-passport-expiration"
                  />
                </div>
                <div class="form-group">
                  <label for="c1-t1-loyalty">Loyalty Number (if applicable)</label>
                  <input
                    type="text"
                    id="c1-t1-loyalty"
                    name="cabin1-traveler1-loyalty-number"
                    placeholder="e.g. 123456789"
                  />
                </div>
              </div>

              <div class="form-group">
                <label for="c1-t1-street">Street Address <span class="required">*</span></label>
                <input
                  type="text"
                  id="c1-t1-street"
                  name="cabin1-traveler1-street-address"
                  placeholder="123 Main St"
                  required
                />
              </div>

              <div class="form-row form-row--thirds">
                <div class="form-group">
                  <label for="c1-t1-city">City <span class="required">*</span></label>
                  <input
                    type="text"
                    id="c1-t1-city"
                    name="cabin1-traveler1-city"
                    placeholder="Springfield"
                    required
                  />
                </div>
                <div class="form-group">
                  <label for="c1-t1-state">State <span class="required">*</span></label>
                  <input
                    type="text"
                    id="c1-t1-state"
                    name="cabin1-traveler1-state"
                    placeholder="NJ"
                    required
                  />
                </div>
                <div class="form-group">
                  <label for="c1-t1-zip">ZIP Code <span class="required">*</span></label>
                  <input
                    type="text"
                    id="c1-t1-zip"
                    name="cabin1-traveler1-zip"
                    placeholder="07901"
                    required
                  />
                </div>
              </div>
            </div>

            {
              [2, 3].map((t) => (
                <details class="trip-inquiry__toggle">
                  <summary>+ Add Traveler {t}</summary>
                  <div class="trip-inquiry__traveler">
                    <div class="form-row">
                      <div class="form-group">
                        <label for={`c1-t${t}-name`}>Full Name (as on passport)</label>
                        <input
                          type="text"
                          id={`c1-t${t}-name`}
                          name={`cabin1-traveler${t}-full-name`}
                          placeholder="Jane Marie Smith"
                        />
                      </div>
                      <div class="form-group">
                        <label for={`c1-t${t}-dob`}>Date of Birth</label>
                        <input
                          type="date"
                          id={`c1-t${t}-dob`}
                          name={`cabin1-traveler${t}-dob`}
                        />
                      </div>
                    </div>
                    <div class="form-row">
                      <div class="form-group">
                        <label for={`c1-t${t}-email`}>Email Address</label>
                        <input
                          type="email"
                          id={`c1-t${t}-email`}
                          name={`cabin1-traveler${t}-email`}
                          placeholder="Enter your email"
                        />
                      </div>
                      <div class="form-group">
                        <label for={`c1-t${t}-phone`}>Phone Number</label>
                        <input
                          type="tel"
                          id={`c1-t${t}-phone`}
                          name={`cabin1-traveler${t}-phone`}
                          placeholder="+1 234 5678"
                        />
                      </div>
                    </div>
                    <div class="form-row">
                      <div class="form-group">
                        <label for={`c1-t${t}-citizenship`}>Citizenship</label>
                        <input
                          type="text"
                          id={`c1-t${t}-citizenship`}
                          name={`cabin1-traveler${t}-citizenship`}
                          placeholder="e.g. United States"
                        />
                      </div>
                      <div class="form-group">
                        <label for={`c1-t${t}-passport`}>Passport Number</label>
                        <input
                          type="text"
                          id={`c1-t${t}-passport`}
                          name={`cabin1-traveler${t}-passport-number`}
                          placeholder="e.g. 123456789"
                        />
                      </div>
                    </div>
                    <div class="form-row">
                      <div class="form-group">
                        <label for={`c1-t${t}-passport-exp`}>Passport Expiration Date</label>
                        <input
                          type="date"
                          id={`c1-t${t}-passport-exp`}
                          name={`cabin1-traveler${t}-passport-expiration`}
                        />
                      </div>
                      <div class="form-group">
                        <label for={`c1-t${t}-loyalty`}>Loyalty Number (if applicable)</label>
                        <input
                          type="text"
                          id={`c1-t${t}-loyalty`}
                          name={`cabin1-traveler${t}-loyalty-number`}
                          placeholder="e.g. 123456789"
                        />
                      </div>
                    </div>
                    <div class="form-group">
                      <label for={`c1-t${t}-street`}>Street Address</label>
                      <input
                        type="text"
                        id={`c1-t${t}-street`}
                        name={`cabin1-traveler${t}-street-address`}
                        placeholder="123 Main St"
                      />
                    </div>
                    <div class="form-row form-row--thirds">
                      <div class="form-group">
                        <label for={`c1-t${t}-city`}>City</label>
                        <input
                          type="text"
                          id={`c1-t${t}-city`}
                          name={`cabin1-traveler${t}-city`}
                          placeholder="Springfield"
                        />
                      </div>
                      <div class="form-group">
                        <label for={`c1-t${t}-state`}>State</label>
                        <input
                          type="text"
                          id={`c1-t${t}-state`}
                          name={`cabin1-traveler${t}-state`}
                          placeholder="NJ"
                        />
                      </div>
                      <div class="form-group">
                        <label for={`c1-t${t}-zip`}>ZIP Code</label>
                        <input
                          type="text"
                          id={`c1-t${t}-zip`}
                          name={`cabin1-traveler${t}-zip`}
                          placeholder="07901"
                        />
                      </div>
                    </div>
                  </div>
                </details>
              ))
            }

            <fieldset class="trip-inquiry__fieldset">
              <legend>Cabin Category <span class="required">*</span></legend>
              <div class="trip-inquiry__choices">
                {
                  cabinCategories.map((category, i) => (
                    <label class="trip-inquiry__choice">
                      <input
                        type="radio"
                        name="cabin1-category"
                        value={category}
                        required={i === 0}
                      />
                      {category}
                    </label>
                  ))
                }
              </div>
            </fieldset>

            <fieldset class="trip-inquiry__fieldset">
              <legend>Cabin Assignment <span class="required">*</span></legend>
              <div class="trip-inquiry__choices">
                <label class="trip-inquiry__choice">
                  <input type="radio" name="cabin1-assignment" value="I pick my cabin" required />
                  I pick my cabin
                </label>
                <label class="trip-inquiry__choice">
                  <input
                    type="radio"
                    name="cabin1-assignment"
                    value="Cruise picks cabin (Guaranteed rate)"
                  />
                  Cruise picks cabin (Guaranteed rate)
                </label>
              </div>
              <div class="form-group trip-inquiry__room-number">
                <label for="c1-room">Desired Room # (if you pick your cabin)</label>
                <input
                  type="text"
                  id="c1-room"
                  name="cabin1-desired-room-number"
                  placeholder="e.g. 9204"
                />
              </div>
            </fieldset>
          </div>

          <!-- CABIN 2 -->
          <details class="trip-inquiry__toggle trip-inquiry__toggle--cabin">
            <summary>+ Add a Second Cabin</summary>
            <div class="trip-inquiry__section">
              <Heading tag="h2" size="m" fontFamily="primary" marginBottom="s" weight="fw600"
                >Cabin 2</Heading
              >

              <div class="trip-inquiry__traveler">
                <h3 class="trip-inquiry__traveler-title">Traveler 1 (Lead Passenger)</h3>

                <div class="form-row">
                  <div class="form-group">
                    <label for="c2-t1-name">Full Name (as on passport)</label>
                    <input
                      type="text"
                      id="c2-t1-name"
                      name="cabin2-traveler1-full-name"
                      placeholder="Jane Marie Smith"
                    />
                  </div>
                  <div class="form-group">
                    <label for="c2-t1-dob">Date of Birth</label>
                    <input type="date" id="c2-t1-dob" name="cabin2-traveler1-dob" />
                  </div>
                </div>

                <div class="form-row">
                  <div class="form-group">
                    <label for="c2-t1-email">Email Address</label>
                    <input
                      type="email"
                      id="c2-t1-email"
                      name="cabin2-traveler1-email"
                      placeholder="Enter your email"
                    />
                  </div>
                  <div class="form-group">
                    <label for="c2-t1-phone">Phone Number</label>
                    <input
                      type="tel"
                      id="c2-t1-phone"
                      name="cabin2-traveler1-phone"
                      placeholder="+1 234 5678"
                    />
                  </div>
                </div>

                <div class="form-row">
                  <div class="form-group">
                    <label for="c2-t1-citizenship">Citizenship</label>
                    <input
                      type="text"
                      id="c2-t1-citizenship"
                      name="cabin2-traveler1-citizenship"
                      placeholder="e.g. United States"
                    />
                  </div>
                  <div class="form-group">
                    <label for="c2-t1-passport">Passport Number</label>
                    <input
                      type="text"
                      id="c2-t1-passport"
                      name="cabin2-traveler1-passport-number"
                      placeholder="e.g. 123456789"
                    />
                  </div>
                </div>

                <div class="form-row">
                  <div class="form-group">
                    <label for="c2-t1-passport-exp">Passport Expiration Date</label>
                    <input
                      type="date"
                      id="c2-t1-passport-exp"
                      name="cabin2-traveler1-passport-expiration"
                    />
                  </div>
                  <div class="form-group">
                    <label for="c2-t1-loyalty">Loyalty Number (if applicable)</label>
                    <input
                      type="text"
                      id="c2-t1-loyalty"
                      name="cabin2-traveler1-loyalty-number"
                      placeholder="e.g. 123456789"
                    />
                  </div>
                </div>

                <div class="form-group">
                  <label for="c2-t1-street">Street Address</label>
                  <input
                    type="text"
                    id="c2-t1-street"
                    name="cabin2-traveler1-street-address"
                    placeholder="123 Main St"
                  />
                </div>

                <div class="form-row form-row--thirds">
                  <div class="form-group">
                    <label for="c2-t1-city">City</label>
                    <input
                      type="text"
                      id="c2-t1-city"
                      name="cabin2-traveler1-city"
                      placeholder="Springfield"
                    />
                  </div>
                  <div class="form-group">
                    <label for="c2-t1-state">State</label>
                    <input
                      type="text"
                      id="c2-t1-state"
                      name="cabin2-traveler1-state"
                      placeholder="NJ"
                    />
                  </div>
                  <div class="form-group">
                    <label for="c2-t1-zip">ZIP Code</label>
                    <input
                      type="text"
                      id="c2-t1-zip"
                      name="cabin2-traveler1-zip"
                      placeholder="07901"
                    />
                  </div>
                </div>
              </div>

              {
                [2, 3].map((t) => (
                  <details class="trip-inquiry__toggle">
                    <summary>+ Add Traveler {t}</summary>
                    <div class="trip-inquiry__traveler">
                      <div class="form-row">
                        <div class="form-group">
                          <label for={`c2-t${t}-name`}>Full Name (as on passport)</label>
                          <input
                            type="text"
                            id={`c2-t${t}-name`}
                            name={`cabin2-traveler${t}-full-name`}
                            placeholder="Jane Marie Smith"
                          />
                        </div>
                        <div class="form-group">
                          <label for={`c2-t${t}-dob`}>Date of Birth</label>
                          <input
                            type="date"
                            id={`c2-t${t}-dob`}
                            name={`cabin2-traveler${t}-dob`}
                          />
                        </div>
                      </div>
                      <div class="form-row">
                        <div class="form-group">
                          <label for={`c2-t${t}-email`}>Email Address</label>
                          <input
                            type="email"
                            id={`c2-t${t}-email`}
                            name={`cabin2-traveler${t}-email`}
                            placeholder="Enter your email"
                          />
                        </div>
                        <div class="form-group">
                          <label for={`c2-t${t}-phone`}>Phone Number</label>
                          <input
                            type="tel"
                            id={`c2-t${t}-phone`}
                            name={`cabin2-traveler${t}-phone`}
                            placeholder="+1 234 5678"
                          />
                        </div>
                      </div>
                      <div class="form-row">
                        <div class="form-group">
                          <label for={`c2-t${t}-citizenship`}>Citizenship</label>
                          <input
                            type="text"
                            id={`c2-t${t}-citizenship`}
                            name={`cabin2-traveler${t}-citizenship`}
                            placeholder="e.g. United States"
                          />
                        </div>
                        <div class="form-group">
                          <label for={`c2-t${t}-passport`}>Passport Number</label>
                          <input
                            type="text"
                            id={`c2-t${t}-passport`}
                            name={`cabin2-traveler${t}-passport-number`}
                            placeholder="e.g. 123456789"
                          />
                        </div>
                      </div>
                      <div class="form-row">
                        <div class="form-group">
                          <label for={`c2-t${t}-passport-exp`}>Passport Expiration Date</label>
                          <input
                            type="date"
                            id={`c2-t${t}-passport-exp`}
                            name={`cabin2-traveler${t}-passport-expiration`}
                          />
                        </div>
                        <div class="form-group">
                          <label for={`c2-t${t}-loyalty`}>Loyalty Number (if applicable)</label>
                          <input
                            type="text"
                            id={`c2-t${t}-loyalty`}
                            name={`cabin2-traveler${t}-loyalty-number`}
                            placeholder="e.g. 123456789"
                          />
                        </div>
                      </div>
                      <div class="form-group">
                        <label for={`c2-t${t}-street`}>Street Address</label>
                        <input
                          type="text"
                          id={`c2-t${t}-street`}
                          name={`cabin2-traveler${t}-street-address`}
                          placeholder="123 Main St"
                        />
                      </div>
                      <div class="form-row form-row--thirds">
                        <div class="form-group">
                          <label for={`c2-t${t}-city`}>City</label>
                          <input
                            type="text"
                            id={`c2-t${t}-city`}
                            name={`cabin2-traveler${t}-city`}
                            placeholder="Springfield"
                          />
                        </div>
                        <div class="form-group">
                          <label for={`c2-t${t}-state`}>State</label>
                          <input
                            type="text"
                            id={`c2-t${t}-state`}
                            name={`cabin2-traveler${t}-state`}
                            placeholder="NJ"
                          />
                        </div>
                        <div class="form-group">
                          <label for={`c2-t${t}-zip`}>ZIP Code</label>
                          <input
                            type="text"
                            id={`c2-t${t}-zip`}
                            name={`cabin2-traveler${t}-zip`}
                            placeholder="07901"
                          />
                        </div>
                      </div>
                    </div>
                  </details>
                ))
              }

              <fieldset class="trip-inquiry__fieldset">
                <legend>Cabin Category</legend>
                <div class="trip-inquiry__choices">
                  {
                    cabinCategories.map((category) => (
                      <label class="trip-inquiry__choice">
                        <input type="radio" name="cabin2-category" value={category} />
                        {category}
                      </label>
                    ))
                  }
                </div>
              </fieldset>

              <fieldset class="trip-inquiry__fieldset">
                <legend>Cabin Assignment</legend>
                <div class="trip-inquiry__choices">
                  <label class="trip-inquiry__choice">
                    <input type="radio" name="cabin2-assignment" value="I pick my cabin" />
                    I pick my cabin
                  </label>
                  <label class="trip-inquiry__choice">
                    <input
                      type="radio"
                      name="cabin2-assignment"
                      value="Cruise picks cabin (Guaranteed rate)"
                    />
                    Cruise picks cabin (Guaranteed rate)
                  </label>
                </div>
                <div class="form-group trip-inquiry__room-number">
                  <label for="c2-room">Desired Room # (if you pick your cabin)</label>
                  <input
                    type="text"
                    id="c2-room"
                    name="cabin2-desired-room-number"
                    placeholder="e.g. 9204"
                  />
                </div>
              </fieldset>
            </div>
          </details>

          <!-- OPTIONS & ADD-ONS -->
          <div class="trip-inquiry__section">
            <Heading tag="h2" size="m" fontFamily="primary" marginBottom="s" weight="fw600"
              >Cruise Options &amp; Add-Ons</Heading
            >

            <fieldset class="trip-inquiry__fieldset">
              <legend>Travel Insurance <span class="required">*</span></legend>
              <div class="trip-inquiry__choices">
                <label class="trip-inquiry__choice">
                  <input
                    type="radio"
                    name="travel-insurance"
                    value="Yes, add travel insurance"
                    required
                  />
                  Yes, add travel insurance to protect my trip.
                </label>
                <label class="trip-inquiry__choice">
                  <input type="radio" name="travel-insurance" value="No, decline insurance" />
                  No, I decline travel insurance.
                </label>
              </div>
            </fieldset>

            <fieldset class="trip-inquiry__fieldset">
              <legend>Pre-Paid Gratuities <span class="required">*</span></legend>
              <div class="trip-inquiry__choices">
                <label class="trip-inquiry__choice">
                  <input
                    type="radio"
                    name="prepaid-gratuities"
                    value="Yes, pre-pay gratuities"
                    required
                  />
                  Yes, pre-pay gratuities now (added to booking total).
                </label>
                <label class="trip-inquiry__choice">
                  <input type="radio" name="prepaid-gratuities" value="No, pay onboard" />
                  No, I will pay gratuities onboard the ship.
                </label>
              </div>
            </fieldset>

            <p class="trip-inquiry__note">
              <strong>Note:</strong> Optional drink packages are not included in this initial
              registration. You can easily add them to your booking later through the mobile app
              once your cruise is officially confirmed.
            </p>
          </div>

