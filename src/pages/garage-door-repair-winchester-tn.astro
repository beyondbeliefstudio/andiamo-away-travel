---
// COMPONENTS
import InternalHero from "@/components/InternalHero.astro";
import Layout from "@/layouts/Layout.astro";
import Heading from "@/components/Heading.astro";
import ServicesCard from "@/components/ServicesCard.astro";
import FAQ from "@/components/FAQ.astro";
import SplitOverlay from "@/components/SplitOverlay.astro";
import Links from "@/components/Links.astro";
import CardGrid from "@/components/CardGrid.astro";

// IMAGES
import homeGarage from "@/assets/homeGarage10.jpeg";
import seanGarage from "@/assets/seanGarage.png";
import closingDoor from "@/assets/closingDoor.png";
import repairingDoor from "@/assets/repairingDoor.png";
import tuneUp from "@/assets/tuneUp.png";

// ICONS
import quality from "@/assets/quality.svg";
import pricing from "@/assets/pricing.svg";
import available from "@/assets/available.svg";

// DATA
import { getCollection } from "astro:content";
const faq = await getCollection("garageDoorRepairWinchesterFAQ");

const faqData = faq.map(item => ({
  tag: item.data.tag,
  question: item.data.question,
  answer: item.data.answer,
}));

const repairCardData = [
  {
    title: "Complete System Inspection",
    description:
      "We evaluate springs, cables, rollers, tracks, hinges, opener components, and safety sensors to determine the root cause of the issue.",
    icon: quality,
    iconAlt: "Inspection checklist icon",
  },
  {
    title: "Clear Diagnosis & Transparent Estimate",
    description:
      "After identifying the problem, we explain the repair in simple terms and provide a clear estimate before beginning any work.",
    icon: pricing,
    iconAlt: "Transparent pricing icon",
  },
  {
    title: "Professional Repair & Testing",
    description:
      "Once the repair is complete, we test the door for balance, smooth operation, and proper safety function.",
    icon: available,
    iconAlt: "Quality assurance icon",
  },
];

const locationServiceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  serviceType: "Garage Door Repair",
  areaServed: {
    "@type": "City",
    name: "Winchester",
    addressRegion: "TN",
  },
  provider: {
    "@type": "LocalBusiness",
    name: "Lambo's Garage Door Service",
  },
};
---

<Layout
  pageTitle="Garage Door Repair in Winchester, TN | Lambo's Garage Door Service"
  description="Fast, reliable garage door repair in Winchester, TN. Broken springs, opener repair, and emergency service across Franklin County. Call today for service."
>
  <script type="application/ld+json" set:html={JSON.stringify(locationServiceSchema)} />

  <InternalHero
    pageTitle="Garage Door Repair in Winchester, TN"
    title="Fast, Reliable Garage Door Service Just Minutes Away"
    ariaLabel="Garage Door Repair Hero Section"
    imageSrc={homeGarage}
    imageAlt="Home garage with a well-maintained garage door"
    primaryCtaText="Schedule Garage Door Repair"
    primaryCtaHref="/contact"
    secondaryCtaText="Call Now for Service"
    secondaryCtaHref="tel:+19312229963"
  >
    <p>
      If your garage door suddenly stops working, refuses to open or close, or starts making loud
      grinding noises, you need dependable repair service you can trust. Lambo’s Garage Door Service
      provides professional garage door repair in Winchester, Tennessee, helping homeowners restore
      safe and reliable operation quickly.
    </p>
    <p>
      Based just a few minutes away in Estill Springs, we regularly serve homeowners throughout
      Winchester and surrounding Franklin County communities. Whether you're dealing with a broken
      spring, off-track door, damaged cable, or opener malfunction, we diagnose the problem
      accurately and repair it the right way.
    </p>
    <div class="btn-wrapper btn-wrapper--left">
      <Links variant="primary" href="/contact">Schedule Garage Door Repair</Links>
      <Links variant="outline" href="tel:+19312229963">Call Now for Service</Links>
    </div>
  </InternalHero>

  <SplitOverlay
    title="Local Garage Door Repair Near Winchester"
    imgSrc={tuneUp}
    imgAlt="Garage door tune-up service"
    background="bg-primary"
    orientation="right"
  >
    <p>
      Garage doors are one of the most frequently used systems in your home. Many homeowners in
      Winchester rely on their garage doors multiple times every day, especially in neighborhoods
      where the garage serves as the main entry point to the house.
    </p>

    <p>
      Over time, the constant movement of springs, rollers, hinges, and cables naturally causes wear
      on the system. Weather patterns across Franklin County, including seasonal temperature swings
      and humidity, can also contribute to metal fatigue and mechanical stress.
    </p>

    <p>
      Because we are located nearby in Estill Springs, we are able to respond quickly to service
      calls throughout Winchester and surrounding areas.
    </p>

    <p>
      Our goal is simple: identify the root cause of the problem and restore smooth, reliable garage
      door operation.
    </p>
  </SplitOverlay>

  <SplitOverlay
    title="Common Garage Door Problems We Repair in Winchester"
    imgSrc={seanGarage}
    imgAlt="Sean performing garage door maintenance service"
    background="bg-light"
    orientation="left"
  >
    <p>
      Most garage door repairs start with small mechanical issues that eventually lead to system
      failure if left untreated.
    </p>

    <p>Homeowners in Winchester frequently call us for repairs involving:</p>

    <ul>
      <li><p>Broken torsion or extension springs</p></li>
      <li><p>Snapped or frayed lift cables</p></li>
      <li><p>Garage doors that have come off track</p></li>
      <li><p>Worn rollers causing loud grinding or vibration</p></li>
      <li><p>Bent or misaligned tracks</p></li>
      <li><p>Garage door opener motor problems</p></li>
      <li><p>Remote or keypad connection issues</p></li>
      <li><p>Safety sensor alignment problems</p></li>
    </ul>

    <p>
      If your garage door suddenly becomes extremely heavy or refuses to lift, a broken spring is
      often the cause. In this case, our <strong
        ><a href="/garage-door-spring-replacement">Garage Door Spring Replacement</a></strong
      > service can safely restore proper balance.
    </p>

    <p>
      If the opener motor runs but the door does not move properly, our <strong
        ><a href="/garage-door-opener-repair">Garage Door Opener Repair</a></strong
      > and <strong><a href="/garage-door-installation">Garage Door Installation</a></strong> service
      may be needed to restore reliable operation.
    </p>
  </SplitOverlay>

  <SplitOverlay
    title="Why Prompt Garage Door Repair Matters"
    imgSrc={repairingDoor}
    imgAlt="Repairing a garage door"
    background="bg-dark"
    orientation="right"
  >
    <p>
      Many homeowners continue using their garage door even after noticing unusual noises or
      inconsistent operation. Unfortunately, small issues can quickly lead to larger mechanical
      failures.
    </p>

    <Heading tag="h3" size="m" fontFamily="primary" marginBottom="s" weight="fw500"
      >Prevent Additional Damage</Heading
    >

    <p>
      When springs or cables wear down, the opener motor must work harder to lift the door. This
      additional strain can eventually damage the opener or cause other components to fail.
    </p>

    <Heading tag="h3" size="m" fontFamily="primary" marginBottom="s" weight="fw500"
      >Maintain Home Safety</Heading
    >

    <p>
      Garage doors operate under significant tension and can weigh hundreds of pounds. Damaged
      springs or cables can fail unexpectedly and create safety risks for your household.
    </p>

    <p>
      Addressing problems early helps keep your garage door system operating safely and reliably.
    </p>
  </SplitOverlay>

  <section class="bg-light">
    <div class="container container-md column-small">
      <div class="content-md">
        <Heading tag="h2" size="xl" fontFamily="primary" marginBottom="l" weight="fw500">
          Our Garage Door Repair Process
        </Heading>
        <p class="margin-bottom-xl">
          When you schedule service in Winchester, we follow a straightforward process designed to
          provide dependable results. Most garage door repairs can be completed during a single
          service visit.
        </p>
      </div>
      <div class="content-full">
        <CardGrid cardData={repairCardData} />
      </div>
    </div>
  </section>

  <FAQ faq={faqData} />

  <SplitOverlay
    title="Most garage door repairs can be completed during a single service visit."
    imgSrc={closingDoor}
    imgAlt="Closing a garage door"
    background="bg-primary"
    orientation="left"
  >
    <p>
      Our garage door repair services extend throughout Winchester and nearby communities across
      Franklin County and neighboring areas of Coffee County.
    </p>

    <p>
      Because we are located nearby in Estill Springs, we frequently provide service to homeowners
      in:
    </p>

    <ul>
      <li>
        <p><a href="/garage-door-repair-decherd-tn">Decherd</a></p>
      </li>
      <li>
        <p><a href="/garage-door-repair-winchester-tn">Winchester</a></p>
      </li>
      <li>
        <p><a href="/garage-door-repair-estill-springs-tn">Estill Springs</a></p>
      </li>
      <li>
        <p><a href="/garage-door-repair-lynchburg-tn">Lynchburg</a></p>
      </li>
      <li>
        <p><a href="/garage-door-repair-tullahoma-tn">Tullahoma</a></p>
      </li>
    </ul>

    <p>If you're searching for garage door repair in Winchester, TN, our team is ready to help.</p>
  </SplitOverlay>

  <section>
    <div class="container container-md column-main">
      <div class="content-md">
        <Heading tag="h2" size="xl" fontFamily="primary" marginBottom="l" weight="fw500">
          Garage Door Services Available in Winchester
        </Heading>
        <p class="margin-bottom-xl">
          In addition to garage door repair, we offer a full range of garage door services for
          homeowners throughout Winchester and the surrounding area.
        </p>
      </div>
      <div class="content-full">
        <div class="services-grid flex">
          <ServicesCard descriptionType="short" excludeIds={[1]} />
        </div>
      </div>
    </div>
  </section>
</Layout>
