---
// COMPONENTS
import Heading from "@/components/Heading.astro";
import InternalHeroAlt from "@/components/InternalHeroAlt.astro";
import Layout from "@/layouts/Layout.astro";
import { baseData } from "@/data/siteData";
---

<Layout
  pageTitle="Privacy Policy | Andiamo Away"
  description="Learn how Andiamo Away collects, uses, and protects your information when you visit our website or request travel planning services."
>
  <InternalHeroAlt
    pageTitle="Privacy Policy"
    title="Privacy Policy"
    subtitle="Andiamo Away respects your privacy and is committed to protecting your personal information. This Privacy Policy explains how information is collected, used, and protected when you visit our website or request travel planning support."
    ariaLabel="Privacy Policy Hero Section"
  />

  <section class="bg-light terms">
    <div class="container container-md">
      <div class="content-md terms__content-wrapper">
        <div class="terms__content">
          <Heading tag="h2" size="l" fontFamily="primary" marginBottom="m" weight="fw500"
            >Information We Collect</Heading
          >
          <p>
            We may collect the information you choose to share when you contact us or request travel
            planning assistance, including:
          </p>
          <ul>
            <li><p>Name</p></li>
            <li><p>Email address</p></li>
            <li><p>Phone number</p></li>
            <li><p>Travel interests, destination details, or trip preferences</p></li>
            <li><p>Message or inquiry details</p></li>
          </ul>
          <p>We do not intentionally collect sensitive personal data through this website.</p>
        </div>

        <div class="terms__content">
          <Heading tag="h2" size="l" fontFamily="primary" marginBottom="m" weight="fw500"
            >How We Use Your Information</Heading
          >
          <p>Information collected through our website is used to:</p>
          <ul>
            <li><p>Respond to inquiries and travel planning requests</p></li>
            <li><p>Communicate about trips, destinations, and related travel services</p></li>
            <li>
              <p>
                Coordinate with travel suppliers or service providers when needed to help arrange
                requested travel
              </p>
            </li>
            <li><p>Improve our website and services</p></li>
          </ul>
          <p>We do not sell, rent, or trade your personal information.</p>
        </div>

        <div class="terms__content">
          <Heading tag="h2" size="l" fontFamily="primary" marginBottom="m" weight="fw500"
            >Analytics and Cookies</Heading
          >
          <p>
            We use analytics tools, including Google Analytics and Ahrefs Analytics when enabled, to
            understand how visitors interact with our website. These services may collect anonymous
            usage data through cookies or similar technologies.
          </p>
          <p>
            At this time, cookies are used for analytics, form handling, and basic website
            functionality.
          </p>
          <p>You can control cookies through your browser settings.</p>
        </div>

        <div class="terms__content">
          <Heading tag="h2" size="l" fontFamily="primary" marginBottom="m" weight="fw500"
            >Data Storage and Security</Heading
          >
          <p>
            We take reasonable steps to protect your personal information. Information submitted
            through our website may be stored by our website, form, hosting, or email providers as
            needed to respond to your inquiry and maintain records.
          </p>
        </div>

        <div class="terms__content">
          <Heading tag="h2" size="l" fontFamily="primary" marginBottom="m" weight="fw500"
            >Third-Party Services</Heading
          >
          <p>
            Our website may use third-party services such as analytics tools, form processors, and
            travel suppliers. These services may collect data in accordance with their own privacy
            policies and terms.
          </p>
        </div>

        <div class="terms__content">
          <Heading tag="h2" size="l" fontFamily="primary" marginBottom="m" weight="fw500"
            >Your Choices</Heading
          >
          <p>
            You can contact us at any time to ask about the information we hold about you, request
            corrections, or ask us to stop using your information for future marketing messages.
          </p>
        </div>

        <div class="terms__content">
          <Heading tag="h2" size="l" fontFamily="primary" marginBottom="m" weight="fw500"
            >Contact Us</Heading
          >
          <p>If you have any questions about this Privacy Policy, please contact:</p>
          <p>
            <strong>{baseData.title}</strong><br />
            <strong>Email:</strong>
            <a href={`mailto:${baseData.email}`}>{baseData.email}</a><br />
            <strong>Phone:</strong>
            <a href={`tel:${baseData.phone.replace(/\D/g, "")}`}>{baseData.phone}</a><br />
            <strong>Location:</strong>
            {baseData.address.full}
          </p>
        </div>
        <p><i>Last Updated: May 20, 2026</i></p>
      </div>
    </div>
  </section>
</Layout>
