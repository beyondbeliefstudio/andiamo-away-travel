---
// COMPONENTS
import Heading from "@/components/Heading.astro";
import InternalHeroAlt from "@/components/InternalHeroAlt.astro";
import Layout from "@/layouts/Layout.astro";
import { baseData } from "@/data/siteData";
---

<Layout
  pageTitle="Privacy Policy"
  description="Learn how Lambo's Garage Door Service collects, uses, and protects your personal information. We respect your privacy and are committed to data security."
>
  <InternalHeroAlt
    pageTitle="Privacy Policy"
    title="Privacy Policy"
    subtitle="Lambo's Garage Door Service LLC respects your privacy and is committed to protecting your personal information. This Privacy Policy explains how information is collected, used, and protected when you visit our website."
    ariaLabel="Privacy Policy Hero Section"
  />

  <section class="bg-light terms">
    <div class="container container-md">
      <div class="content-md terms__content-wrapper">
        <div class="terms__content">
          <Heading tag="h2" size="l" fontFamily="primary" marginBottom="m" weight="fw500"
            >Information We Collect</Heading
          >
          <p>We may collect the following information when you submit a form on our website:</p>
          <ul>
            <li><p>Name</p></li>
            <li><p>Email address</p></li>
            <li><p>Phone number</p></li>
            <li><p>Service requested</p></li>
            <li><p>Message or inquiry details</p></li>
          </ul>
          <p>We do not collect sensitive personal data.</p>
        </div>

        <div class="terms__content">
          <Heading tag="h2" size="l" fontFamily="primary" marginBottom="m" weight="fw500"
            >How We Use Your Information</Heading
          >
          <p>Information collected through our website is used only to:</p>
          <ul>
            <li><p>Respond to service requests and inquiries</p></li>
            <li><p>Communicate about garage door services</p></li>
            <li><p>Improve our website and services</p></li>
          </ul>
          <p>We do not sell, rent, or trade your personal information.</p>
        </div>

        <div class="terms__content">
          <Heading tag="h2" size="l" fontFamily="primary" marginBottom="m" weight="fw500"
            >Analytics and Cookies</Heading
          >
          <p>
            We use Google Analytics to understand how visitors interact with our website. Google
            Analytics may collect anonymous usage data through cookies.
          </p>
          <p>
            At this time, cookies are used only for analytics and basic website functionality.
            Additional tracking tools may be added in the future as advertising services are
            implemented.
          </p>
          <p>You can control cookies through your browser settings.</p>
        </div>

        <div class="terms__content">
          <Heading tag="h2" size="l" fontFamily="primary" marginBottom="m" weight="fw500"
            >Data Storage and Security</Heading
          >
          <p>
            We take reasonable steps to protect your personal information. Information submitted
            through our website is not intentionally stored long term unless required for
            communication or record keeping related to service inquiries.
          </p>
        </div>

        <div class="terms__content">
          <Heading tag="h2" size="l" fontFamily="primary" marginBottom="m" weight="fw500"
            >Third-Party Services</Heading
          >
          <p>
            Our website may use third-party services such as analytics tools. These services may
            collect data in accordance with their own privacy policies.
          </p>
        </div>

        <div class="terms__content">
          <Heading tag="h2" size="l" fontFamily="primary" marginBottom="m" weight="fw500"
            >Tennessee Privacy Rights</Heading
          >
          <p>
            Tennessee residents have the right to request information about how their personal data
            is collected and used. If you have questions or concerns, you may contact us using the
            information below.
          </p>
        </div>

        <div class="terms__content">
          <Heading tag="h2" size="l" fontFamily="primary" marginBottom="m" weight="fw500"
            >Contact Us</Heading
          >
          <p>If you have any questions about this Privacy Policy, please contact:</p>
          <p>
            <strong>{baseData.title}</strong><br />
            <strong>Email:</strong>
            <a href={`mailto:${baseData.email}`}>{baseData.email}</a><br />
            <strong>Phone:</strong>
            <a href={`tel:${baseData.phone.replace(/\D/g, "")}`}>{baseData.phone}</a><br />
            <strong>Location:</strong>
            {baseData.address.full}
          </p>
        </div>
        <p><i>Last Updated: December 22, 2025</i></p>
      </div>
    </div>
  </section>
</Layout>
