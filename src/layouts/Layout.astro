---
// COMPONENTS
import BaseHead from "@/layouts/BaseHead.astro";
import Footer from "@/layouts/Footer.astro";
import Nav from "@/layouts/Nav.astro";
import CTA from "@/components/CTA.astro";
import LighthouseGalleryModal from "@/components/LighthouseGalleryModal.astro";

// STYLES
import "@/styles/global.scss";
import ScrollingMarquee from "@/components/ScrollingMarquee.astro";

// PROPS
const { hideCTA = false } = Astro.props;
---

<!doctype html>
<html lang="en">
  <BaseHead {...Astro.props} />
  <body>
    <Nav />
    <main>
      <slot />
    </main>
    {!hideCTA && <CTA id="contact" />}
    <ScrollingMarquee />
    <Footer />
    <!-- <UserBack /> -->
    <LighthouseGalleryModal />
  </body>
</html>
