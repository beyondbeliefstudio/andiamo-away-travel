---
// HELPERS
import { Image } from "astro:assets";

// COMPONENTS
import Links from "@/components/Links.astro";

// DATA
import { navData } from "@/data/navData";

// IMAGES\
import wordmark from "@/assets/wordmark.svg";
---

<!--=============== HEADER ===============-->
<header class="nav">
  <div class="nav__container container container-lg">
    <div class="nav__logo">
      <a href="/" class="nav__logo-img">
        <Image src={wordmark} alt="Andiamo Away Logo" />
      </a>
      <a href="/" class="nav__logo-img__sticky">
        <Image src={wordmark} alt="Andiamo Away Logo" />
      </a>
    </div>

    <nav class="nav__links">
      {
        navData.map(i => {
          if (i.children?.length) {
            return (
              <div class="nav__item nav__item--has-children">
                <button
                  type="button"
                  class="nav__desktop-toggle btn nav-link"
                  aria-expanded="false"
                  aria-label={`Toggle ${i.title} links`}
                >
                  <span>{i.title}</span>
                  <span class="nav__chevron" aria-hidden="true" />
                </button>
                <div class="nav__sub-links">
                  {i.children.map(child => (
                    <Links variant="nav-link" href={child.href}>
                      {child.title}
                    </Links>
                  ))}
                </div>
              </div>
            );
          }

          return (
            <Links variant="nav-link" href={i.href}>
              {i.title}
            </Links>
          );
        })
      }
      <Links variant="primary" href={"tel:+19084199557"}>Call (908) 419-9557</Links>
    </nav>

    <!-- Hamburger -->
    <button class="hamburger" id="hamburgerBtn" aria-label="Toggle Menu">
      <!-- <div class="circle"></div> -->
      <span class="line top"></span>
      <span class="line middle"></span>
      <span class="line bottom"></span>
    </button>
  </div>

  <!-- Mobile Menu -->
  <div class="nav__mobile" id="mobileNav">
    {
      navData.map(i => {
        if (i.children?.length) {
          return (
            <div class="nav__mobile-item nav__mobile-item--has-children">
              <button
                type="button"
                class="nav__mobile-toggle btn nav-link"
                aria-expanded="false"
                aria-label={`Toggle ${i.title} links`}
              >
                <span>{i.title}</span>
                <span class="nav__mobile-chevron" aria-hidden="true" />
              </button>
              <div class="nav__mobile-sub-links">
                {i.children.map(child => (
                  <Links variant="nav-link" href={child.href}>
                    {child.title}
                  </Links>
                ))}
              </div>
            </div>
          );
        }

        return (
          <Links variant="nav-link" href={i.href}>
            {i.title}
          </Links>
        );
      })
    }
    <Links variant="primary" href={"tel:+19084199557"}>Call (908) 419-9557</Links>
  </div>

  <!-- Mobile Menu Overlay -->
  <div class="nav__overlay" id="navOverlay"></div>
</header>

<style lang="scss">
  .nav {
    width: 100%;
    z-index: 1000;
    position: fixed;
    top: 0;
    left: 0;

    &__container {
      display: flex;
      align-items: center;
      justify-content: space-between;
      background-color: var(--light-100);
      padding: 0.5rem;
      border-radius: var(--border-radius-small);
      margin: 1rem auto;
      width: 100%;
      gap: 3rem;
      position: relative;
      z-index: 10;
      outline: 1px solid var(--brand-primary-light);

      @media (max-width: 1070px) {
        margin: 0.5rem auto;
        max-width: calc(100% - 1rem);
        padding: 0.5rem;
      }
    }

    &__logo-img {
      display: block;
      height: 100%;
      line-height: 0;

      svg,
      img {
        height: 70px !important;
        width: auto !important;

        @media (max-width: 1070px) {
          height: 35px !important;
        }
      }
    }

    &__logo-img__sticky {
      display: none;
      height: 100%;
      line-height: 0;

      svg,
      img {
        height: 50px !important;
        width: auto !important;

        @media (max-width: 1070px) {
          height: 35px !important;
        }
      }
    }

    &__links {
      display: flex;
      align-items: center;
      gap: 1.5rem;

      @media (max-width: 1070px) {
        display: none;
      }

      .btn {
        margin: 0;
      }
    }

    &__item {
      position: relative;

      &--has-children.is-open .nav__sub-links {
        opacity: 1;
        visibility: visible;
        pointer-events: auto;
        transform: translateY(0);
      }

      &--has-children.is-open .nav__chevron {
        transform: rotate(225deg);
      }
    }

    &__desktop-toggle {
      display: inline-flex;
      align-items: center;
      gap: 0.35rem;
      background: transparent;
    }

    &__chevron {
      width: 8px;
      height: 8px;
      border-right: 2px solid var(--content-primary);
      border-bottom: 2px solid var(--content-primary);
      transform: rotate(45deg);
      transition: transform 0.2s ease;
      pointer-events: none;
      margin-top: -2px;
    }

    &__sub-links {
      position: absolute;
      top: 100%;
      left: 0;
      display: flex;
      flex-direction: column;
      gap: 0.75rem;
      width: max-content;
      min-width: 180px;
      background-color: var(--light-100);
      padding: 0.75rem;
      opacity: 0;
      visibility: hidden;
      pointer-events: none;
      transform: translateY(0.25rem);
      transition:
        opacity 0.2s ease,
        transform 0.2s ease;
      z-index: 20;

      .nav-link {
        text-align: left;
      }

      .btn.nav-link {
        font-size: var(--_typography---font-size--text-main);
      }
    }

    &.scrolled {
      position: fixed;
      top: 0;
      z-index: 999;
      width: 100%;

      .nav__logo-img {
        display: none;
      }

      .nav__logo-img__sticky {
        display: block;
      }

      .nav__container {
        background-color: var(--light-100);
        width: fit-content;
        padding: 0.5rem 0.5rem 0.5rem 1rem;
        box-shadow: 0px 0px 13px #00000029;

        @media (max-width: 1070px) {
          width: 100%;
          padding-left: 0.5rem;
        }
      }
    }

    /* Mobile Nav */
    &__mobile {
      display: none;
      position: absolute;
      background-color: var(--light-100);
      border-radius: var(--border-radius-small);
      outline: 1px solid var(--dark-900);
      width: 100%;
      padding: 0.5rem;
      flex-direction: column;
      gap: 1rem;
      justify-content: center;

      z-index: 1;
      transform: translateY(100%);
      height: fit-content;
      top: 100%;
      max-width: calc(100% - 1rem);
      left: 0.5rem;
      right: 0.5rem;
    }

    &__mobile-toggle {
      display: inline-flex;
      align-items: center;
      gap: 0.35rem;
      background: transparent;
    }

    &__mobile-chevron {
      width: 8px;
      height: 8px;
      border-right: 2px solid var(--content-primary);
      border-bottom: 2px solid var(--content-primary);
      transform: rotate(45deg);
      transition: transform 0.2s ease;
      margin-top: -2px;
    }

    &__mobile-sub-links {
      display: grid;
      gap: 0.5rem;
      padding-left: 0.75rem;
      max-height: 0;
      opacity: 0;
      overflow: hidden;
      transition:
        max-height 0.25s ease,
        opacity 0.2s ease;

      .nav-link {
        font-size: var(--_typography---font-size--text-main);
      }
    }

    &__mobile-item--has-children.is-open {
      .nav__mobile-sub-links {
        max-height: 180px;
        opacity: 1;
        margin: 0.5rem auto 0;
      }

      .nav__mobile-chevron {
        transform: rotate(225deg);
      }
    }

    &__mobile a:not(.btn) {
      color: var(--dark-900);
      text-align: left;
      text-decoration: none;
      position: relative;
    }

    &__mobile .btn {
      width: fit-content;
      margin: 0;
    }

    /* Open State */
    &__mobile.open {
      transform: translateY(0);
      display: flex !important;
    }

    /* Mobile Menu Overlay */
    &__overlay {
      position: fixed;
      top: 0;
      left: 0;
      width: 100vw;
      height: 100vh;
      background: rgba(0, 0, 0, 0.5);
      backdrop-filter: blur(2px);
      z-index: 0;
      opacity: 0;
      visibility: hidden;
      transition:
        opacity 0.3s ease,
        visibility 0.3s ease;
      pointer-events: none;
    }

    &__overlay.active {
      opacity: 1;
      visibility: visible;
      pointer-events: auto;
    }
  }

  /* Hamburger Button */
  .hamburger {
    position: relative;
    width: 38px;
    height: 20px;
    border: none;
    background: none;
    cursor: pointer;
    display: none;
    align-items: center;
    justify-content: center;
    z-index: 1000;

    @media (max-width: 1070px) {
      display: flex;
      flex-direction: column;
      gap: 5px;
    }
  }

  .line {
    width: 24px;
    height: 3px;
    background-color: var(--dark-900);
    border-radius: 2px;
    transition: background-color 0.3s ease;
  }

  .line.top {
    top: 14px;
  }

  .line.middle {
    top: 22px;
  }

  .line.bottom {
    top: 30px;
  }

  body.menu-open {
    overflow: hidden;
  }
</style>

<script>
  import gsap from "gsap";

  // NAV
  const hamburgerBtn = document.getElementById("hamburgerBtn") as HTMLElement;
  const mobileNav = document.getElementById("mobileNav") as HTMLElement;
  const navOverlay = document.getElementById("navOverlay") as HTMLElement;
  const topLine = document.querySelector(".line.top");
  const middleLine = document.querySelector(".line.middle");
  const bottomLine = document.querySelector(".line.bottom");
  const circle = document.querySelector(".circle");
  const desktopDropdownToggles = Array.from(document.querySelectorAll(".nav__desktop-toggle"));
  const mobileDropdownToggles = Array.from(document.querySelectorAll(".nav__mobile-toggle"));
  let isOpen = false;

  const tl = gsap.timeline({ paused: true });

  function hideNav(): void {
    gsap.set(mobileNav, { display: "none" });
  }

  // Ensure the mobile nav starts hidden and only opens via the hamburger toggle.
  hideNav();

  function closeMobileDropdowns(): void {
    mobileDropdownToggles.forEach(toggle => {
      const mobileItem = toggle.closest(".nav__mobile-item--has-children") as HTMLElement | null;
      if (!mobileItem) return;

      mobileItem.classList.remove("is-open");
      toggle.setAttribute("aria-expanded", "false");
    });
  }

  function closeDesktopDropdowns(): void {
    desktopDropdownToggles.forEach(toggle => {
      const desktopItem = toggle.closest(".nav__item--has-children") as HTMLElement | null;
      if (!desktopItem) return;

      desktopItem.classList.remove("is-open");
      toggle.setAttribute("aria-expanded", "false");
    });
  }

  tl.to(
    middleLine,
    {
      duration: 0.2,
      opacity: 0,
      ease: "power1.inOut",
    },
    0
  )
    .to(
      topLine,
      {
        duration: 0.3,
        rotate: 45,
        y: 8,
        ease: "power2.inOut",
      },
      0
    )
    .to(
      bottomLine,
      {
        duration: 0.3,
        rotate: -45,
        y: -8,
        ease: "power2.inOut",
      },
      0
    )
    .to(
      circle,
      {
        duration: 0.3,
        scale: 1,
        ease: "power2.inOut",
      },
      0
    );

  hamburgerBtn.classList.remove("open");

  hamburgerBtn.addEventListener("click", () => {
    mobileNav.classList.toggle("open");
    navOverlay.classList.toggle("active");
    document.body.classList.toggle("menu-open");
    hamburgerBtn.classList.toggle("open");

    if (!isOpen) {
      // Reveal and animate in
      gsap.set(mobileNav, { display: "flex", y: "-100%" });
      gsap.to(mobileNav, { duration: 0.5, y: "0%", ease: "power2.out" });
      isOpen = true;
      tl.play();
    } else {
      // Animate out and hide
      gsap.to(mobileNav, {
        duration: 0.4,
        y: "-100%",
        ease: "power2.in",
        onComplete: hideNav,
      });
      closeMobileDropdowns();
      closeDesktopDropdowns();
      tl.reverse();
      isOpen = false;
    }
  });

  // Close menu when clicking overlay
  navOverlay.addEventListener("click", () => {
    if (isOpen) {
      closeMobileDropdowns();
      closeDesktopDropdowns();
      mobileNav.classList.remove("open");
      navOverlay.classList.remove("active");
      document.body.classList.remove("menu-open");
      hamburgerBtn.classList.remove("open");

      gsap.to(mobileNav, {
        duration: 0.4,
        y: "-100%",
        ease: "power2.in",
        onComplete: hideNav,
      });
      tl.reverse();
      isOpen = false;
    }
  });

  desktopDropdownToggles.forEach(toggle => {
    toggle.addEventListener("click", () => {
      const desktopItem = toggle.closest(".nav__item--has-children") as HTMLElement | null;
      if (!desktopItem) return;

      const willOpen = !desktopItem.classList.contains("is-open");
      closeDesktopDropdowns();
      desktopItem.classList.toggle("is-open", willOpen);
      toggle.setAttribute("aria-expanded", String(willOpen));
    });
  });

  mobileDropdownToggles.forEach(toggle => {
    toggle.addEventListener("click", () => {
      const mobileItem = toggle.closest(".nav__mobile-item--has-children") as HTMLElement | null;
      if (!mobileItem) return;

      const willOpen = !mobileItem.classList.contains("is-open");
      mobileItem.classList.toggle("is-open", willOpen);
      toggle.setAttribute("aria-expanded", String(willOpen));
    });
  });

  document.addEventListener("click", event => {
    const target = event.target as HTMLElement;
    if (!target.closest(".nav__item--has-children")) {
      closeDesktopDropdowns();
    }
  });

  document.addEventListener("keydown", event => {
    if (event.key === "Escape") {
      closeMobileDropdowns();
      closeDesktopDropdowns();
    }
  });

  window.addEventListener("scroll", () => {
    const header = document.querySelector(".nav") as HTMLElement;
    if (window.scrollY > 50) {
      header.classList.add("scrolled");
    } else {
      header.classList.remove("scrolled");
    }
  });

  function updateNavLayout(): void {
    const header = document.querySelector(".nav") as HTMLElement;
    if (!header) return;

    document.documentElement.style.setProperty("--nav-height", `${header.offsetHeight}px`);
  }

  updateNavLayout();
</script>
