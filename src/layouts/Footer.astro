---
// COMPONENTS
import Links from "@/components/Links.astro";

// HELPERS
import { Image } from "astro:assets";

// Content
import { navData } from "@/data/navData";
import { baseData } from "@/data/siteData";

// Images
import instagram from "@/assets/instagram.png";
import Heading from "@/components/Heading.astro";
import wordmark from "@/assets/wordmark.svg";
---

<footer class="footer bg-light" aria-label="footer">
  <div class="container container-md">
    <div class="content-full footer__content">
      <div class="footer__info">
        <a href="/">
          <Image src={wordmark} alt="Andiamo Away Logo" class="footer__wordmark" />
        </a>
        <p>
          {baseData.description}
        </p>
        <div class="social-grid">
          <a
            class="social"
            href={baseData.social.instagram}
            target="_blank"
            rel="noopener noreferrer"
          >
            <Image src={instagram} alt="Instagram Icon" />
          </a>
        </div>
      </div>
      <div class="footer__links">
        <div class="footer__col">
          <Heading
            tag="h3"
            size="m"
            fontFamily="primary"
            marginBottom="m"
            weight="fw600"
            textTransform="capitalize">Quick Links</Heading
          >
          <nav class="footer__nav-links">
            {
              navData
                .filter(i => i.title !== "Garage Services" && i.title !== "Service Areas")
                .map(i => {
                  return (
                    <div class="footer__link-group">
                      {i.href ? (
                        <Links variant="nav-link" href={i.href}>
                          {i.title}
                        </Links>
                      ) : (
                        <p class="footer__group-label">{i.title}</p>
                      )}
                    </div>
                  );
                })
            }
          </nav>
        </div>
        <div class="footer__col">
          <Heading
            tag="h3"
            size="m"
            fontFamily="primary"
            marginBottom="m"
            weight="fw600"
            textTransform="capitalize">Contact Us</Heading
          >
          <nav class="footer__nav-links">
            <Links variant="nav-link" href={`mailto:${baseData.email}`} classes="lowercase"
              >{baseData.email}</Links
            >
            <Links variant="nav-link" href={`tel:${baseData.phone.replace(/\D/g, "")}`}
              >{baseData.phone}</Links
            >
          </nav>
        </div>
      </div>
    </div>
  </div>
  <div class="footer__bottom container container-md">
    <div class="footer__bottom-content">
      <p class="footer__copyright">
        © {new Date().getFullYear()}
        {baseData.title}. | Designed by <a
          href="https://beyondbeliefwebdesign.com/"
          target="_blank"
          rel="noopener noreferrer">Beyond Belief Web Design</a
        >
      </p>
      <nav class="footer__legal">
        <Links variant="nav-link" href="/privacy-policy">Privacy Policy</Links>
        <span class="footer__divider">•</span>
        <Links variant="nav-link" href="/terms-and-conditions">Terms & Conditions</Links>
        <span class="footer__divider">•</span>
        <Links variant="nav-link" href="/accessibility">Accessibility</Links>
      </nav>
    </div>
  </div>
</footer>

<style lang="scss">
  .footer {
    &__content {
      gap: var(--_spacing---space--8);
      justify-content: space-between;
      width: 100%;
      display: flex;
      text-align: left;

      @media (max-width: 768px) {
        flex-direction: column;
        gap: var(--_spacing---section-space--large);
      }
    }

    &__info {
      flex-flow: column;
      width: 44%;
      display: flex;
      max-width: 400px;

      .social-grid {
        margin-top: 0.5rem;
      }

      p,
      a {
        font-size: var(--_typography---font-size--text-main);
        line-height: 1.4;
      }

      p a {
        color: var(--content-primary);
        text-decoration: underline;
        text-underline-offset: 2px;

        &:hover {
          color: var(--brand-primary);
        }
      }

      @media (max-width: 1070px) {
        width: 50%;
      }

      @media (max-width: 768px) {
        width: 100%;
      }
    }

    &__links {
      justify-content: end;
      align-items: flex-start;
      min-width: fit-content;
      display: grid;
      max-width: 850px;
      grid-template-columns: auto auto;
      grid-gap: var(--_spacing---section-space--main);

      @media (max-width: 1070px) {
        grid-template-columns: 1fr;
        width: 50%;
      }
    }

    &__col {
      p {
        font-family: var(--primary-family);
        margin-bottom: 0rem;
      }
    }

    &__nav-links {
      display: flex;
      flex-direction: column;
      gap: 0.5rem;
      font-size: var(--_typography---font-size--h6);

      .lowercase {
        text-transform: lowercase !important;
      }

      .nav-link {
        font-size: var(--_typography---font-size--h6);
      }
    }

    &__link-group {
      display: flex;
      flex-direction: column;
      gap: 0.25rem;
    }

    &__group-label {
      margin: 0;
      font-size: var(--_typography---font-size--h6);
      font-family: var(--primary-family);
    }

    &__sub-links {
      display: flex;
      flex-direction: column;
      gap: 0.35rem;
      padding-left: 0.75rem;
    }

    &__wordmark {
      max-width: 100%;
      background-size: contain;
      height: fit-content;
      max-width: 250px;
      margin-bottom: 1rem;

      @media screen and (max-width: 768px) {
        max-width: 175px;
      }
    }

    &__bottom {
      border-top: 1px solid var(--brand-secondary-dark);
      padding: 1.5rem 0;
    }

    &__bottom-content {
      display: flex;
      justify-content: space-between;
      align-items: center;
      flex-wrap: wrap;
      gap: 1rem;

      @media (max-width: 768px) {
        flex-direction: column-reverse;
        align-items: start;
      }
    }

    &__copyright {
      font-size: var(--_typography---font-size--text-main);
      color: var(--brand-primary);
      margin: 0;
      font-family: var(--primary-family);
      text-wrap: balance;

      a {
        color: var(--brand-primary);
        text-decoration: none;
        transition: color 0.2s ease;
        font-size: var(--_typography---font-size--text-main);
        font-weight: 600;

        &:hover {
          color: var(--brand-primary-dark);
        }
      }
    }

    &__legal {
      display: flex;
      align-items: center;
      gap: 0.75rem;

      @media screen and (max-width: 768px) {
        flex-direction: column;
        gap: 0.5rem;
        align-items: start;

        .footer__divider {
          display: none;
        }
      }

      .nav-link {
        font-size: var(--_typography---font-size--text-main);
        font-weight: 600;
        text-transform: capitalize;
      }
    }
  }
</style>
