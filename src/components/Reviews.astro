---
import Heading from "@/components/Heading.astro";
import { getCollection } from "astro:content";
import ReviewsCard from "./ReviewsCard.astro";

const reviews = await getCollection("reviews", ({ data }) => data.isFeatured);
---

<div class="scroller-image">
  <ul class="scroller-inner-image">
    {reviews.map(review => <ReviewsCard reviews={review} />)}
  </ul>
</div>

<style lang="scss">
  .scroller-image {
    max-width: 100%;
    width: fit-content;
    margin: auto;
    overflow: hidden;
  }

  .scroller-image .scroller-inner-image {
    margin: 0;
    padding: 1rem 0;
    list-style: none;
    display: flex;
    gap: 1rem;
    width: max-content;
    flex-wrap: nowrap;
    animation: scroll 350s forwards linear infinite;

    @media screen and (max-width: 768px) {
      animation: scroll 150s forwards linear infinite;
    }
  }

  @keyframes scroll {
    to {
      transform: translate(calc(-50% - 0.5rem));
    }
  }
</style>
