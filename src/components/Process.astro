---
// COMPONENTS
import Heading from "@/components/Heading.astro";
import Links from "@/components/Links.astro";
import ProcessCard from "@/components/ProcessCard.astro";
---

<section class="services bg-primary">
  <div class="container container-md column-main services__container">
    <div class="services__intro">
      <Heading tag="h2" size="xxl" fontFamily="primary" marginBottom="m" weight="fw800">
        Simple, Fast, and Done Right
      </Heading>
      <p>
        We make it easy to get the cleaning and restoration you need with a simple process that
        focuses on clear communication, fast response times, and quality results.
      </p>
    </div>
    <div class="services__grid">
      <ProcessCard />
    </div>
  </div>
</section>

<style lang="scss">
  .services {
    &__container {
      align-items: flex-start;
      flex-direction: row;

      @media (max-width: 1024px) {
        flex-direction: column;
      }
    }

    &__intro {
      position: sticky !important;
      top: 7rem;
      width: 50%;

      @media (max-width: 1024px) {
        position: static !important;
        width: 100%;
      }
    }

    &__grid {
      display: flex;
      flex-direction: column;
      width: 50%;
      gap: var(--_spacing---space--6);

      @media (max-width: 1024px) {
        width: 100%;
      }
    }
  }
</style>
