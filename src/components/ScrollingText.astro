---
// IMAGES
import gear from "@/assets/gear-icon.svg";

// HELPERS
import { Image } from "astro:assets";

// DATA
const towns = [
  "Estill Springs",
  "Tullahoma",
  "Murfreesboro",
  "Winchester",
  "Decherd",
  "Manchester",
  "Lynchburg",
  "Shelbyville",
  "Fayetteville",
  "Franklin County",
  "Coffee County",
  "Moore County",
];
---

<section class="bg-primary">
  <div class="scrolling-marquee">
    <div class="scrolling-marquee-inner">
      {
        towns.map(town => (
          <>
            <span class="town-item">{town}</span>
            <Image src={gear} alt="" class="gear-icon" aria-hidden="true" />
          </>
        ))
      }
    </div>
  </div>
</section>

<style lang="scss">
  section {
    // transform: rotate(-2deg);
  }

  /* SCROLLING MARQUEE */
  .scrolling-marquee {
    max-width: 100%;
    width: fit-content;
    margin: auto;
    overflow: hidden;

    &-inner {
      margin: 0;
      padding: 2rem 0 1.75rem;
      list-style: none;
      display: flex;
      gap: 2rem;
      width: max-content;
      flex-wrap: nowrap;
      animation: scroll 120s forwards linear infinite;
      align-items: center;
    }
  }

  .town-item {
    font-size: var(--_typography---font-size--h3);
    font-weight: 400;
    color: var(--light-100);
    white-space: nowrap;
    font-family: var(--primary-family);
    text-transform: uppercase;
  }

  .gear-icon {
    width: 2rem;
    height: 2rem;
    filter: invert(1);

    @media (max-width: 768px) {
      width: 1.5rem;
      height: 1.5rem;
    }
  }

  @keyframes scroll {
    to {
      transform: translate(calc(-50% - 2.5rem));
    }
  }
</style>

<script>
  const scrollText: NodeListOf<HTMLElement> =
    document.querySelectorAll<HTMLElement>(".scrolling-marquee");

  if (!window.matchMedia("(prefers-reduced-motion: reduce)").matches) {
    scrollingText();
  }

  function scrollingText(): void {
    scrollText.forEach((scroller: HTMLElement) => {
      scroller.setAttribute("data-animated", "true");

      const scrollTextInner: HTMLElement | null = scroller.querySelector<HTMLElement>(
        ".scrolling-marquee-inner"
      );
      if (scrollTextInner) {
        const scrollContent: HTMLElement[] = Array.from(scrollTextInner.children) as HTMLElement[];

        for (let i = 0; i < 3; i++) {
          scrollContent.forEach((item: HTMLElement) => {
            const duplicatedItem: HTMLElement = item.cloneNode(true) as HTMLElement;
            duplicatedItem.setAttribute("aria-hidden", "true");
            scrollTextInner.appendChild(duplicatedItem);
          });
        }
      }
    });
  }
</script>
