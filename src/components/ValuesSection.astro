---
import Heading from "@/components/Heading.astro";

import local from "@/assets/local.svg";
import fast from "@/assets/fast.svg";
import vacuum from "@/assets/vacuum.svg";
import price from "@/assets/price.svg";
import vet from "@/assets/vet.svg";

type ValueItem = {
  title: string;
  description: string;
  icon: string;
};

const defaultValues: ValueItem[] = [
  {
    title: "Veteran-owned and operated",
    description:
      "We bring a strong work ethic, attention to detail, and pride in every job we take on. It's not just about cleaning, it's about doing the job right.",
    icon: vet.src,
  },
  {
    title: "25+ years of hands-on experience",
    description:
      "We've seen just about every type of stain, surface, and situation. That experience helps us know what works and how to get the best results.",
    icon: vacuum.src,
  },
  {
    title: "No rushed jobs or cutting corners",
    description:
      "We take the time to properly clean each surface instead of rushing through jobs. The goal is results that actually last, not quick turnarounds.",
    icon: fast.src,
  },
  {
    title: "Honest pricing and clear communication",
    description:
      "No surprises, no confusing quotes. We keep things straightforward so you know exactly what to expect from start to finish.",
    icon: price.src,
  },
];

const {
  id = "values",
  sectionClass = "bg-primary",
  containerClass = "container container-md column-medium",
  heading = "We Show Up and Do It Right",
  intro = "There's a difference between a quick cleaning and one that's actually done properly. We've been doing this for over 25 years, and we've built our reputation on being reliable, easy to work with, and consistent.",
  gridClass = "card-grid grid-auto-4",
  values = defaultValues,
} = Astro.props as {
  id?: string;
  sectionClass?: string;
  containerClass?: string;
  heading?: string;
  intro?: string;
  gridClass?: string;
  values?: ValueItem[];
};
---

<section id={id} class={sectionClass}>
  <div class={containerClass}>
    <div class="content-md">
      <Heading tag="h3" size="xxl" fontFamily="primary" marginBottom="s" weight="fw800"
        >{heading}</Heading
      >
      <p>{intro}</p>
    </div>
    <div class="content-full">
      <div class={gridClass}>
        {
          values.map(item => (
            <div class="card bg-white">
              <span class="icon">
                <img src={item.icon} alt="" />
              </span>
              <div class="card__content">
                <Heading
                  tag="h3"
                  size="m"
                  fontFamily="primary"
                  marginBottom="s"
                  weight="fw800"
                  textTransform="capitalize"
                >
                  {item.title}
                </Heading>
                <p>{item.description}</p>
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </div>
</section>
