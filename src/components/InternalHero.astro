---
// COMPONENTS
import Heading from "@/components/Heading.astro";
import Links from "@/components/Links.astro";

// HELPERS
import type { HTMLAttributes } from "astro/types";
import { Picture } from "astro:assets";

export interface HeroProps extends HTMLAttributes<"section"> {
  pageTitle?: string;
  title: string;
  subtitle?: string;
  ariaLabel?: string;
  classes?: string;
  imageSrc?: string;
  imageAlt?: string;
  primaryCtaText?: string;
  primaryCtaHref?: string;
  secondaryCtaText?: string;
  secondaryCtaHref?: string;
}

const {
  pageTitle,
  title,
  subtitle,
  ariaLabel,
  classes,
  imageSrc,
  imageAlt,
  primaryCtaText,
  primaryCtaHref,
  secondaryCtaText,
  secondaryCtaHref,
  ...rest
} = Astro.props;
---

<section class:list={["internal-hero", classes]} aria-label={ariaLabel} {...rest}>
  <div class="container container-md internal-hero__container column-main">
    <div class="content-full internal-hero__content grid-auto-2">
      <div class="internal-hero__headings">
        <Heading
          tag="h1"
          size="xs"
          fontFamily="primary"
          marginBottom="m"
          weight="fw500"
          class="internal-hero__title eyebrow">{pageTitle}</Heading
        >
        <Heading tag="h2" size="xxl" fontFamily="primary" marginBottom="none" weight="fw500"
          >{title}</Heading
        >
      </div>
      <div class="internal-hero__copy">
        <slot />
      </div>
    </div>
    <div class="content-full internal-hero__img">
      <div class="internal-hero__img-wrapper img-wrapper">
        <Picture
          src={imageSrc}
          formats={["avif", "webp"]}
          alt={imageAlt}
          width={1440}
          height={810}
          widths={[480, 768, 1280, 1440]}
          sizes="100vw"
          quality={65}
          loading="eager"
          fetchpriority="high"
          decoding="async"
        />
      </div>
    </div>
  </div>
</section>

<style lang="scss">
  .internal-hero {
    overflow: hidden;
    position: relative;
    padding-top: 124px;

    &__container {
      padding-top: var(--_spacing---section-space--xl);
      padding-bottom: var(--_spacing---section-space--main);

      @media (max-width: 768px) {
        padding-top: var(--_spacing---section-space--main);
      }
    }

    &__content {
      text-align: left;
      align-items: start;
    }

    .img-wrapper {
      width: 100%;
      border-radius: var(--border-radius-small);
      overflow: hidden;
      height: 100%;
      aspect-ratio: 16 / 9;
    }

    .column {
      position: relative;
      z-index: 999;
    }

    &__title {
      margin-left: 0;
      background: var(--light-200);
    }

    &__copy {
      text-wrap: pretty;

      p {
        margin-bottom: 0;
      }
    }

    &__btn-group {
      margin-top: 1.5rem;
      justify-content: flex-start;

      @media (max-width: 768px) {
        margin-top: 1rem;
      }
    }
  }
</style>
