---
import { Picture } from "astro:assets";
import type { HTMLAttributes } from "astro/types";

export interface ScrollingMarqueeProps extends HTMLAttributes<"section"> {
  classes?: string;
}

const { classes, ...rest } = Astro.props;

import greece from "@/assets/marquee-temp/greece.jpg";
import italy from "@/assets/marquee-temp/italy.jpg";
import paris from "@/assets/marquee-temp/paris.jpg";
import china from "@/assets/marquee-temp/china.jpg";
import mexico from "@/assets/marquee-temp/mexico.jpg";
import japan from "@/assets/marquee-temp/japan.jpg";
import spain from "@/assets/marquee-temp/spain.jpg";
import thailand from "@/assets/marquee-temp/thailand.jpg";
import turkey from "@/assets/marquee-temp/turkey.jpg";
import switzerland from "@/assets/marquee-temp/switzerland.jpg";

const items = [
  {
    src: greece,
    alt: "Traveler by whitewashed hillside buildings in Santorini, Greece",
    imgText: "Santorini, Greece",
  },
  {
    src: italy,
    alt: "Traveler enjoying a scenic Mediterranean view in Positano, Italy",
    imgText: "Positano, Italy",
  },
  {
    src: paris,
    alt: "Traveler in front of the Eiffel Tower in Paris, France",
    imgText: "Paris, France",
  },
  {
    src: china,
    alt: "Traveler with skyline view in Shanghai, China",
    imgText: "Shanghai, China",
  },
  {
    src: mexico,
    alt: "Traveler exploring colorful streets in Mexico City, Mexico",
    imgText: "Mexico City, Mexico",
  },
  {
    src: japan,
    alt: "Traveler crossing a busy district in Tokyo, Japan",
    imgText: "Tokyo, Japan",
  },
  {
    src: spain,
    alt: "Traveler on historic streets in Barcelona, Spain",
    imgText: "Barcelona, Spain",
  },
  {
    src: thailand,
    alt: "Traveler relaxing on a tropical beach in Phuket, Thailand",
    imgText: "Phuket, Thailand",
  },
  {
    src: turkey,
    alt: "Traveler enjoying sunset views over Istanbul, Turkey",
    imgText: "Istanbul, Turkey",
  },
  {
    src: switzerland,
    alt: "Traveler overlooking alpine scenery in Interlaken, Switzerland",
    imgText: "Interlaken, Switzerland",
  },
];
---

<section class:list={classes} {...rest}>
  <div class="scrolling-photos">
    <div class="scrolling-photos-inner">
      {
        items.map(item => (
          <div class="polaroids">
            <div class="polaroids__img-wrapper">
              <Picture
                src={item.src}
                alt={item.alt ?? "Travel destination"}
                class="polaroids__img"
                loading="eager"
                width={2000}
                height={1000}
              />
              <p>{item.imgText}</p>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>

<style lang="scss">
  /* SCROLLING PHOTOS MARQUEE */
  .scrolling-photos {
    max-width: 100%;
    width: fit-content;
    margin: auto;
    overflow: hidden;

    &-inner {
      margin: 0;
      padding: 3rem 0;
      list-style: none;
      display: flex;
      gap: 3rem;
      width: max-content;
      flex-wrap: nowrap;
      animation: scrollPhotos 200s forwards linear infinite;
    }
  }

  .polaroids {
    background: #fff;
    padding: 0.5rem;
    padding-bottom: 5rem;
    border-radius: 0;
    filter: drop-shadow(2px 4px 15px rgba(20, 20, 20, 0.1));
    height: 500px;
    width: 100%;
    transform: rotate(-2deg);
    position: relative;

    &:nth-of-type(3n + 1) {
      transform: rotate(2deg) translateY(10px);
    }

    &:nth-of-type(3n + 2) {
      transform: rotate(1deg) translateY(-5px);
    }

    &__img-wrapper {
      aspect-ratio: 1/1;
      width: 100%;
      height: 100%;
      overflow: hidden;
    }

    p {
      height: 5rem;
      width: 100%;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 1.5rem;
      font-family: var(--secondary-family);
      position: absolute;
      bottom: 0;
      left: 0;
      z-index: 10;
      margin-bottom: 0;
    }
  }

  @keyframes scrollPhotos {
    to {
      transform: translate(calc(-50% - 1.5rem));
    }
  }
</style>

<script>
  const scrollPhotos: NodeListOf<HTMLElement> =
    document.querySelectorAll<HTMLElement>(".scrolling-photos");

  if (!window.matchMedia("(prefers-reduced-motion: reduce)").matches) {
    scrollingPhotos();
  }

  function scrollingPhotos(): void {
    scrollPhotos.forEach((scroller: HTMLElement) => {
      scroller.setAttribute("data-animated", "true");

      const scrollPhotosInner: HTMLElement | null =
        scroller.querySelector<HTMLElement>(".scrolling-photos-inner");
      if (scrollPhotosInner) {
        const scrollContent: HTMLElement[] = Array.from(
          scrollPhotosInner.children
        ) as HTMLElement[];

        for (let i = 0; i < 3; i++) {
          scrollContent.forEach((item: HTMLElement) => {
            const duplicatedItem: HTMLElement = item.cloneNode(true) as HTMLElement;
            duplicatedItem.setAttribute("aria-hidden", "true");
            scrollPhotosInner.appendChild(duplicatedItem);
          });
        }
      }
    });
  }
</script>
