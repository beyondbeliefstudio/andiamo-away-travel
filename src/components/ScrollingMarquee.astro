---
// HELPERS
import { Picture } from "astro:assets";

// COMPONENTS
import Heading from "./Heading.astro";

// IMAGES
import upholstery from "@/assets/upholstery.jpg";
import carpetCleaning from "@/assets/carpetCleaning.jpg";
import groutCleaning from "@/assets/groutCleaning.jpg";
import flooring from "@/assets/flooring.jpg";
import kitchen from "@/assets/kitchen.jpg";

const items = [
  {
    src: carpetCleaning,
    title: "Carpet Cleaning",
    description: "Ideal for high-traffic areas, pet stains, and general wear.",
  },
  {
    src: upholstery,
    title: "Upholstery Cleaning",
    description: "Couches, chairs, and fabric surfaces that need a refresh.",
  },
  {
    src: groutCleaning,
    title: "Tile and Grout Cleaning",
    description: "Cuts through built-up grime and restores the original look.",
  },
  {
    src: flooring,
    title: "Hardwood Floor Cleaning",
    description: "Safe, effective cleaning that enhances the natural finish.",
  },
  {
    src: kitchen,
    title: "Stone Surface Cleaning",
    description: "Quartz, marble, and granite cleaned with care.",
  },
];
---

<section>
  <div class="scrolling-photos">
    <div class="scrolling-photos__inner">
      {
        items.map(item => (
          <div class="scrolling-photos__item">
            <div class="scrolling-photos__img-wrapper">
              <Picture
                src={item.src as any}
                formats={["avif", "webp"]}
                alt={`${item.title} service photo`}
                class="scrolling-photos__img"
                loading="lazy"
                quality={60}
                width={500}
                height={500}
                widths={[300, 500]}
                sizes="(max-width: 768px) 300px, 500px"
              />
            </div>
            <div class="scrolling-photos__content">
              <Heading
                tag="h3"
                size="l"
                fontFamily="primary"
                marginBottom="none"
                weight="fw800"
                class="scrolling-photos__text"
              >
                {item.title}
              </Heading>
              <p class="scrolling-photos__description">{item.description}</p>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>

<style lang="scss">
  /* SCROLLING PHOTOS MARQUEE */
  .scrolling-photos {
    max-width: 100%;
    width: fit-content;
    margin: auto;
    overflow: hidden;
    background-color: var(--light-100);

    &__inner {
      margin: 0;
      padding: 1rem 0;
      list-style: none;
      display: flex;
      gap: 1rem;
      width: max-content;
      flex-wrap: nowrap;
      animation: scrollPhotos 140s linear infinite;

      @media screen and (max-width: 768px) {
        animation: scrollPhotos 150s linear infinite;
      }
    }

    &__item {
      position: relative;
      overflow: hidden;
      border-radius: var(--border-radius-small);
      aspect-ratio: 4 / 5;
      height: 500px;
      display: flex;
      flex-direction: column;
      align-items: start;
      justify-content: end;
    }

    &__content {
      position: relative;
      z-index: 999;
      padding: 1rem;
    }

    &__text {
      color: #fff;
      z-index: 999;
      text-wrap: balance;
      width: calc(100% - 2rem);
      line-height: 1.2;
      font-size: clamp(1.15rem, 1.2vw + 0.75rem, 1.6rem);
    }

    &__description {
      margin: 0;
      color: #fff;
      z-index: 999;
      font-family: var(--secondary-family);
      font-size: var(--_typography---font-size--text-main);
      line-height: 1.3;
      text-wrap: pretty;
    }

    &__img-wrapper {
      position: absolute;
      height: 100%;
      width: 100%;

      &:before {
        content: "";
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: linear-gradient(0deg, rgba(0, 0, 0, 0.7) 0%, rgba(0, 0, 0, 0) 100%);
        opacity: 1;
        pointer-events: none;
        z-index: 1;
      }

      img,
      video {
        height: 100%;
        width: 100%;
        // height: 500px;
        // max-width: 100vw;
        // aspect-ratio: 5/6;
        width: auto !important;
        object-fit: cover;
        vertical-align: middle;
        display: inline-block;

        @media screen and (max-width: 768px) {
          // height: 300px;
        }
      }
    }
  }

  @keyframes scrollPhotos {
    to {
      transform: translate(calc(-50% - 0.5rem));
    }
  }
</style>

<script>
  const scrollPhotos: NodeListOf<HTMLElement> =
    document.querySelectorAll<HTMLElement>(".scrolling-photos");

  if (!window.matchMedia("(prefers-reduced-motion: reduce)").matches) {
    scrollingPhotos();
  }

  function scrollingPhotos(): void {
    scrollPhotos.forEach((scroller: HTMLElement) => {
      scroller.setAttribute("data-animated", "true");

      const scrollPhotosInner: HTMLElement | null = scroller.querySelector<HTMLElement>(
        ".scrolling-photos__inner"
      );
      if (scrollPhotosInner) {
        const scrollContent: HTMLElement[] = Array.from(
          scrollPhotosInner.children
        ) as HTMLElement[];

        for (let i = 0; i < 3; i++) {
          scrollContent.forEach((item: HTMLElement) => {
            const duplicatedItem: HTMLElement = item.cloneNode(true) as HTMLElement;
            duplicatedItem.setAttribute("aria-hidden", "true");
            scrollPhotosInner.appendChild(duplicatedItem);
          });
        }
      }
    });
  }
</script>
