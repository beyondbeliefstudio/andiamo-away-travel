---
// HELPERS
import { Picture } from "astro:assets";

// COMPONENTS
import Heading from "./Heading.astro";

// IMAGES
import stainRemover from "@/assets/stainRemover.jpg";
import upholstery from "@/assets/upholstery.jpg";
import waterDamage from "@/assets/waterDamage.jpg";
import carpetCleaning from "@/assets/carpetCleaning.jpg";
import floodCleanUp from "@/assets/floodCleanUp.jpg";
import groutCleaning from "@/assets/groutCleaning.jpg";

const items = [
  { src: stainRemover, alt: "Stain Remover", type: "photo" },
  { src: upholstery, alt: "Upholstery Cleaning", type: "photo" },
  { src: waterDamage, alt: "Water Damage Cleanup", type: "photo" },
  { src: carpetCleaning, alt: "Carpet Cleaning", type: "photo" },
  { src: floodCleanUp, alt: "Flood Cleanup", type: "photo" },
  { src: groutCleaning, alt: "Grout Cleaning", type: "photo" },
];
---

<section>
  <div class="scrolling-photos">
    <div class="scrolling-photos__inner">
      {
        items.map(item => (
          <div class="scrolling-photos__item">
            <div class="scrolling-photos__img-wrapper">
              <Picture
                src={item.src as any}
                formats={["avif", "webp"]}
                alt={item.alt}
                class="scrolling-photos__img"
                loading="lazy"
                quality={60}
                width={500}
                height={500}
                widths={[300, 500]}
                sizes="(max-width: 768px) 300px, 500px"
              />
            </div>
            <Heading
              tag="h3"
              size="l"
              fontFamily="primary"
              marginBottom="s"
              weight="fw800"
              class="scrolling-photos__text"
            >
              {item.alt}
            </Heading>
          </div>
        ))
      }
    </div>
  </div>
</section>

<style lang="scss">
  /* SCROLLING PHOTOS MARQUEE */
  .scrolling-photos {
    max-width: 100%;
    width: fit-content;
    margin: auto;
    overflow: hidden;
    background-color: var(--light-100);

    &__inner {
      margin: 0;
      padding: 1rem 0;
      list-style: none;
      display: flex;
      gap: 1rem;
      width: max-content;
      flex-wrap: nowrap;
      animation: scrollPhotos 140s linear infinite;

      @media screen and (max-width: 768px) {
        animation: scrollPhotos 150s linear infinite;
      }
    }

    &__item {
      position: relative;
      overflow: hidden;
      border-radius: var(--border-radius-small);
    }

    &__text {
      position: absolute;
      bottom: 1rem;
      left: 1rem;
      color: #fff;
      z-index: 999;
      text-wrap: balance;
      width: 50%;
    }

    &__img-wrapper {
      width: 100%;
      height: 100%;

      &:before {
        content: "";
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: linear-gradient(0deg, rgba(0, 0, 0, 0.7) 0%, rgba(0, 0, 0, 0) 100%);
        opacity: 0.6;
        pointer-events: none;
        z-index: 1;
      }

      img,
      video {
        height: 500px;
        max-width: 100vw;
        aspect-ratio: 5/6;
        width: auto !important;
        object-fit: cover;
        vertical-align: middle;
        display: inline-block;

        @media screen and (max-width: 768px) {
          height: 300px;
        }
      }
    }
  }

  @keyframes scrollPhotos {
    to {
      transform: translate(calc(-50% - 0.5rem));
    }
  }
</style>

<script>
  const scrollPhotos: NodeListOf<HTMLElement> =
    document.querySelectorAll<HTMLElement>(".scrolling-photos");

  if (!window.matchMedia("(prefers-reduced-motion: reduce)").matches) {
    scrollingPhotos();
  }

  function scrollingPhotos(): void {
    scrollPhotos.forEach((scroller: HTMLElement) => {
      scroller.setAttribute("data-animated", "true");

      const scrollPhotosInner: HTMLElement | null = scroller.querySelector<HTMLElement>(
        ".scrolling-photos__inner"
      );
      if (scrollPhotosInner) {
        const scrollContent: HTMLElement[] = Array.from(
          scrollPhotosInner.children
        ) as HTMLElement[];

        for (let i = 0; i < 3; i++) {
          scrollContent.forEach((item: HTMLElement) => {
            const duplicatedItem: HTMLElement = item.cloneNode(true) as HTMLElement;
            duplicatedItem.setAttribute("aria-hidden", "true");
            scrollPhotosInner.appendChild(duplicatedItem);
          });
        }
      }
    });
  }
</script>
