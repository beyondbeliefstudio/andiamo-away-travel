---
import { Picture } from "astro:assets";
import type { HTMLAttributes } from "astro/types";

export interface ScrollingMarqueeProps extends HTMLAttributes<"section"> {
  classes?: string;
}

const { classes, ...rest } = Astro.props;

import amsterdam from "@/assets/scrolling-images/Amsterdam.jpeg";
import croatia from "@/assets/scrolling-images/Croatia.jpeg";
import greece from "@/assets/scrolling-images/Greece.jpeg";
import london from "@/assets/scrolling-images/London.jpeg";
import montreal from "@/assets/scrolling-images/Montreal.jpeg";
import paris from "@/assets/scrolling-images/Paris.jpeg";
import portofino from "@/assets/scrolling-images/Portofino.jpeg";
import portugal from "@/assets/scrolling-images/Portugal.jpeg";
import puntaCana from "@/assets/scrolling-images/Punta Cana.jpeg";
import santorini from "@/assets/scrolling-images/Santorini.jpeg";

const items = [
  {
    src: amsterdam,
    alt: "Scenic canal lined with historic buildings in Amsterdam, Netherlands",
    imgText: "Amsterdam, Netherlands",
  },
  {
    src: croatia,
    alt: "Stunning coastal view of the old town and Adriatic Sea in Dubrovnik, Croatia",
    imgText: "Dubrovnik, Croatia",
  },
  {
    src: greece,
    alt: "Traveler among ancient ruins and olive groves in Athens, Greece",
    imgText: "Athens, Greece",
  },
  {
    src: london,
    alt: "Iconic view of Tower Bridge and the Thames River in London, England",
    imgText: "London, England",
  },
  {
    src: montreal,
    alt: "Vibrant street scene in the historic Old Port district of Montreal, Canada",
    imgText: "Montreal, Canada",
  },
  {
    src: paris,
    alt: "Traveler strolling along the Seine with a view of the Eiffel Tower in Paris, France",
    imgText: "Paris, France",
  },
  {
    src: portofino,
    alt: "Colorful harbor village nestled along the cliffs of Portofino, Italy",
    imgText: "Portofino, Italy",
  },
  {
    src: portugal,
    alt: "Traveler exploring the tiled facades and hillside streets of Lisbon, Portugal",
    imgText: "Lisbon, Portugal",
  },
  {
    src: puntaCana,
    alt: "Pristine white sand beach with turquoise water in Punta Cana, Dominican Republic",
    imgText: "Punta Cana, D.R.",
  },
  {
    src: santorini,
    alt: "Traveler overlooking whitewashed buildings and blue-domed churches in Santorini, Greece",
    imgText: "Santorini, Greece",
  },
];
---

<section class:list={classes} {...rest}>
  <div class="scrolling-photos">
    <div class="scrolling-photos-inner">
      {
        items.map(item => (
          <div class="polaroids">
            <div class="polaroids__img-wrapper">
              <Picture
                src={item.src}
                formats={["avif", "webp"]}
                alt={item.alt ?? "Travel destination"}
                class="polaroids__img"
                loading="eager"
                width={700}
                height={700}
                widths={[300, 500, 700]}
                sizes="(max-width: 768px) 280px, 450px"
                quality={70}
              />
              <p>{item.imgText}</p>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>

<style lang="scss">
  /* SCROLLING PHOTOS MARQUEE */
  .scrolling-photos {
    max-width: 100%;
    width: fit-content;
    margin: auto;
    overflow: hidden;

    &-inner {
      margin: 0;
      padding: 3rem 0;
      list-style: none;
      display: flex;
      gap: 3rem;
      width: max-content;
      flex-wrap: nowrap;
      animation: scrollPhotos 200s forwards linear infinite;
    }
  }

  .polaroids {
    background: #fff;
    padding: 0.5rem;
    padding-bottom: 5rem;
    border-radius: 0;
    filter: drop-shadow(2px 4px 15px rgba(20, 20, 20, 0.1));
    height: 500px;
    width: 100%;
    transform: rotate(-2deg);
    position: relative;

    @media (max-width: 768px) {
      height: 300px;
      padding-bottom: 3rem;
    }

    &:nth-of-type(3n + 1) {
      transform: rotate(2deg) translateY(10px);
    }

    &:nth-of-type(3n + 2) {
      transform: rotate(1deg) translateY(-5px);
    }

    &__img-wrapper {
      aspect-ratio: 1/1;
      width: 100%;
      height: 100%;
      overflow: hidden;
    }

    p {
      height: 5rem;
      width: 100%;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 1.5rem;
      font-family: var(--secondary-family);
      position: absolute;
      bottom: 0;
      left: 0;
      z-index: 10;
      margin-bottom: 0;

      @media (max-width: 768px) {
        height: 3rem;
      }
    }
  }

  @keyframes scrollPhotos {
    to {
      transform: translate(calc(-50% - 1.5rem));
    }
  }
</style>

<script>
  const scrollPhotos: NodeListOf<HTMLElement> =
    document.querySelectorAll<HTMLElement>(".scrolling-photos");

  if (!window.matchMedia("(prefers-reduced-motion: reduce)").matches) {
    scrollingPhotos();
  }

  function scrollingPhotos(): void {
    scrollPhotos.forEach((scroller: HTMLElement) => {
      scroller.setAttribute("data-animated", "true");

      const scrollPhotosInner: HTMLElement | null =
        scroller.querySelector<HTMLElement>(".scrolling-photos-inner");
      if (scrollPhotosInner) {
        const scrollContent: HTMLElement[] = Array.from(
          scrollPhotosInner.children
        ) as HTMLElement[];

        for (let i = 0; i < 3; i++) {
          scrollContent.forEach((item: HTMLElement) => {
            const duplicatedItem: HTMLElement = item.cloneNode(true) as HTMLElement;
            duplicatedItem.setAttribute("aria-hidden", "true");
            scrollPhotosInner.appendChild(duplicatedItem);
          });
        }
      }
    });
  }
</script>
