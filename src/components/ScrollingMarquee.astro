---
import { Picture } from "astro:assets";

import amalfi from "@/assets/amalfi.jpg";
import familyCruise from "@/assets/family-cruise.jpg";
import kathyLondon from "@/assets/kathy-london.jpg";
import lima from "@/assets/lima.jpg";
import tuscany from "@/assets/tuscany.jpg";

const items = [
  { src: amalfi, alt: "Amalfi Coast, Italy", imgText: "Amalfi Coast, Italy" },
  { src: tuscany, alt: "Tuscany, Italy", imgText: "Tuscany, Italy" },
  { src: familyCruise, alt: "Family cruise vacation", imgText: "Family Cruise" },
  { src: lima, alt: "Lima, Peru cityscape", imgText: "Lima, Peru" },
  { src: kathyLondon, alt: "Traveler in London", imgText: "London, England" },
];
---

<section>
  <div class="scrolling-photos">
    <div class="scrolling-photos-inner">
      {
        items.map(item => (
          <div class="polaroids">
            <div class="polaroids__img-wrapper">
              <Picture
                src={item.src}
                alt={item.alt ?? "Travel destination"}
                class="polaroids__img"
                loading="eager"
                width={2000}
                height={1000}
              />
              <p>{item.imgText}</p>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>

<style lang="scss">
  /* SCROLLING PHOTOS MARQUEE */
  .scrolling-photos {
    max-width: 100%;
    width: fit-content;
    margin: auto;
    overflow: hidden;

    &-inner {
      margin: 0;
      padding: 3rem 0;
      list-style: none;
      display: flex;
      gap: 3rem;
      width: max-content;
      flex-wrap: nowrap;
      animation: scrollPhotos 60s forwards linear infinite;
    }
  }

  .polaroids {
    background: #fff;
    padding: 0.5rem;
    padding-bottom: 5rem;
    border-radius: 0;
    filter: drop-shadow(2px 4px 15px rgba(20, 20, 20, 0.1));
    height: 500px;
    width: 100%;
    transform: rotate(-2deg);
    position: relative;

    &:nth-of-type(3n + 1) {
      transform: rotate(2deg) translateY(10px);
    }

    &:nth-of-type(3n + 2) {
      transform: rotate(1deg) translateY(-5px);
    }

    &__img-wrapper {
      aspect-ratio: 1/1;
      width: 100%;
      height: 100%;
      overflow: hidden;
    }

    p {
      height: 5rem;
      width: 100%;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 1.5rem;
      font-family: var(--secondary-family);
      position: absolute;
      bottom: 0;
      left: 0;
      z-index: 10;
      margin-bottom: 0;
    }
  }

  @keyframes scrollPhotos {
    to {
      transform: translate(calc(-50% - 1.5rem));
    }
  }
</style>

<script>
  const scrollPhotos: NodeListOf<HTMLElement> =
    document.querySelectorAll<HTMLElement>(".scrolling-photos");

  if (!window.matchMedia("(prefers-reduced-motion: reduce)").matches) {
    scrollingPhotos();
  }

  function scrollingPhotos(): void {
    scrollPhotos.forEach((scroller: HTMLElement) => {
      scroller.setAttribute("data-animated", "true");

      const scrollPhotosInner: HTMLElement | null =
        scroller.querySelector<HTMLElement>(".scrolling-photos-inner");
      if (scrollPhotosInner) {
        const scrollContent: HTMLElement[] = Array.from(
          scrollPhotosInner.children
        ) as HTMLElement[];

        for (let i = 0; i < 3; i++) {
          scrollContent.forEach((item: HTMLElement) => {
            const duplicatedItem: HTMLElement = item.cloneNode(true) as HTMLElement;
            duplicatedItem.setAttribute("aria-hidden", "true");
            scrollPhotosInner.appendChild(duplicatedItem);
          });
        }
      }
    });
  }
</script>
