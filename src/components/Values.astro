---
// COMPONENTS
import Heading from "@/components/Heading.astro";

// ICONS
import local from "@/assets/local.svg";
import lambo from "@/assets/lambo.svg";
import pricing from "@/assets/pricing.svg";
import fast from "@/assets/fast.svg";
import available from "@/assets/available.svg";
import quality from "@/assets/quality.svg";

import CardGrid from "./CardGrid.astro";

// DATA
const values = [
  {
    title: "Local One on One Service",
    description:
      "You deal directly with me from the first phone call until the job is done. No call centers or subcontractors.",
    icon: local,
    iconAlt: "Local service icon",
  },
  {
    title: "Lambo on Every Job",
    description:
      "Lambo comes to every appointment. He sits calmly nearby while I work and brings a friendly, personal touch that customers appreciate.",
    icon: lambo,
    iconAlt: "Dog paw icon",
  },
  {
    title: "Honest Pricing",
    description:
      "You get straightforward guidance on what is needed. No unnecessary repairs or sales tactics.",
    icon: pricing,
    iconAlt: "Pricing tag icon",
  },
  {
    title: "Fast Response Times",
    description:
      "Most garage door repairs in Estill Springs, Tullahoma and Murfreesboro are completed the same day.",
    icon: fast,
    iconAlt: "Fast service icon",
  },
  {
    title: "Available When You Need Me",
    description:
      "Open 7 days a week from 8 am to 11 pm with 24 hour emergency service for urgent issues.",
    icon: available,
    iconAlt: "24/7 availability icon",
  },
  {
    title: "Quality Workmanship",
    description:
      "Every repair and installation is done right the first time with attention to detail and lasting results.",
    icon: quality,
    iconAlt: "Quality workmanship icon",
  },
];
---

<section class="values bg-light">
  <div class="container container-md column-main">
    <div class="content-md">
      <Heading tag="h2" size="xl" fontFamily="primary" marginBottom="l" weight="fw500">
        Why Choose Lambo's Garage Door Service
      </Heading>
      <p class="margin-bottom-xl">
        When you hire Lambo's Garage Door Service, you are getting more than just a repair or
        installation. You are working with a locally owned business that values quality, honesty and
        personal service.
      </p>
    </div>
    <div class="content-full">
      <CardGrid cardData={values} />
    </div>
  </div>
</section>
