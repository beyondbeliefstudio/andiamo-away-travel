---
// COMPONENTS
import Heading from "@/components/Heading.astro";

// PROPS
interface Props {
  descriptionType?: "short" | "full";
}

const { descriptionType = "short" } = Astro.props;

const process = [
  {
    number: 1,
    title: "Call or Text Us for a Quote",
    description:
      "Reach out with a quick call or text and tell us what you need cleaned. We will provide clear pricing and help you choose the right service.",
  },
  {
    number: 2,
    title: "Schedule a Time That Works for You",
    description:
      "Pick a day and time that fits your schedule. We offer flexible appointment windows so service is convenient and stress-free.",
  },
  {
    number: 3,
    title: "We Show Up and Get to Work",
    description:
      "Our team arrives on time with professional equipment and gets started right away, focusing on deep, detailed cleaning from the start.",
  },
  {
    number: 4,
    title: "You Enjoy a Cleaner, Fresher Space",
    description:
      "Once we finish, you can relax in a cleaner, healthier home with noticeably fresher carpets, floors, and upholstery that look and feel renewed.",
  },
];
---

{
  process.map(item => (
    <div class="services-card card-2">
      <div class="services-card__content">
        <div class="services-card__info">
          <Heading
            tag="h3"
            size="display"
            fontFamily="primary"
            marginBottom="s"
            weight="fw800"
            class="number"
          >
            0{item.number}
          </Heading>
          <Heading tag="h3" size="m" fontFamily="primary" marginBottom="s" weight="fw800">
            {item.title}
          </Heading>
          <p>{item.description}</p>
        </div>
        {descriptionType === "full" && <p>{item.description}</p>}
      </div>
    </div>
  ))
}

<style lang="scss">
  .services-card {
    padding: 1rem;
    border-radius: var(--border-radius-small);
    background-color: var(--light-100);
    display: flex;
    flex-direction: column;
    gap: 1rem;
    transition: 0.3s ease all;
    text-decoration: none;
    color: inherit;
    position: sticky !important;
    top: 7rem;

    &__content {
      text-align: left;
      display: flex;
      gap: 0rem;
      flex-direction: column;
      align-items: start;
      justify-content: space-between;
      width: 100%;
    }

    &__info p {
      margin-bottom: 0;
    }

    &__info .number {
      color: var(--brand-primary);
      margin-bottom: 3rem;
    }
  }
</style>
