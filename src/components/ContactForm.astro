---
import Buttons from "./Buttons.astro";
---

<form
  data-netlify="true"
  data-netlify-recaptcha="true"
  netlify-honeypot="bot-field"
  name="contact"
  class="contact-form__form"
  method="POST"
  action="/submit-contact"
>
  <!-- Honeypot field - hidden from users but visible to bots -->
  <p class="hidden" style="position: absolute; left: -9999px; opacity: 0; pointer-events: none;">
    <label
      >Don't fill this out if you're human: <input
        name="bot-field"
        type="text"
        tabindex="-1"
        autocomplete="off"
      /></label
    >
  </p>

  <div class="form-row">
    <div class="form-group">
      <label for="firstName" class="contact-form__label"
        >First Name <span class="required">*</span></label
      >
      <input
        type="text"
        id="firstName"
        name="firstName"
        class="contact-form__input"
        placeholder="John"
        required
      />
    </div>
    <div class="form-group">
      <label for="lastName" class="contact-form__label"
        >Last Name <span class="required">*</span></label
      >
      <input
        type="text"
        id="lastName"
        name="lastName"
        class="contact-form__input"
        placeholder="Smith"
        required
      />
    </div>
  </div>

  <div class="form-row">
    <div class="form-group">
      <label for="email" class="contact-form__label">Email <span class="required">*</span></label>
      <input
        type="email"
        id="email"
        name="email"
        class="contact-form__input"
        placeholder="Enter your email"
        required
      />
    </div>
    <div class="form-group">
      <label for="phone" class="contact-form__label">Phone number</label>
      <input
        type="tel"
        id="phone"
        name="phone"
        class="contact-form__input"
        placeholder="+1 234 5678"
      />
    </div>
  </div>

  <div class="form-group">
    <label for="message" class="contact-form__label">Message</label>
    <textarea
      id="message"
      name="message"
      class="contact-form__textarea"
      placeholder="Leave your message..."
      rows="6"></textarea>
  </div>

  <!-- Netlify reCAPTCHA -->
  <div data-netlify-recaptcha="true"></div>

  <Buttons type="submit" variant="primary">SEND A MESSAGE</Buttons>
</form>

<style lang="scss">
  .contact-form {
    &__form {
      margin-top: 2rem;
    }
  }
</style>

<script>
  document.addEventListener("DOMContentLoaded", function () {
    const contactForm = document.querySelector(".contact-form__form") as HTMLFormElement;

    if (contactForm) {
      contactForm.addEventListener("submit", function (e) {
        // Check honeypot field
        const honeypotField = contactForm.querySelector(
          'input[name="bot-field"]'
        ) as HTMLInputElement;
        if (honeypotField && honeypotField.value.trim() !== "") {
          e.preventDefault();
          alert("Form submission failed. Please try again.");
          return;
        }

        // Basic rate limiting check
        const lastSubmission = localStorage.getItem("lastContactSubmission");
        const now = Date.now();
        if (lastSubmission && now - parseInt(lastSubmission) < 5000) {
          // 5 second cooldown
          e.preventDefault();
          alert("Please wait a moment before submitting again.");
          return;
        }

        // Store submission time
        localStorage.setItem("lastContactSubmission", now.toString());
      });
    }
  });
</script>
