---

<div id="lighthouse-gallery-modal" class="lighthouse-gallery-modal">
  <div class="lighthouse-gallery-modal__backdrop"></div>
  <div class="lighthouse-gallery-modal__container">
    <button class="lighthouse-gallery-modal__close" aria-label="Close gallery">
      <span>&times;</span>
    </button>
    <div class="lighthouse-gallery-modal__image-wrapper">
      <img id="lighthouse-gallery-modal__image" src="/" alt="Gallery Image" />
    </div>
  </div>
</div>

<style lang="scss">
  .lighthouse-gallery-modal {
    position: fixed;
    z-index: 999999;
    left: 0;
    top: 0;
    width: 100vw;
    height: 100vh;
    display: none;
    align-items: center;
    justify-content: center;
    opacity: 0;
    visibility: hidden;
    transition:
      opacity 0.3s ease,
      visibility 0.3s ease;

    &.active {
      display: flex;
      opacity: 1;
      visibility: visible;
    }

    &__backdrop {
      position: absolute;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      background: rgba(0, 0, 0, 0.95);
      backdrop-filter: blur(2px);
      cursor: pointer;
    }

    &__container {
      position: relative;
      max-width: 90vw;
      max-height: 90vh;
      display: flex;
      align-items: center;
      justify-content: center;
      z-index: 1;
    }

    &__image-wrapper {
      position: relative;
      border-radius: var(--border-radius-medium);
      overflow: hidden;
      box-shadow: 0 20px 60px rgba(0, 0, 0, 0.5);
    }

    &__image-wrapper img {
      max-width: 90vw;
      max-height: 85vh;
      width: auto;
      height: auto;
      object-fit: contain;
      border-radius: var(--border-radius-medium);
      transition: transform 0.3s ease;
    }

    &__close {
      position: absolute;
      top: -50px;
      right: 0;
      background: rgba(255, 255, 255, 0.1);
      border: none;
      border-radius: 50%;
      width: 40px;
      height: 40px;
      display: flex;
      align-items: center;
      justify-content: center;
      cursor: pointer;
      z-index: 2;
      transition:
        background-color 0.3s ease,
        transform 0.2s ease;

      span {
        font-size: 24px;
        color: #ffffff;
        font-weight: 300;
        line-height: 1;
      }

      &:hover {
        background: rgba(255, 255, 255, 0.2);
        transform: scale(1.1);
      }

      &:focus {
        outline: 2px solid var(--brand-primary);
        outline-offset: 2px;
      }
    }

    // Mobile adjustments
    @media (max-width: 768px) {
      &__close {
        top: 20px;
        right: 20px;
        background: rgba(0, 0, 0, 0.8);
      }

      &__image-wrapper img {
        max-width: 95vw;
        max-height: 80vh;
      }
    }
  }
</style>
