---
import Heading from "../Heading.astro";
import Links from "@/components/Links.astro";

// Photos
import stockRepair from "@/assets/stock-repair.jpg";
import stockSpring from "@/assets/stock-spring.jpg";
import garageInstall from "@/assets/garage-install.jpg";
import garageFix from "@/assets/garage-fix.jpg";
import heroImage from "@/assets/heroPlaceholder.jpg";
import garageEmergency from "@/assets/garage-emergency.jpg";

const services = [
  {
    title: "Garage Door Repair",
    description:
      "Fixing doors that will not open or close. Loud doors. Off track doors. Broken rollers. Damaged panels.",
    image: stockRepair,
    imageAlt: "Professional garage door repair service in Middle Tennessee",
    cta: {
      text: "Learn More",
      href: "/services/repair",
    },
  },
  {
    title: "Spring Replacement",
    description: "Torsion and extension spring replacement for broken or worn garage door springs.",
    image: stockSpring,
    imageAlt: "Same day garage door spring replacement service",
    cta: {
      text: "Learn More",
      href: "/services/spring-replacement",
    },
  },
  {
    title: "Garage Door Installation",
    description:
      "New garage doors installed for homes in Middle Tennessee. Professional setup and removal of old doors.",
    image: garageInstall,
    imageAlt: "New garage door installation for homes in Middle Tennessee",
    cta: {
      text: "Learn More",
      href: "/services/installation",
    },
  },
  {
    title: "Opener Repair and Installation",
    description:
      "Fixing non responsive garage door openers. Installing new LiftMaster and Chamberlain style openers.",
    image: garageFix,
    imageAlt: "Garage door opener repair and installation with WiFi features",
    cta: {
      text: "Learn More",
      href: "/services/opener",
    },
  },
  {
    title: "Garage Door Maintenance",
    description: "Tune ups. Lubrication. Safety checks. Balance adjustments.",
    image: heroImage,
    imageAlt: "Regular garage door maintenance and tune-up service",
    cta: {
      text: "Learn More",
      href: "/services/maintenance",
    },
  },
  {
    title: "24 Hour Emergency Service",
    description:
      "Fast emergency garage door repair in Estill Springs, Tullahoma, Murfreesboro and surrounding areas.",
    image: garageEmergency,
    imageAlt: "24 hour emergency garage door repair service in Middle Tennessee",
    cta: {
      text: "Learn More",
      href: "tel:615-555-0123",
    },
  },
];
---

<section class="services">
  <div class="container container-md column-main services__container">
    <div class="services__intro">
      <Heading
        tag="h2"
        size="xl"
        fontFamily="primary"
        marginBottom="l"
        weight="fw500"
        textTransform="uppercase"
      >
        Our Garage Door Services
      </Heading>
      <p class="margin-bottom-xl">
        At Lambo's Garage Door Service, I provide a full range of garage door services to homeowners
        throughout Middle Tennessee. Whether you need a quick repair, a new door installation or
        regular maintenance, I am here to help. Below are some of the most popular services I offer:
      </p>
      <Links href="/services" variant="primary"> View All Services </Links>
    </div>
    <div class="services__grid">
      {
        services.map(service => (
          <a href={service.cta.href} class="services__card">
            <div class="img-wrapper">
              <img
                src={service.image.src}
                alt={service.imageAlt}
                class="services__image margin-bottom-m"
              />
            </div>
            <div class="services__content">
              <div class="services__info">
                <Heading
                  tag="h3"
                  size="m"
                  fontFamily="primary"
                  marginBottom="s"
                  weight="fw500"
                  textTransform="uppercase"
                >
                  {service.title}
                </Heading>
                <p>{service.description}</p>
              </div>
              <div class="services__arrow">
                <svg
                  width="24"
                  height="24"
                  viewBox="0 0 24 24"
                  fill="none"
                  xmlns="http://www.w3.org/2000/svg"
                >
                  <path
                    d="M5 12h14m0 0l-7-7m7 7l-7 7"
                    stroke="currentColor"
                    stroke-width="1.5"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  />
                </svg>
              </div>
            </div>
          </a>
        ))
      }
    </div>
  </div>
</section>

<style lang="scss">
  .services {
    &__container {
      align-items: flex-start;
      flex-direction: row;
    }

    &__intro {
      position: sticky !important;
      top: 15rem;
      width: 50%;

      @media (max-width: 1024px) {
        position: static !important;
      }
    }

    &__grid {
      display: flex;
      flex-direction: column;
      width: 50%;
      gap: 1rem;
    }

    &__card {
      padding: 1rem;
      padding-bottom: 0.5rem;
      border-radius: var(--border-radius-medium);
      background-color: var(--light-200);
      display: flex;
      flex-direction: column;
      gap: 1rem;
      transition: 0.3s ease all;
      text-decoration: none;
      color: inherit;

      &:hover {
        background-color: var(--brand-primary);
        color: var(--light-100);

        * {
          color: var(--light-100) !important;
        }

        .services__arrow {
          background-color: var(--light-100);

          svg {
            transition: 0.3s ease all;
            transform: rotate(-25deg);
          }

          svg path {
            color: var(--dark-900) !important;
          }
        }
      }

      .img-wrapper {
        aspect-ratio: 2 / 1;
        overflow: hidden;
        object-fit: cover;
        border-radius: 5px;
      }
    }

    &__content {
      text-align: left;
      display: flex;
      gap: 0.5rem;
      flex-direction: row;
      align-items: center;
      justify-content: space-between;
    }

    &__info {
      width: calc(100% - 6rem);
    }

    &__arrow {
      width: 4rem;
      height: 4rem;
      border-radius: 50%;
      background-color: var(--brand-primary);
      border: 1px solid #000;
      display: flex;
      align-items: center;
      justify-content: center;
      transition: all 0.3s ease;

      svg {
        width: 2rem;
        height: 2rem;
        color: var(--light-100);
        transform: rotate(0deg);
        transition: color 0.3s ease;
      }
    }
  }
</style>
