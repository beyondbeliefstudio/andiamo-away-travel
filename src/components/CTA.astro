---
// COMPONENTS
import Heading from "@/components/Heading.astro";
import Buttons from "@/components/Buttons.astro";

// DATA
import { baseData } from "@/data/siteData";

// HELPERS
import { Image } from "astro:assets";

// IMAGES
import garageHome from "@/assets/garageHome.jpg";
import callIcon from "@/assets/call.svg";
import mailIcon from "@/assets/mail.svg";
---

<section class="CTA">
  <div class="container container-md CTA__container">
    <div class="CTA__content grid-auto-2">
      <Image src={garageHome} alt="Garage door service" class="CTA__bg" />
      <div class="CTA__overlay"></div>
      <div class="CTA__text">
        <Heading tag="h2" size="xl" fontFamily="primary" marginBottom="m" weight="fw500"
          >We're Just A Call Away
        </Heading>
        <p class="large">
          If your garage door is not working or you need a new one installed, I am here to help.
        </p>
        <div class="CTA__contact-info">
          <a href={`tel:${baseData.phone.replace(/\D/g, "")}`} class="CTA__contact-item">
            <span class="CTA__icon">
              <Image src={callIcon} alt="Phone" width={24} height={24} />
            </span>
            {baseData.phone}
          </a>
          <a href={`mailto:${baseData.email}`} class="CTA__contact-item">
            <span class="CTA__icon">
              <Image src={mailIcon} alt="Email" width={24} height={24} />
            </span>
            {baseData.email}
          </a>
        </div>
      </div>

      <div class="CTA__form-wrapper">
        <form class="CTA__form">
          <Heading tag="h3" size="l" fontFamily="primary" marginBottom="none" weight="fw500"
            >Book Your Service</Heading
          >

          <div class="form-group">
            <label for="name">Name</label>
            <input type="text" id="name" name="name" placeholder="Your Name" required />
          </div>

          <div class="form-group">
            <label for="email">Email</label>
            <input type="email" id="email" name="email" placeholder="demo@mail.com" required />
          </div>

          <div class="form-group">
            <label for="phone">Phone</label>
            <input type="tel" id="phone" name="phone" placeholder="xxx-xxx-xxx" required />
          </div>

          <div class="form-group">
            <label for="service">Service</label>
            <select id="service" name="service" required>
              <option value="">Select a service</option>
              <option value="repair">Garage Door Repair</option>
              <option value="spring">Spring Replacement</option>
              <option value="installation">Garage Door Installation</option>
              <option value="opener">Opener Repair and Installation</option>
              <option value="maintenance">Garage Door Maintenance</option>
              <option value="emergency">24 Hour Emergency Service</option>
            </select>
          </div>

          <!-- <button type="submit" class="CTA__submit">Make An Appointment</button> -->
          <Buttons variant="primary" type="submit">Make An Appointment</Buttons>
        </form>
      </div>
    </div>
  </div>
</section>

<style lang="scss">
  .CTA {
    &__content {
      position: relative;
      gap: var(--_spacing---section-space--main);
      align-items: center;
      padding: var(--_spacing---section-space--main);
      overflow: hidden;
      border-radius: var(--border-radius-small);

      @media (max-width: 1024px) {
        grid-template-columns: 1fr;
      }
    }

    &__bg {
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      bottom: 0;
      background-size: cover;
      background-position: center;
      background-repeat: no-repeat;
      opacity: 0.2; // Adjust this value (0 to 1) to control image opacity
      z-index: 0;
      background-attachment: fixed;
    }

    &__overlay {
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      bottom: 0;
      z-index: 1;
      pointer-events: none;
      background: rgb(36, 26, 26);
      mix-blend-mode: lighten;
    }

    &__text {
      position: relative;
      z-index: 2;

      h2,
      h3,
      h4,
      p {
        color: var(--light-100);
      }
    }

    &__contact-info {
      display: flex;
      flex-direction: column;
      gap: 1rem;
      margin-top: 1rem;
    }

    &__contact-item {
      display: flex;
      align-items: center;
      gap: 1rem;
      font-size: var(--_typography---font-size--text-large);
      color: var(--light-100);
      text-decoration: none;
      transition: all 0.2s ease;
      font-family: var(--primary-family);

      &:hover {
        color: var(--light-200);
        text-decoration: underline;
      }
    }

    &__icon {
      font-size: 1.5rem;
      width: 60px;
      height: 60px;
      display: flex;
      align-items: center;
      justify-content: center;
      background: var(--brand-primary);
      border-radius: 50%;
      border: 1px solid var(--dark-900);

      @media screen and (max-width: 768px) {
        width: 40px;
        height: 40px;
      }

      img {
        width: 32px;
        height: 32px;
        filter: invert(1);

        @media screen and (max-width: 768px) {
          width: 24px;
          height: 24px;
        }
      }
    }

    &__form-wrapper {
      h3 {
        text-align: center;
      }
    }
  }
</style>
