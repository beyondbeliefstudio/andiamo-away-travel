---
// COMPONENTS
import Heading from "@/components/Heading.astro";
import Buttons from "@/components/Buttons.astro";

// DATA
import { baseData } from "@/data/siteData";

// HELPERS
import { Image, Picture } from "astro:assets";

// IMAGES
import callIcon from "@/assets/call.svg";
import mailIcon from "@/assets/mail.svg";
---

<section class="CTA bg-dark">
  <div class="container container-md CTA__container">
    <div class="CTA__content grid-auto-2">
      <div class="CTA__form-wrapper">
        <form
          data-netlify="true"
          data-netlify-recaptcha="true"
          netlify-honeypot="bot-field"
          name="book-service"
          class="CTA__form"
          method="POST"
          action="/submit-booking"
        >
          <!-- Honeypot field - hidden from users but visible to bots -->
          <p
            class="hidden"
            style="position: absolute; left: -9999px; opacity: 0; pointer-events: none;"
          >
            <label
              >Don't fill this out if you're human: <input
                name="bot-field"
                type="text"
                tabindex="-1"
                autocomplete="off"
              /></label
            >
          </p>

          <!-- <Heading tag="h3" size="l" fontFamily="primary" marginBottom="none" weight="fw500"
            >Book Your Service</Heading
          > -->

          <div class="form-group">
            <label for="name">Name</label>
            <input type="text" id="name" name="name" placeholder="Your Name" required />
          </div>

          <div class="form-group">
            <label for="email">Email</label>
            <input type="email" id="email" name="email" placeholder="demo@mail.com" required />
          </div>

          <div class="form-group">
            <label for="phone">Phone</label>
            <input type="tel" id="phone" name="phone" placeholder="xxx-xxx-xxx" required />
          </div>

          <div class="form-group">
            <label for="service">Service</label>
            <select id="service" name="service" required>
              <option value="">Select a service</option>
              <option value="carpet-cleaning">Carpet Cleaning</option>
              <option value="tile-grout-cleaning">Tile and Grout Cleaning</option>
              <option value="upholstery-cleaning">Upholstery Cleaning</option>
              <option value="air-duct-cleaning">Air Duct Cleaning</option>
              <option value="dryer-vent-cleaning">Dryer Vent Cleaning</option>
              <option value="lvp-laminate-cleaning">LVP and Laminate Floor Cleaning</option>
              <option value="hardwood-floor-cleaning">Hardwood Floor Cleaning</option>
              <option value="water-damage-restoration">Water Damage Restoration</option>
              <option value="emergency-flood-cleanup">Emergency Flood Cleanup</option>
              <option value="odor-stain-removal">Odor and Stain Removal</option>
            </select>
          </div>

          <!-- Netlify reCAPTCHA -->
          <div data-netlify-recaptcha="true"></div>

          <!-- <button type="submit" class="CTA__submit">Make An Appointment</button> -->
          <Buttons variant="primary" type="submit">Make An Appointment</Buttons>
        </form>
      </div>
      <div class="CTA__text">
        <Heading
          tag="h2"
          size="xxl"
          fontFamily="primary"
          marginBottom="m"
          weight="fw800"
          textTransform="capitalize"
          >Book your cleaning service today.
        </Heading>
        <p>
          Whether you need a deep carpet cleaning or emergency restoration, Mercy Carpet Cleaning &
          Restoration is ready to help. We make it easy, we show up on time, and we get results.
        </p>
        <div class="CTA__contact-info">
          <a href={`tel:${baseData.phone.replace(/\D/g, "")}`} class="CTA__contact-item">
            <span class="CTA__icon">
              <Image src={callIcon} alt="Phone" width={24} height={24} />
            </span>
            {baseData.phone}
          </a>
          <a href={`mailto:${baseData.email}`} class="CTA__contact-item">
            <span class="CTA__icon">
              <Image src={mailIcon} alt="Email" width={24} height={24} />
            </span>
            {baseData.email}
          </a>
        </div>
      </div>
    </div>
  </div>
</section>

<style lang="scss">
  .CTA {
    &__content {
      position: relative;
      gap: var(--_spacing---section-space--main);
      align-items: center;

      @media (max-width: 1024px) {
        grid-template-columns: 1fr;
      }
    }

    &__bg {
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      bottom: 0;
      z-index: 0;
      opacity: 0.2; // Adjust this value (0 to 1) to control image opacity

      :global(picture),
      :global(img) {
        width: 100%;
        height: 100%;
        object-fit: cover;
        object-position: center;
      }
    }

    &__overlay {
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      bottom: 0;
      z-index: 1;
      pointer-events: none;
      background: rgb(36, 26, 26);
      mix-blend-mode: lighten;
    }

    &__text {
      position: relative;
      z-index: 2;

      h2,
      h3,
      h4,
      p {
        color: var(--light-100);
      }
    }

    &__contact-info {
      display: flex;
      flex-direction: column;
      gap: 1rem;
      margin-top: 1rem;
    }

    &__contact-item {
      display: flex;
      align-items: center;
      gap: 1rem;
      // font-size: var(--_typography---font-size--text-large);
      color: var(--light-100);
      text-decoration: none;
      transition: all 0.2s ease;
      font-family: var(--primary-family);
      font-weight: 400;

      &:hover {
        color: var(--light-200);
        text-decoration: underline;
      }
    }

    &__icon {
      font-size: 1.5rem;
      display: flex;
      align-items: center;
      justify-content: center;

      @media screen and (max-width: 768px) {
        width: 40px;
        height: 40px;
      }

      img {
        width: 32px;
        height: 32px;
        filter: invert(1);

        @media screen and (max-width: 768px) {
          width: 24px;
          height: 24px;
        }
      }
    }

    &__form-wrapper {
      h3 {
        text-align: center;
      }
    }
  }
</style>
