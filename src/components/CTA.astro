---
// COMPONENTS
import Heading from "@/components/Heading.astro";
import Buttons from "@/components/Buttons.astro";

// DATA
import { baseData } from "@/data/siteData";

// HELPERS
import { Image } from "astro:assets";
import type { HTMLAttributes } from "astro/types";

export interface CTAProps extends HTMLAttributes<"section"> {
  classes?: string;
}

const { classes, ...rest } = Astro.props;

// IMAGES
import callIcon from "@/assets/call.svg";
import mailIcon from "@/assets/mail.svg";
import planeIcon from "@/assets/plane.svg";
---

<section class:list={["CTA bg-secondary", classes]} {...rest}>
  <div class="container container-md CTA__container">
    <div class="CTA__content grid-auto-2">
      <div class="CTA__form-wrapper">
        <form
          data-netlify="true"
          data-netlify-recaptcha="true"
          netlify-honeypot="bot-field"
          name="book-service"
          class="CTA__form"
          method="POST"
          action="/thank-you"
        >
          <input type="hidden" name="form-name" value="book-service" />

          <!-- Honeypot field - hidden from users but visible to bots -->
          <p
            class="hidden"
            style="position: absolute; left: -9999px; opacity: 0; pointer-events: none;"
          >
            <label
              >Don't fill this out if you're human: <input
                name="bot-field"
                type="text"
                tabindex="-1"
                autocomplete="off"
              /></label
            >
          </p>
          <Heading tag="h3" size="l" fontFamily="primary" marginBottom="none" weight="fw500"
            >Trip Information</Heading
          >

          <!-- <Heading tag="h3" size="l" fontFamily="primary" marginBottom="none" weight="fw500"
            >Book Your Service</Heading
          > -->

          <div class="form-group">
            <label for="name">Name <span class="required">*</span></label>
            <input type="text" id="name" name="name" placeholder="Your Name" required />
          </div>

          <div class="form-group">
            <label for="email">Email <span class="required">*</span></label>
            <input type="email" id="email" name="email" placeholder="demo@mail.com" required />
          </div>

          <div class="form-group">
            <label for="phone">Phone <span class="required">*</span></label>
            <input type="tel" id="phone" name="phone" placeholder="xxx-xxx-xxx" required />
          </div>

          <div class="form-group">
            <label for="tripType">Trip Type <span class="required">*</span></label>
            <select id="tripType" name="tripType" required>
              <option value="">Select a trip type</option>
              <option value="luxury-all-inclusive-resorts"
                >Luxury &amp; All-Inclusive Resorts</option
              >
              <option value="cruises">Cruises</option>
              <option value="global-adventures">Global Adventures</option>
              <option value="family-vacations">Family Vacations</option>
              <option value="honeymoons-romantic-getaways"
                >Honeymoons &amp; Romantic Getaways</option
              >
              <option value="milestones-or-celebrations">Milestones or Celebrations</option>
              <option value="golf-trips">Golf Trips</option>
              <option value="custom-multi-destination-itinerary"
                >Custom Multi-Destination Itinerary</option
              >
              <option value="not-sure-yet">Not Sure Yet</option>
              <option value="other">Other</option>
            </select>
          </div>

          <div class="form-group">
            <label for="tripDetails">Tell Us About Your Trip <span class="required">*</span></label>
            <textarea
              id="tripDetails"
              name="tripDetails"
              rows="6"
              placeholder="Share your destinations, dates, budget range, travelers, and any must-haves."
              required
            ></textarea>
          </div>

          <div class="form-group">
            <label>Preferred Method of Contact <span class="required">*</span></label>
            <div class="form-checkboxes" id="contactMethodGroup">
              <label class="checkbox-label">
                <input type="checkbox" name="contactMethod" value="text" />
                Text
              </label>
              <label class="checkbox-label">
                <input type="checkbox" name="contactMethod" value="call" />
                Call
              </label>
              <label class="checkbox-label">
                <input type="checkbox" name="contactMethod" value="email" />
                Email
              </label>
            </div>
            <p class="form-error" id="contactMethodError" hidden>Please select at least one preferred method of contact.</p>
          </div>

          <!-- Netlify reCAPTCHA -->
          <div data-netlify-recaptcha="true"></div>

          <Buttons variant="primary" type="submit">Submit</Buttons>
        </form>
      </div>
      <div class="CTA__text">
        <Heading
          tag="h2"
          size="xl"
          fontFamily="primary"
          marginBottom="l"
          weight="fw500"
          textTransform="capitalize"
          >Start Planning Your Next Getaway
        </Heading>
        <Heading
          tag="h3"
          size="s"
          fontFamily="primary"
          marginBottom="s"
          weight="fw700"
          textTransform="capitalize"
          >Let’s Talk About The Trip You’ve Been Dreaming About
        </Heading>
        <p>
          Every great vacation starts with a conversation. Fill out the short form below and Kathy
          will personally reach out to learn more about your travel goals, preferred destinations,
          budget, timeline, and the type of experience you’re hoping to create.
        </p>
        <p>
          Whether you already have a destination in mind or are still exploring ideas, this initial
          conversation helps us better understand how to guide you toward the right trip. From
          relaxing beach escapes and cruises to bucket-list European adventures, Andiamo Away is
          here to help make the planning process feel easier, more personalized, and far less
          overwhelming.
        </p>
      </div>
    </div>
  </div>
</section>

<div class="form-success-modal" id="cta-success-modal" aria-hidden="true" role="dialog" aria-modal="true" aria-labelledby="cta-success-title">
  <div class="form-success-modal__backdrop"></div>
  <div class="form-success-modal__box">
    <button class="form-success-modal__close" aria-label="Close">&#x2715;</button>
    <Image src={planeIcon} alt="" aria-hidden="true" class="form-success-modal__icon" width={48} height={48} />
    <Heading tag="h3" size="l" fontFamily="primary" marginBottom="s" weight="fw500" id="cta-success-title">
      You're all set!
    </Heading>
    <p>Kathy will personally reach out within 1–2 business days to start planning your trip.</p>
  </div>
</div>

<style lang="scss">
  .CTA {
    &__content {
      position: relative;
      gap: var(--_spacing---section-space--main);
      align-items: center;

      @media (max-width: 1024px) {
        grid-template-columns: 1fr;
      }
    }

    &__bg {
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      bottom: 0;
      z-index: 0;
      opacity: 0.2; // Adjust this value (0 to 1) to control image opacity

      :global(picture),
      :global(img) {
        width: 100%;
        height: 100%;
        object-fit: cover;
        object-position: center;
      }
    }

    &__overlay {
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      bottom: 0;
      z-index: 1;
      pointer-events: none;
      background: rgb(36, 26, 26);
      mix-blend-mode: lighten;
    }

    &__text {
      position: relative;
      z-index: 2;

      @media (max-width: 768px) {
        order: -1;
      }

      // h2,
      // h3,
      // h4,
      // p {
      //   color: var(--light-100);
      // }
    }

    &__icon {
      font-size: 1.5rem;
      display: flex;
      align-items: center;
      justify-content: center;

      @media screen and (max-width: 768px) {
        width: 40px;
        height: 40px;
      }

      img {
        width: 32px;
        height: 32px;

        @media screen and (max-width: 768px) {
          width: 24px;
          height: 24px;
        }
      }
    }

    &__form-wrapper {
      h3 {
        text-align: center;
        color: var(--brand-primary);
      }

      textarea {
        width: 100%;
        min-height: 8rem;
        resize: vertical;
      }

      .form-checkboxes {
        display: flex;
        gap: 1.5rem;
        flex-wrap: wrap;
      }

      .checkbox-label {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        font-weight: 500;
        cursor: pointer;

        input[type="checkbox"] {
          width: 1.1rem;
          height: 1.1rem;
          accent-color: var(--brand-primary);
          cursor: pointer;
        }
      }

      .form-error {
        margin-top: 0.4rem;
        font-size: 0.85rem;
        color: #d32f2f;
        margin-bottom: 0;
      }
    }
  }

  .form-success-modal {
    display: none;
    position: fixed;
    inset: 0;
    z-index: 9999;
    align-items: center;
    justify-content: center;

    &.is-open {
      display: flex;
    }

    &__backdrop {
      position: absolute;
      inset: 0;
      background: rgba(0, 0, 0, 0.55);
      cursor: pointer;
    }

    &__box {
      position: relative;
      z-index: 1;
      background: #fff;
      border-radius: var(--border-radius-medium);
      padding: 3rem 2.5rem;
      max-width: 480px;
      width: calc(100% - 2rem);
      text-align: center;
      box-shadow: 0 8px 40px rgba(0, 0, 0, 0.18);

      p {
        margin-bottom: 0;
        color: var(--dark-700);
      }
    }

    &__close {
      position: absolute;
      top: 1rem;
      right: 1rem;
      background: none;
      border: none;
      font-size: 1.25rem;
      cursor: pointer;
      color: var(--dark-500);
      line-height: 1;
      padding: 0.25rem 0.5rem;

      &:hover {
        color: var(--dark-900);
      }
    }

    &__icon {
      width: 48px;
      height: 48px;
      margin-bottom: 1rem;
    }
  }
</style>

<script>
  const form = document.querySelector<HTMLFormElement>(".CTA__form");
  const modal = document.getElementById("cta-success-modal");
  const closeBtn = modal?.querySelector<HTMLButtonElement>(".form-success-modal__close");
  const backdrop = modal?.querySelector<HTMLDivElement>(".form-success-modal__backdrop");

  function openModal() {
    modal?.classList.add("is-open");
    modal?.setAttribute("aria-hidden", "false");
    closeBtn?.focus();
    document.body.style.overflow = "hidden";
  }

  function closeModal() {
    modal?.classList.remove("is-open");
    modal?.setAttribute("aria-hidden", "true");
    document.body.style.overflow = "";
  }

  const checkboxGroup = document.getElementById("contactMethodGroup");
  const checkboxError = document.getElementById("contactMethodError");

  form?.addEventListener("submit", async e => {
    e.preventDefault();

    const checked = checkboxGroup?.querySelectorAll<HTMLInputElement>("input:checked").length ?? 0;
    if (checked === 0) {
      if (checkboxError) checkboxError.hidden = false;
      checkboxGroup?.querySelector("input")?.focus();
      return;
    }
    if (checkboxError) checkboxError.hidden = true;

    const body = new URLSearchParams(new FormData(form) as unknown as Record<string, string>).toString();

    try {
      const res = await fetch("/", {
        method: "POST",
        headers: { "Content-Type": "application/x-www-form-urlencoded" },
        body,
      });

      if (res.ok) {
        form.reset();
        openModal();
      } else {
        form.submit();
      }
    } catch {
      form.submit();
    }
  });

  closeBtn?.addEventListener("click", closeModal);
  backdrop?.addEventListener("click", closeModal);

  document.addEventListener("keydown", e => {
    if (e.key === "Escape" && modal?.classList.contains("is-open")) {
      closeModal();
    }
  });
</script>
