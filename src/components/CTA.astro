---
// COMPONENTS
import Heading from "@/components/Heading.astro";
import Buttons from "@/components/Buttons.astro";

// DATA
import { baseData } from "@/data/siteData";

// HELPERS
import { Image, Picture } from "astro:assets";
import type { HTMLAttributes } from "astro/types";

export interface CTAProps extends HTMLAttributes<"section"> {
  classes?: string;
}

const { classes, ...rest } = Astro.props;

// IMAGES
import callIcon from "@/assets/call.svg";
import mailIcon from "@/assets/mail.svg";
---

<section class:list={["CTA bg-secondary", classes]} {...rest}>
  <div class="container container-md CTA__container">
    <div class="CTA__content grid-auto-2">
      <div class="CTA__form-wrapper">
        <form
          data-netlify="true"
          data-netlify-recaptcha="true"
          netlify-honeypot="bot-field"
          name="book-service"
          class="CTA__form"
          method="POST"
          action="/submit-booking"
        >
          <!-- Honeypot field - hidden from users but visible to bots -->
          <p
            class="hidden"
            style="position: absolute; left: -9999px; opacity: 0; pointer-events: none;"
          >
            <label
              >Don't fill this out if you're human: <input
                name="bot-field"
                type="text"
                tabindex="-1"
                autocomplete="off"
              /></label
            >
          </p>
          <Heading tag="h3" size="l" fontFamily="primary" marginBottom="none" weight="fw500"
            >Trip Information</Heading
          >

          <!-- <Heading tag="h3" size="l" fontFamily="primary" marginBottom="none" weight="fw500"
            >Book Your Service</Heading
          > -->

          <div class="form-group">
            <label for="name">Name</label>
            <input type="text" id="name" name="name" placeholder="Your Name" required />
          </div>

          <div class="form-group">
            <label for="email">Email</label>
            <input type="email" id="email" name="email" placeholder="demo@mail.com" required />
          </div>

          <div class="form-group">
            <label for="phone">Phone</label>
            <input type="tel" id="phone" name="phone" placeholder="xxx-xxx-xxx" required />
          </div>

          <div class="form-group">
            <label for="tripType">Trip Type</label>
            <select id="tripType" name="tripType" required>
              <option value="">Select a trip type</option>
              <option value="luxury-all-inclusive-resorts"
                >Luxury &amp; All-Inclusive Resorts</option
              >
              <option value="cruises">Cruises</option>
              <option value="european-adventures">European Adventures</option>
              <option value="family-vacations">Family Vacations</option>
              <option value="honeymoons-romantic-getaways"
                >Honeymoons &amp; Romantic Getaways</option
              >
              <option value="disney-destinations">Disney Destinations</option>
              <option value="custom-multi-destination-itinerary"
                >Custom Multi-Destination Itinerary</option
              >
              <option value="not-sure-yet">Not Sure Yet</option>
              <option value="other">Other</option>
            </select>
          </div>

          <div class="form-group">
            <label for="tripDetails">Tell Us About Your Trip</label>
            <textarea
              id="tripDetails"
              name="tripDetails"
              rows="6"
              placeholder="Share your destinations, dates, budget range, travelers, and any must-haves."
            ></textarea>
          </div>

          <!-- Netlify reCAPTCHA -->
          <div data-netlify-recaptcha="true"></div>

          <!-- <button type="submit" class="CTA__submit">Make An Appointment</button> -->
          <Buttons variant="primary" type="submit">Make An Appointment</Buttons>
        </form>
      </div>
      <div class="CTA__text">
        <Heading
          tag="h2"
          size="xl"
          fontFamily="primary"
          marginBottom="l"
          weight="fw500"
          textTransform="capitalize"
          >Start Planning Your Next Getaway
        </Heading>
        <Heading
          tag="h3"
          size="s"
          fontFamily="primary"
          marginBottom="s"
          weight="fw700"
          textTransform="capitalize"
          >Let’s Talk About The Trip You’ve Been Dreaming About
        </Heading>
        <p>
          Every great vacation starts with a conversation. Fill out the short form below and Kathy
          will personally reach out to learn more about your travel goals, preferred destinations,
          budget, timeline, and the type of experience you’re hoping to create.
        </p>
        <p>
          Whether you already have a destination in mind or are still exploring ideas, this initial
          conversation helps us better understand how to guide you toward the right trip. From
          relaxing beach escapes and cruises to bucket-list European adventures, Andiamo Away is
          here to help make the planning process feel easier, more personalized, and far less
          overwhelming.
        </p>
      </div>
    </div>
  </div>
</section>

<style lang="scss">
  .CTA {
    &__content {
      position: relative;
      gap: var(--_spacing---section-space--main);
      align-items: center;

      @media (max-width: 1024px) {
        grid-template-columns: 1fr;
      }
    }

    &__bg {
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      bottom: 0;
      z-index: 0;
      opacity: 0.2; // Adjust this value (0 to 1) to control image opacity

      :global(picture),
      :global(img) {
        width: 100%;
        height: 100%;
        object-fit: cover;
        object-position: center;
      }
    }

    &__overlay {
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      bottom: 0;
      z-index: 1;
      pointer-events: none;
      background: rgb(36, 26, 26);
      mix-blend-mode: lighten;
    }

    &__text {
      position: relative;
      z-index: 2;

      // h2,
      // h3,
      // h4,
      // p {
      //   color: var(--light-100);
      // }
    }

    &__icon {
      font-size: 1.5rem;
      display: flex;
      align-items: center;
      justify-content: center;

      @media screen and (max-width: 768px) {
        width: 40px;
        height: 40px;
      }

      img {
        width: 32px;
        height: 32px;

        @media screen and (max-width: 768px) {
          width: 24px;
          height: 24px;
        }
      }
    }

    &__form-wrapper {
      h3 {
        text-align: center;
        color: var(--brand-primary);
      }

      textarea {
        width: 100%;
        min-height: 12rem;
        resize: vertical;
      }
    }
  }
</style>
