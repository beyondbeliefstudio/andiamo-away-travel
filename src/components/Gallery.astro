---
// HELPERS
import { Image, Picture } from "astro:assets";
const { items } = Astro.props;
---

<div class="content-full">
  <div class="projects flex">
    {
      items.map((item: { src: string; alt?: string; id?: string }) => (
        <div class="projects__img-wrapper card-3">
          <Picture
            src={item.src}
            formats={["avif", "webp"]}
            alt={item.alt ?? null}
            class="projects__img"
            id={item.id}
            loading="eager"
            quality={70}
            width={2000}
            height={1000}
            widths={[400, 800, 1200, 1600]}
            sizes="(max-width: 768px) 100vw, (max-width: 1200px) 50vw, 33vw"
          />
        </div>
      ))
    }
  </div>
</div>

<style lang="scss">
  .projects {
    &__img-wrapper {
      overflow: hidden;
      border-radius: var(--border-radius-small);
      cursor: pointer;
      aspect-ratio: 1/1;
      padding: 0px !important;

      picture {
        display: block;
        width: 100%;
        height: 100%;
        transition: transform 0.3s ease;
      }
    }
  }
</style>

<script is:inline>
  document.addEventListener("DOMContentLoaded", function () {
    const imageWrappers = document.querySelectorAll(".projects__img-wrapper");

    imageWrappers.forEach(item => {
      const img = item.querySelector("img");
      if (img) {
        img.addEventListener("click", function () {
          // Use the global LighthouseGalleryModal function
          if (window.LighthouseGalleryModal) {
            window.LighthouseGalleryModal.open(img.src, img.alt || "Gallery Image");
          }
        });
      }
    });
  });
</script>
