---
import Heading from "@/components/Heading.astro";
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";

interface CardItem {
  title: string;
  description: string;
  icon: ImageMetadata;
  iconAlt: string;
}

interface Props {
  cardData: CardItem[];
}

const { cardData } = Astro.props as Props;
---

<div class="card-grid grid-auto-3">
  {
    cardData.map(card => (
      <div class="card-grid__card">
        <div class="card-grid__icon">
          <Image src={card.icon} alt={card.iconAlt} />
        </div>
        <div class="card-grid__content">
          <Heading tag="h3" size="m" fontFamily="primary" marginBottom="m" weight="fw500">
            {card.title}
          </Heading>
          <p>{card.description}</p>
        </div>
      </div>
    ))
  }
</div>

<style lang="scss">
  .card-grid {
    &__card {
      padding: 1rem;
      border-radius: var(--border-radius-small);
      background-color: var(--light-100);
      display: flex;
      flex-direction: column;
      gap: var(--_spacing---space--6);
    }

    &__icon {
      width: 60px;
      height: 60px;
      background: var(--brand-primary);
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      flex-shrink: 0;
      border: 1px solid var(--dark-900);

      @media screen and (max-width: 768px) {
        width: 40px;
        height: 40px;
      }

      img {
        width: 32px;
        height: 32px;
        filter: invert(1);

        @media screen and (max-width: 768px) {
          width: 25px;
          height: 25px;
        }
      }
    }

    &__content {
      text-align: left;
    }
  }
</style>
