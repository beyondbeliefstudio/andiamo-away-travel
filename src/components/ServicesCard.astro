---
// HELPERS
import { getCollection } from "astro:content";
import { Picture } from "astro:assets";

// COMPONENTS
import Heading from "@/components/Heading.astro";

// PROPS
interface Props {
  descriptionType?: "short" | "full";
}

const { descriptionType = "short" } = Astro.props;

// DATA
const services = await getCollection("services");
---

{
  services.map(({ data }) => (
    <div class="services-card">
      <div class="services-card__img-wrapper">
        <Picture
          src={data.image as any}
          formats={["avif", "webp"]}
          alt={data.imageAlt}
          class="services-card__image"
          loading="lazy"
          quality={60}
          width={800}
          height={400}
          widths={[340, 400, 800]}
          sizes="(max-width: 768px) 340px, 400px"
        />
      </div>
      <div class="services-card__content">
        <div class="services-card__info">
          <Heading tag="h3" size="m" fontFamily="primary" marginBottom="s" weight="fw500">
            {data.title}
          </Heading>
          {descriptionType === "short" ? (
            <p>{data.shortDescription}</p>
          ) : (
            <>
              <p>{data.description}</p>
              <ul class="services-card__features">
                {data.features.map((feature: string) => (
                  <li>
                    <p>{feature}</p>
                  </li>
                ))}
              </ul>
            </>
          )}
        </div>
      </div>
    </div>
  ))
}

<style lang="scss">
  .services-card {
    padding: 1rem;
    padding-bottom: 0.5rem;
    border-radius: var(--border-radius-small);
    background-color: var(--light-200);
    display: flex;
    flex-direction: column;
    gap: 1rem;
    transition: 0.3s ease all;
    text-decoration: none;
    color: inherit;

    &__img-wrapper {
      aspect-ratio: 2 / 1;
      overflow: hidden;
      object-fit: cover;
      border-radius: 5px;
    }

    &__image {
      transition: transform 0.3s ease;
    }

    &__content {
      text-align: left;
      display: flex;
      gap: 0.5rem;
      flex-direction: row;
      align-items: center;
      justify-content: space-between;
    }

    &__features {
      list-style: none;
      padding: 0;
      margin: 1rem 0 0.5rem;
      display: flex;
      flex-direction: column;
      gap: 1rem;

      li {
        position: relative;
        padding-left: 2rem;

        p {
          margin-bottom: 0;
          line-height: 1.3;
        }

        &::before {
          content: "";
          position: absolute;
          left: 0;
          top: 0;
          width: 24px;
          height: 24px;
          background-color: var(--brand-primary);
          background-image: url("/src/assets/check.svg");
          background-size: 16px 16px;
          background-repeat: no-repeat;
          background-position: center;
          border-radius: 50%;
        }
      }
    }
  }
</style>
