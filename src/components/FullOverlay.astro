---
// COMPONENTS
import Heading from "@/components/Heading.astro";
import { Picture } from "astro:assets";

// HELPERS
import type { ImageMetadata } from "astro";

export interface Props {
  backgroundImage: ImageMetadata;
  bgOpacity?: number;
  overlayOpacity?: number;
}

const { backgroundImage } = Astro.props;
---

<section class="full-overlay">
  <!-- <div class="full-overlay__overlay"></div> -->
  <div class="container container-md">
    {
      backgroundImage && (
        <div class="full-overlay__bg">
          <Picture
            src={backgroundImage}
            formats={["avif", "webp"]}
            alt=""
            width={1920}
            height={1080}
            widths={[640, 1024, 1920]}
            sizes="100vw"
            quality={65}
            loading="lazy"
            decoding="async"
          />
        </div>
      )
    }
    <div class="content content-md">
      <slot />
    </div>
  </div>
</section>

<style lang="scss" is:global>
  .full-overlay {
    .container {
      position: relative;
      min-height: 65vh;
      display: flex;
      align-items: center;
      overflow: hidden;
      border-radius: var(--border-radius-small);
    }

    .content {
      padding: 2rem;
      border-radius: var(--border-radius-small);
      background: var(--glass);
      border: 1px solid var(--border-color);
      backdrop-filter: blur(18px);
    }

    &__bg {
      position: absolute;
      inset: 0;
      z-index: -1;

      :global(picture),
      :global(img) {
        width: 100%;
        height: 100%;
        object-fit: cover;
        object-position: center;
      }
    }

    &__overlay {
      position: absolute;
      inset: 0;
      background: rgba(26, 36, 29, 0.7);
      z-index: 1;
      pointer-events: none;
    }
  }
</style>
