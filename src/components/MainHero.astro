---
// COMPONENTS
import Heading from "@/components/Heading.astro";
import Links from "@/components/Links.astro";
import { Picture } from "astro:assets";

// IMAGES
import garageDoor from "@/assets/garage-door.jpg";
import seanLamboHero from "@/assets/seanLamboHero.png";
---

<section class="hero">
  <div class="hero__bg">
    <Picture
      src={garageDoor}
      formats={["avif", "webp"]}
      alt="Professional garage door installation"
      loading="eager"
      quality={70}
      width={1920}
      height={1080}
      widths={[768, 1200, 1600, 1920]}
      sizes="100vw"
      fetchpriority="high"
      decoding="async"
    />
  </div>
  <div class="hero__overlay"></div>
  <div class="container container-md hero__graphic--wrapper">
    <Picture
      src={seanLamboHero}
      formats={["png", "webp"]}
      alt="Lambo and owner illustration"
      class="hero__graphic"
      loading="eager"
      quality={100}
      width={600}
      height={550}
      widths={[250, 400, 600]}
      sizes="(max-width: 768px) 250px, 600px"
    />
  </div>
  <div class="container container-md hero__container">
    <div class="column column-main flex-1">
      <div class="content-lg hero__content">
        <div class="hero__reviews">
          <div class="hero__reviews-wrapper">
            <img
              src="https://www.gstatic.com/images/branding/product/1x/googleg_24dp.png"
              alt="Google"
              class="hero__reviews-logo"
            />
            <div class="hero__reviews-stars">
              <span>★★★★★</span>
            </div>
          </div>
          <p class="hero__reviews-text small">4.9 Based on 59+ Reviews</p>
        </div>
        <Heading tag="h1" size="xxl" fontFamily="primary" marginBottom="l" weight="fw500"
          >Fast, Professional Garage Door Repair You Can Trust</Heading
        >
        <ul class="hero__key-points">
          <li><p>Fast Repairs for Broken Springs and Stuck Garage Doors</p></li>
          <li><p>Same Day Repair and 24 Hour Emergency Service</p></li>
          <li><p>Local, Owner-Operated Service With Honest Pricing</p></li>
        </ul>
        <div class="btn-wrapper btn-wrapper--left">
          <Links variant="primary" href={"tel:+19312229963"}>Call (931) 222-9963</Links>
          <Links href="/services" variant="outline">Our Services</Links>
        </div>
      </div>
    </div>

    <style lang="scss">
      .hero {
        position: relative;
        z-index: 9;
        display: flex;
        align-items: center;
        justify-content: center;
        margin-top: 53px;
        overflow: hidden;

        @media screen and (max-width: 1010px) {
          margin-top: 42px;
        }

        &__bg {
          position: absolute;
          top: 0;
          left: 0;
          right: 0;
          bottom: 0;
          z-index: 0;
          opacity: 0.4;

          :global(img) {
            width: 100%;
            height: 100%;
            object-fit: cover;
            object-position: center;
          }
        }

        &__overlay {
          position: absolute;
          top: 0;
          left: 0;
          right: 0;
          bottom: 0;
          z-index: 1;
          pointer-events: none;
          background: rgba(255 255 255 / 0.2);
          mix-blend-mode: lighten;
        }

        &__graphic--wrapper {
          position: absolute;
          bottom: 0;
          height: fit-content;
        }

        &__graphic {
          position: absolute;
          bottom: 0px;
          right: 0;
          max-width: 600px;
          width: 45%;
          height: auto;
          z-index: 2;
          pointer-events: none;

          :global(img) {
            width: 100%;
            height: auto;
          }

          @media (max-width: 768px) {
            max-width: 250px;
            width: 50%;
          }
        }

        &__container {
          padding-top: var(--_spacing---section-space--xl);
          padding-bottom: var(--_spacing---section-space--xl);
          position: relative;
          z-index: 2;
          margin-top: 3rem;
          margin-bottom: 3rem;

          @media screen and (max-width: 768px) {
            margin-bottom: 134px;
          }
        }

        .img-wrapper {
          width: 100%;
          border-radius: var(--border-radius-medium);
          overflow: hidden;
          height: 100%;
          aspect-ratio: 16 / 9;
        }

        .column {
          position: relative;
          z-index: 2;
        }

        &__content {
          text-align: left;
          margin-left: 0;

          .eyebrow {
            background-color: var(--light-200);
            color: var(--brand-primary-dark);
          }
        }

        &__reviews {
          display: flex;
          align-items: center;
          gap: 0.75rem;
          background: rgba(255, 255, 255, 0.95);
          padding: 0.5rem;
          border-radius: var(--border-radius-small);
          width: fit-content;
          margin-bottom: 1.5rem;
          box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);

          @media screen and (max-width: 768px) {
            padding: 0.5rem;
            gap: 0.5rem;
          }
        }

        &__reviews-wrapper {
          width: 100%;
          display: flex;
          flex-direction: row;
          align-items: center;
          gap: 0.75rem;

          @media screen and (max-width: 768px) {
            gap: 0.5rem;
          }
        }

        &__reviews-logo {
          width: 24px;
          height: 24px;

          @media screen and (max-width: 768px) {
            width: 18px;
            height: 18px;
          }
        }

        &__reviews-stars {
          display: flex;

          span {
            color: #fbbc04;
            font-size: 1.1rem;
            letter-spacing: 2px;
            line-height: 1;

            @media screen and (max-width: 768px) {
              font-size: 0.9rem;
            }
          }
        }

        &__reviews-text {
          margin: 0;
          color: var(--dark-900) !important;
          font-weight: 600;
          line-height: 1;
          min-width: fit-content;
        }

        &__title {
          width: fit-content;
          margin-left: auto;
          letter-spacing: 0px;
          padding: 0.5rem;
          border-radius: 5px;
          margin-right: auto;
        }

        &__key-points {
          list-style: none;
          padding: 0;
          margin: 1.5rem 0;
          display: grid;
          gap: 1rem;

          li {
            position: relative;
            background: var(--light-100);
            width: fit-content;
            padding: 0.5rem;
            display: flex;
            flex-direction: row;
            gap: 0.5rem;
            align-items: center;
            border-radius: var(--border-radius-small);

            p {
              font-size: var(--_typography---font-size--h6);
              font-family: var(--primary-family);
              margin-bottom: 0;
              font-weight: 400;
              text-transform: uppercase;
              letter-spacing: 0.5px;
              width: 100%;
              text-wrap: auto;
              line-height: 1.3;
            }

            &::before {
              content: "";
              display: block;
              left: 0;
              top: 0;
              width: 24px;
              height: 24px;
              background-color: var(--brand-primary);
              background-image: url("/src/assets/check.svg");
              background-size: 16px 16px;
              background-repeat: no-repeat;
              background-position: center;
              border-radius: 50%;
            }
          }
        }
      }
    </style>
  </div>
</section>
