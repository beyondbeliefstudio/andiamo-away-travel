---
// HELPERS
import { Image, Picture } from "astro:assets";

// COMPONENTS
import Heading from "@/components/Heading.astro";
import Links from "@/components/Links.astro";

// IMAGES
import heroCarpet from "@/assets/hero_carpet.jpg";
import carpetHero from "@/assets/carpetHero.jpg";
import angiCertified from "@/assets/angi-certified-logo.svg";
---

<section aria-label="title" class="hero bg-dark">
  <div class="container container-md">
    <div class="content-full hero__grid">
      <div class="hero__col hero__content">
        <div class="hero__content-bottom">
          <Heading
            tag="h1"
            size="xs"
            fontFamily="secondary"
            marginBottom="s"
            weight="fw800"
            textTransform="uppercase"
            class="internal-hero__title">Trusted Carpet Cleaning in Monroe</Heading
          >
          <Heading
            tag="h2"
            size="display"
            fontFamily="primary"
            marginBottom="s"
            weight="fw800"
            textTransform="uppercase"
            lineHeight={1}
          >
            We Clean Anything You Don’t Want To
          </Heading>
          <Heading
            tag="h3"
            size="xs"
            fontFamily="secondary"
            marginBottom="none"
            weight="fw500"
            lineHeight={1.25}
          >
            Veteran-owned carpet and floor cleaning in Monroe. Over 25 years of experience helping
            homes and businesses get back to clean. If it’s stained, worn down, or just overdue,
            we’ll take care of it.
          </Heading>
          <ul class="hero__key-points">
            <li><p>Remove stains, odors, and built-up grime</p></li>
            <li><p>Restore carpets, floors, and surfaces</p></li>
            <li><p>Get it done right without the runaround</p></li>
          </ul>
          <div class="btn-wrapper btn-wrapper--left">
            <Links
              variant="light"
              href="/contact"
              ariaLabel="Schedule your carpet cleaning in Monroe, NC">Get A Free Quote</Links
            >
            <Links
              variant="outline-light"
              href="/services"
              ariaLabel="View our carpet cleaning services in Monroe, NC">View Our Services</Links
            >
          </div>
        </div>
      </div>
      <div class="hero__col">
        <div class="hero__reviews">
          <div class="hero__reviews-wrapper">
            <Image
              src={angiCertified}
              alt="Angi Certified logo"
              class="hero__reviews-logo"
              width={24}
              height={24}
            />
          </div>
          <p class="hero__reviews-text">Angi Approved</p>
        </div>
        <div class="hero__img-wrapper">
          <Picture
            src={carpetHero}
            formats={["avif", "webp"]}
            alt="Carpet cleaning hero image"
            class="hero__img"
            loading="lazy"
            quality={65}
            width={800}
            height={800}
            widths={[400, 600, 800]}
            sizes="(max-width: 768px) 100vw, (max-width: 1010px) 90vw, 50vw"
          />
        </div>
      </div>
    </div>
  </div>
</section>

<style lang="scss" is:global>
  .hero {
    &__grid {
      display: grid;
      gap: var(--_spacing---section-space--main);
      grid-template-columns: 1fr 1fr;
      min-height: 50vh;

      @media (max-width: 1010px) {
        grid-template-columns: 1fr;
      }
    }

    &__col {
      display: flex;
      flex-direction: column;
      justify-content: center;
      height: 100%;
      position: relative;
    }

    &__img-wrapper {
      width: 100%;
      height: 100%;
      position: relative;
      margin-right: 0;
      margin-left: auto;
      overflow: hidden;
      border-radius: var(--border-radius-small);
    }

    &__content {
      text-align: left;
      text-wrap: pretty;
      display: flex;
      flex-direction: column;
      align-items: start;
      justify-content: center;
      padding: 5rem 0;
      h3 {
        margin-top: 1rem;
      }

      h4 {
        margin-bottom: 0.25rem;
        line-height: 1;
        font-size: 1.1rem;
        font-weight: 500;
      }
    }

    .btn {
      width: fit-content;
    }

    &__reviews {
      display: flex;
      align-items: center;
      gap: 0.75rem;
      background: rgba(255, 255, 255, 0.95);
      padding: 0.5rem;
      border-radius: var(--border-radius-small);
      width: fit-content;
      margin-bottom: 1.5rem;
      box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
      position: absolute;
      bottom: 1rem;
      right: 1rem;
      z-index: 999;
      margin-bottom: 0;

      @media screen and (max-width: 768px) {
        padding: 0.5rem;
        gap: 0.5rem;
      }
    }

    &__reviews-wrapper {
      width: 100%;
      display: flex;
      flex-direction: row;
      align-items: center;
      gap: 0.75rem;

      @media screen and (max-width: 768px) {
        gap: 0.5rem;
      }
    }

    &__reviews-logo {
      width: 24px;
      height: 24px;
      object-fit: contain;

      @media screen and (max-width: 768px) {
        width: 18px;
        height: 18px;
      }
    }

    &__reviews-text {
      margin: 0;
      color: var(--dark-900) !important;
      font-weight: 600;
      line-height: 1;
      min-width: fit-content;
    }

    &__key-points {
      list-style: none;
      padding: 0;
      margin: 1.5rem 0;
      display: grid;
      gap: 0;

      li {
        position: relative;
        width: fit-content;
        padding: 0.5rem;
        padding-left: 0;
        display: flex;
        flex-direction: row;
        gap: 0.5rem;
        align-items: center;

        p {
          font-size: var(--_typography---font-size--h5);
          font-family: var(--primary-family);
          margin-bottom: 0;
          font-weight: 700;
          text-transform: uppercase;
          letter-spacing: 0.5px;
          width: 100%;
          text-wrap: auto;
          line-height: 1.3;
        }

        &::before {
          content: "";
          display: block;
          left: 0;
          top: 0;
          width: 24px;
          height: 24px;
          background-color: var(--brand-primary);
          background-image: url("/src/assets/check.svg");
          background-size: 16px 16px;
          background-repeat: no-repeat;
          background-position: center;
          border-radius: 50%;
          aspect-ratio: 1/1;
        }
      }
    }
  }
</style>
