---
// HELPERS
import { Picture } from "astro:assets";

// COMPONENTS
import Heading from "@/components/Heading.astro";
import Links from "@/components/Links.astro";

// IMAGES
import heroCarpet from "@/assets/hero_carpet.jpg";
---

<section aria-label="title" class="hero bg-light">
  <div class="container container-lg">
    <div class="content-full hero__grid">
      <div class="hero__col hero__content">
        <div class="hero__content-bottom">
          <div class="hero__reviews">
            <div class="hero__reviews-wrapper">
              <img
                src="https://www.gstatic.com/images/branding/product/1x/googleg_24dp.png"
                alt="Google"
                class="hero__reviews-logo"
              />
              <div class="hero__reviews-stars">
                <span>★★★★★</span>
              </div>
            </div>
            <p class="hero__reviews-text small">5 Based on 90+ Reviews</p>
          </div>
          <Heading tag="h1" size="display" fontFamily="secondary" marginBottom="m" weight="fw800">
            Carpet Cleaning & Restoration That Delivers Results
          </Heading>
          <Heading
            tag="h2"
            size="s"
            fontFamily="primary"
            marginBottom="none"
            weight="fw400"
            lineHeight={1.25}
          >
            Carpet, tile, grout, upholstery, and water damage cleanup with fast response times and
            24/7 emergency service.
          </Heading>
          <ul class="hero__key-points">
            <li><p>Locally Owned and Operated</p></li>
            <li><p>24/7 Emergency Service</p></li>
            <li><p>Licensed and Insured</p></li>
          </ul>
          <div class="btn-wrapper btn-wrapper--left">
            <Links
              variant="primary"
              href="/contact"
              ariaLabel="Schedule your carpet cleaning in Monroe, NC">Schedule Your Cleaning</Links
            >
            <Links
              variant="outline"
              href="/services"
              ariaLabel="View our carpet cleaning services in Monroe, NC">View Our Services</Links
            >
          </div>
        </div>
      </div>
      <div class="hero__col">
        <div class="hero__img-wrapper">
          <Picture
            src={heroCarpet}
            formats={["avif", "webp"]}
            alt="Carpet cleaning hero image"
            class="hero__img"
            loading="lazy"
            quality={65}
            width={800}
            height={800}
            widths={[400, 600, 800]}
            sizes="(max-width: 768px) 100vw, (max-width: 1010px) 90vw, 50vw"
          />
        </div>
      </div>
    </div>
  </div>
</section>

<style lang="scss" is:global>
  .hero {
    &__grid {
      display: grid;
      gap: var(--_spacing---section-space--main);
      grid-template-columns: 1fr 1fr;
      min-height: 50vh;

      @media (max-width: 1010px) {
        grid-template-columns: 1fr;
      }
    }

    &__col {
      display: flex;
      flex-direction: column;
      justify-content: center;
      height: 100%;
      position: relative;
    }

    &__img-wrapper {
      width: 100%;
      height: 100%;
      position: relative;
      margin-right: 0;
      margin-left: auto;
      overflow: hidden;
      border-radius: var(--border-radius-small);
    }

    &__content {
      text-align: left;
      text-wrap: pretty;
      background-color: var(--light-200);
      display: flex;
      flex-direction: column;
      align-items: start;
      justify-content: center;

      h3 {
        margin-top: 1rem;
      }

      h4 {
        margin-bottom: 0.25rem;
        line-height: 1;
        font-size: 1.1rem;
        font-weight: 500;
      }
    }

    &__eyebrow {
      width: fit-content;
      letter-spacing: 0px;
      width: fit-content;
      letter-spacing: 1px;
      background: var(--light-200);
      padding: 0.5rem 0.5rem;
      border-radius: 5px;
    }

    .btn {
      width: fit-content;
    }

    &__reviews {
      display: flex;
      align-items: center;
      gap: 0.75rem;
      background: rgba(255, 255, 255, 0.95);
      padding: 0.5rem;
      border-radius: var(--border-radius-small);
      width: fit-content;
      margin-bottom: 1.5rem;
      box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);

      @media screen and (max-width: 768px) {
        padding: 0.5rem;
        gap: 0.5rem;
      }
    }

    &__reviews-wrapper {
      width: 100%;
      display: flex;
      flex-direction: row;
      align-items: center;
      gap: 0.75rem;

      @media screen and (max-width: 768px) {
        gap: 0.5rem;
      }
    }

    &__reviews-logo {
      width: 24px;
      height: 24px;

      @media screen and (max-width: 768px) {
        width: 18px;
        height: 18px;
      }
    }

    &__reviews-stars {
      display: flex;

      span {
        color: #fbbc04;
        font-size: 1.1rem;
        letter-spacing: 2px;
        line-height: 1;

        @media screen and (max-width: 768px) {
          font-size: 0.9rem;
        }
      }
    }

    &__reviews-text {
      margin: 0;
      color: var(--dark-900) !important;
      font-weight: 600;
      line-height: 1;
      min-width: fit-content;
    }

    &__key-points {
      list-style: none;
      padding: 0;
      margin: 1.5rem 0;
      display: grid;
      gap: 0;

      li {
        position: relative;
        width: fit-content;
        padding: 0.5rem;
        padding-left: 0;
        display: flex;
        flex-direction: row;
        gap: 0.5rem;
        align-items: center;

        p {
          font-size: var(--_typography---font-size--h6);
          font-family: var(--primary-family);
          margin-bottom: 0;
          font-weight: 700;
          text-transform: uppercase;
          letter-spacing: 0.5px;
          width: 100%;
          text-wrap: auto;
          line-height: 1.3;
        }

        &::before {
          content: "";
          display: block;
          left: 0;
          top: 0;
          width: 24px;
          height: 24px;
          background-color: var(--brand-primary);
          background-image: url("/src/assets/check.svg");
          background-size: 16px 16px;
          background-repeat: no-repeat;
          background-position: center;
          border-radius: 50%;
          aspect-ratio: 1/1;
        }
      }
    }
  }
</style>
