---
// HELPERS
import { Image, Picture } from "astro:assets";

// COMPONENTS
import Heading from "@/components/Heading.astro";
import Links from "@/components/Links.astro";

// IMAGES
import heroGraphic from "@/assets/hero__graphic.svg";
import tuscanyImage from "@/assets/tuscany.jpg";
import nancyPhoto from "@/assets/nancy-photo.jpeg";
---

<section aria-label="title" class="hero">
  <!-- Background decorative elements -->
  <div class="hero__bg-graphics">
    <img src={heroGraphic.src} alt="" aria-hidden="true" class="hero__bg-graphic" />
  </div>

  <!-- Hero content -->
  <div class="container container-md">
    <div class="content-full hero__grid">
      <!-- Left Side -->
      <div class="hero__col hero__content">
        <div class="hero__content-bottom">
          <Heading
            tag="h1"
            size="xs"
            fontFamily="primary"
            marginBottom="s"
            weight="fw500"
            textTransform="uppercase"
            class="eyebrow">Personalized Travel Planning</Heading
          >
          <Heading
            tag="h2"
            size="xxl"
            fontFamily="primary"
            marginBottom="l"
            weight="fw500"
            textTransform="capitalize"
            lineHeight={1}
          >
            Travel Better With Someone In Your Corner
          </Heading>
          <p class="large">
            From cruises and luxury resorts to unforgettable European adventures, Andiamo Away helps
            travelers plan seamless vacations with expert guidance, personalized recommendations,
            and support every step of the way.
          </p>
          <div class="btn-wrapper btn-wrapper--left">
            <Links
              variant="primary"
              href="#contact"
              ariaLabel="Schedule your trip with Andiamo Away">Start Planning Your Trip</Links
            >
          </div>
        </div>
      </div>

      <!-- Right Side -->
      <div class="hero__col">
        <div class="hero__polaroid">
          <div class="hero__img-wrapper">
            <Picture
              src={nancyPhoto}
              formats={["avif", "webp"]}
              alt="Tuscany hero image"
              class="hero__img"
              loading="lazy"
              quality={65}
              width={800}
              height={800}
              widths={[400, 600, 800]}
              sizes="(max-width: 768px) 100vw, (max-width: 1010px) 90vw, 50vw"
            />
          </div>
          <p>Let's travel!</p>
        </div>
      </div>
    </div>
  </div>
</section>

<style lang="scss">
  .hero {
    overflow: hidden;
    position: relative;

    &__bg-graphics {
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      bottom: 0;
      pointer-events: none;
      z-index: 1;
    }

    &__bg-graphic {
      position: absolute;
      top: 140px;
      left: 0;
      opacity: 0.4;
      width: 100%;
      height: auto;
      min-width: 800px;
      transition: opacity 0.3s ease;
      object-fit: cover;
      object-position: top left;

      @media (max-width: 1024px) {
        min-width: 700px;
        opacity: 0.7;
      }

      @media (max-width: 768px) {
        min-width: 600px;
        opacity: 0.6;
      }

      @media (max-width: 480px) {
        min-width: 500px;
        opacity: 0.5;
      }
    }

    &__grid {
      display: grid;
      gap: var(--_spacing---section-space--main);
      grid-template-columns: 1fr 1fr;

      @media (max-width: 1010px) {
        grid-template-columns: 1fr;
      }
    }

    &__col {
      display: flex;
      flex-direction: column;
      justify-content: center;
      height: 100%;
      position: relative;
      z-index: 9;
    }

    &__content {
      text-align: left;
      text-wrap: pretty;
      display: flex;
      flex-direction: column;
      align-items: start;
      justify-content: center;
      padding: 5rem 0;

      @media screen and (max-width: 768px) {
        padding: 0rem 0 1rem;
      }

      h3 {
        margin-top: 1rem;
      }

      h4 {
        margin-bottom: 0.25rem;
        line-height: 1;
        font-size: 1.1rem;
        font-weight: 500;
      }
    }

    .btn-wrapper {
      margin-top: 2rem;
    }

    .btn {
      width: fit-content;
    }

    &__img-wrapper {
      position: relative;
      overflow: hidden;
      aspect-ratio: 1/1;
    }

    &__polaroid {
      background: #fff;
      padding: 1rem;
      padding-bottom: 0;
      border-radius: 0;
      transform: rotate(1deg);
      filter: drop-shadow(2px 4px 15px rgba(20, 20, 20, 0.1));
      width: 100%;

      p {
        height: 6rem;
        width: 100%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 3rem;
        font-family: var(--secondary-family);

        @media (max-width: 768px) {
          height: 4rem;
          font-size: 2rem;
          padding-top: 0.5rem;
        }
      }
    }
  }
</style>
