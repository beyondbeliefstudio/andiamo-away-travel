---
// COMPONENTS
import { Picture } from "astro:assets";
import Heading from "@/components/Heading.astro";

// IMAGES
import luxuryResortImg from "@/assets/trip-types/luxury-resort.jpg";
import cruisesImg from "@/assets/trip-types/cruises.jpg";
import europeanAdventuresImg from "@/assets/trip-types/european-adventures.jpg";
import familyVacationsImg from "@/assets/trip-types/family-vacations.jpg";
import honeymoonsImg from "@/assets/trip-types/honeymoons.jpg";
import golfTripsImg from "@/assets/trip-types/golf-trips.jpg";
import manarolaCinqueTerreImg from "@/assets/manarola_cinque_terre_italy.jpg";
import golfTrips from "@/assets/golfTrips.jpg";
import milestones from "@/assets/milestones.jpg";
import global from "@/assets/trip-types/chianti_vineyard_hilltop_tuscany_italy.jpeg";

import type { HTMLAttributes } from "astro/types";

export interface ProcessStepsProps extends HTMLAttributes<"section"> {
  classes?: string;
}

const { classes, ...rest } = Astro.props;

const tripTypes = [
  {
    id: "luxury-all-inclusive",
    number: "01",
    title: "Luxury & All-Inclusive Resorts",
    description:
      "Beautiful destinations designed for relaxation, comfort, and unforgettable experiences.",
    img: luxuryResortImg,
    imgAlt: "Aerial view of a luxury beachfront resort with multiple pools and palm trees",
  },
  {
    id: "cruises",
    number: "02",
    title: "Cruises",
    description: "Ocean and river cruises tailored to your travel style, pace, and interests.",
    img: cruisesImg,
    imgAlt: "Large cruise ship sailing across open ocean on a bright day",
  },
  {
    id: "global-adventures",
    number: "03",
    title: "Global Adventures",
    description: "Custom trips filled with culture, food, history, and once-in-a-lifetime moments.",
    img: global,
    imgAlt:
      "Traveler exploring a scenic vineyard hilltop in Chianti, Tuscany, Italy with rolling hills and cypress trees",
  },
  {
    id: "family-vacations",
    number: "04",
    title: "Family Vacations",
    description: "Stress-free travel planning designed to make family memories easier to enjoy.",
    img: manarolaCinqueTerreImg,
    imgAlt: "Family walking together on a beach during vacation",
  },
  {
    id: "milestone-celebrations",
    number: "05",
    title: "Milestone & Celebration Trips",
    description:
      "Thoughtfully planned trips for honeymoons, anniversaries, bachelorettes, and milestone moments.",
    img: milestones,
    imgAlt: "Couple celebrating a milestone on a tropical beach with turquoise water",
  },
  {
    id: "golf-trips",
    number: "06",
    title: "Golf Trips",
    description:
      "Scenic golf getaways to world-class courses and resorts, planned around your game.",
    img: golfTrips,
    imgAlt: "Aerial view of a scenic golf course with rolling fairways and sand bunkers",
  },
];
---

<section class:list={["trip-types", classes]} {...rest}>
  <div class="container container-md column-main">
    <div class="content-lg">
      <Heading
        tag="h2"
        size="xs"
        fontFamily="primary"
        marginBottom="m"
        weight="fw700"
        class="eyebrow"
      >
        Trip Types
      </Heading>
      <Heading tag="h2" size="xl" fontFamily="primary" marginBottom="m" weight="fw500">
        Explore The Trip Types We Love Planning
      </Heading>
      <p>From cruises to custom Europe itineraries, we plan travel that fits your style.</p>
    </div>
    <div class="content-full">
      <div class="trip-types__main grid-auto-3" id="trip-types-container">
        <!-- Steps -->
        {
          tripTypes.map((trip, index) => (
            <div class="trip-types__content">
              <div class="trip-types__img-wrapper">
                <Picture
                  src={trip.img}
                  formats={["avif", "webp"]}
                  alt={trip.imgAlt}
                  width={600}
                  height={600}
                  widths={[300, 450, 600]}
                  sizes="(max-width: 768px) 100vw, (max-width: 1024px) 50vw, 33vw"
                  loading="lazy"
                  quality={70}
                  class="trip-types__image"
                />
              </div>
              <div class="trip-types__text">
                <Heading
                  tag="h3"
                  size="xs"
                  fontFamily="primary"
                  marginBottom="s"
                  weight="fw600"
                  textTransform="uppercase"
                  class="trip-types__heading"
                >
                  {trip.title}
                </Heading>
                <p class="trip-types__description small">{trip.description}</p>
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </div>

  <style lang="scss">
    .trip-types {
      &__main {
        gap: 1rem;
      }

      &__content {
        display: flex;
        flex-direction: column;
        align-items: center;
        text-align: center;
      }

      &__text {
        background: var(--light-100);
        width: calc(100% - 2rem);
        margin: auto;
        margin-top: -1rem;
        padding: 1rem;
        border-radius: var(--border-radius-medium);
        text-wrap: balance;
      }

      &__heading {
        text-transform: uppercase !important;
        letter-spacing: 3px;
      }

      &__description {
        line-height: 1.3;
      }

      &__img-wrapper {
        border-radius: 500px 500px 8px 8px;
        overflow: hidden;
        aspect-ratio: 1 / 1;
        width: 100%;

        picture {
          display: block;
          width: 100%;
          height: 100%;
        }
      }

      &__image {
        display: block;
        width: 100%;
        height: 100%;
        object-fit: cover;
      }

      .eyebrow {
        margin-inline: auto;
      }
    }
  </style>
</section>
