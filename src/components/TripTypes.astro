---
// COMPONENTS
import { Picture } from "astro:assets";
import Heading from "@/components/Heading.astro";

// IMAGES
import luxuryResortImg from "@/assets/trip-types/luxury-resort.jpg";
import cruisesImg from "@/assets/trip-types/cruises.jpg";
import europeanAdventuresImg from "@/assets/trip-types/european-adventures.jpg";
import familyVacationsImg from "@/assets/trip-types/family-vacations.jpg";
import honeymoonsImg from "@/assets/trip-types/honeymoons.jpg";
import disneyDestinationsImg from "@/assets/trip-types/disney-destinations.jpg";

import type { HTMLAttributes } from "astro/types";

export interface ProcessStepsProps extends HTMLAttributes<"section"> {
  classes?: string;
}

const { classes, ...rest } = Astro.props;

const tripTypes = [
  {
    id: "luxury-all-inclusive",
    number: "01",
    title: "Luxury & All-Inclusive Resorts",
    description:
      "Beautiful destinations designed for relaxation, comfort, and unforgettable experiences.",
    img: luxuryResortImg,
    imgAlt: "Aerial view of a luxury beachfront resort with multiple pools and palm trees",
  },
  {
    id: "cruises",
    number: "02",
    title: "Cruises",
    description: "Ocean and river cruises tailored to your travel style, pace, and interests.",
    img: cruisesImg,
    imgAlt: "Large cruise ship sailing across open ocean on a bright day",
  },
  {
    id: "european-adventures",
    number: "03",
    title: "European Adventures",
    description: "Custom trips filled with culture, food, history, and once-in-a-lifetime moments.",
    img: europeanAdventuresImg,
    imgAlt: "Dramatic coastal landscape in Scotland representing European adventure travel",
  },
  {
    id: "family-vacations",
    number: "04",
    title: "Family Vacations",
    description: "Stress-free travel planning designed to make family memories easier to enjoy.",
    img: familyVacationsImg,
    imgAlt: "Family walking together on a beach during vacation",
  },
  {
    id: "honeymoons-romantic-getaways",
    number: "05",
    title: "Honeymoons & Romantic Getaways",
    description: "Thoughtfully planned escapes designed around meaningful experiences together.",
    img: honeymoonsImg,
    imgAlt: "Couple holding hands on a tropical beach with turquoise water",
  },
  {
    id: "disney-destinations",
    number: "06",
    title: "Disney Destinations",
    description: "Magical vacations made simpler with expert guidance and planning support.",
    img: disneyDestinationsImg,
    imgAlt: "Iconic Disney castle viewed from below against a bright sky",
  },
];
---

<section class:list={["trip-types", classes]} {...rest}>
  <div class="container container-md column-main">
    <div class="content-lg">
      <Heading
        tag="h2"
        size="xs"
        fontFamily="primary"
        marginBottom="m"
        weight="fw700"
        class="eyebrow"
      >
        Trip Types
      </Heading>
      <Heading tag="h2" size="xl" fontFamily="primary" marginBottom="m" weight="fw500">
        Explore The Trip Types We Love Planning
      </Heading>
      <p>From cruises to custom Europe itineraries, we plan travel that fits your style.</p>
    </div>
    <div class="content-full">
      <div class="trip-types__main grid-auto-3" id="trip-types-container">
        <!-- Steps -->
        {
          tripTypes.map((trip, index) => (
            <div class="trip-types__content">
              <div class="trip-types__img-wrapper">
                <Picture
                  src={trip.img}
                  alt={trip.imgAlt}
                  width={800}
                  height={600}
                  loading="lazy"
                  class="trip-types__image"
                />
              </div>
              <div class="trip-types__text">
                <Heading
                  tag="h3"
                  size="xs"
                  fontFamily="primary"
                  marginBottom="s"
                  weight="fw600"
                  textTransform="uppercase"
                  class="trip-types__heading"
                >
                  {trip.title}
                </Heading>
                <p class="trip-types__description small">{trip.description}</p>
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </div>

  <style lang="scss">
    .trip-types {
      &__main {
        gap: var(--_spacing---section-space--small);
      }

      &__content {
        display: flex;
        flex-direction: column;
        align-items: center;
        text-align: center;
      }

      &__text {
        background: var(--light-100);
        width: calc(100% - 2rem);
        margin: auto;
        margin-top: -1rem;
        padding: 1rem;
        border-radius: var(--border-radius-medium);
      }

      &__heading {
        text-transform: uppercase !important;
        letter-spacing: 3px;
      }

      &__description {
        line-height: 1.3;
      }

      &__img-wrapper {
        border-radius: 500px 500px 8px 8px;
        overflow: hidden;
        aspect-ratio: 1 / 1;
      }

      .eyebrow {
        margin-inline: auto;
      }
    }
  </style>
</section>
